---
import Layout from "../layouts/Layout.astro";
---

<Layout 
  title="Cien Mares | Experiencias Náuticas Premium en Cádiz"
  description="Servicios náuticos de excelencia en Conil de la Frontera. Alquiler de embarcaciones, academia homologada, gestoría y traslados internacionales desde 2010."
>
  <main class="home">
    
    <!-- ═══════════════════════════════════════════════════════════════════════
         HERO — Immersive Fullscreen Experience
         ═══════════════════════════════════════════════════════════════════════ -->
    <section class="hero">
      <div class="hero-backdrop">
        <div class="hero-image-container">
          <img 
            src="https://images.unsplash.com/photo-1544551763-46a013bb70d5?w=2400&q=90" 
            alt="Yacht sailing on Mediterranean waters"
            class="hero-image"
          />
        </div>
        <div class="hero-gradient-overlay"></div>
        <div class="hero-wave-overlay">
          <svg class="wave wave-back" viewBox="0 0 1440 320" preserveAspectRatio="none">
            <path fill="rgba(212, 168, 83, 0.1)" d="M0,192L48,197.3C96,203,192,213,288,229.3C384,245,480,267,576,250.7C672,235,768,181,864,181.3C960,181,1056,235,1152,234.7C1248,235,1344,181,1392,154.7L1440,128L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path>
          </svg>
          <svg class="wave wave-mid" viewBox="0 0 1440 320" preserveAspectRatio="none">
            <path fill="rgba(212, 168, 83, 0.05)" d="M0,64L48,80C96,96,192,128,288,128C384,128,480,96,576,106.7C672,117,768,171,864,186.7C960,203,1056,181,1152,165.3C1248,149,1344,139,1392,133.3L1440,128L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path>
          </svg>
        </div>
      </div>
      
      <div class="hero-content-wrapper">
        <div class="container">
          <div class="hero-content">
            <div class="hero-eyebrow reveal-up">
              <span class="eyebrow-line"></span>
              <span class="eyebrow-text">Conil de la Frontera, Cádiz</span>
            </div>
            <h1 class="hero-title">
              <span class="title-line reveal-up" data-delay="1">Navega</span>
              <span class="title-line reveal-up" data-delay="2">sin límites</span>
            </h1>
            <p class="hero-desc reveal-up" data-delay="3">
              Desde 2010, creamos experiencias náuticas inolvidables en el corazón 
              de la costa gaditana. Excelencia, pasión y el mar como compañero.
            </p>
            <div class="hero-cta reveal-up" data-delay="4">
              <a href="/alquiler" class="btn btn-primary">
                <span>Explorar flota</span>
                <svg class="btn-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
              <a href="/contacto" class="btn btn-glass">
                <span>Contactar</span>
              </a>
            </div>
          </div>
        </div>
      </div>
      
      <div class="hero-scroll-indicator">
        <div class="scroll-mouse">
          <div class="scroll-wheel"></div>
        </div>
        <span class="scroll-text">Descubre</span>
      </div>
      
      <div class="hero-stats-float">
        <div class="stat-bubble reveal-scale" data-delay="5">
          <span class="bubble-number">14</span>
          <span class="bubble-label">Años de<br/>excelencia</span>
        </div>
      </div>
    </section>
    
    <!-- ═══════════════════════════════════════════════════════════════════════
         INTRO — Asymmetric Storytelling
         ═══════════════════════════════════════════════════════════════════════ -->
    <section class="intro section-ocean">
      <div class="intro-bg-pattern"></div>
      <div class="container">
        <div class="intro-grid">
          <div class="intro-visual">
            <div class="intro-image-frame">
              <div class="intro-image-wrap img-reveal">
                <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?w=1000&q=85" alt="Luxury yacht experience" />
              </div>
              <div class="intro-image-accent"></div>
            </div>
            <div class="intro-badge reveal-right" data-delay="2">
              <div class="badge-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
                </svg>
              </div>
              <div class="badge-content">
                <span class="badge-number">500+</span>
                <span class="badge-text">Aventuras<br/>realizadas</span>
              </div>
            </div>
          </div>
          
          <div class="intro-content">
            <div class="section-tag reveal-up">
              <span class="tag-number">01</span>
              <span class="tag-line"></span>
              <span class="tag-text">Nuestra esencia</span>
            </div>
            <h2 class="intro-title reveal-up" data-delay="1">
              Donde la pasión<br/>
              <span class="title-accent">encuentra el mar</span>
            </h2>
            <div class="intro-body">
              <p class="reveal-up" data-delay="2">
                <strong>Cien Mares</strong> nació de una obsesión: compartir la magia del 
                Atlántico. Desde nuestro puerto base en Conil de la Frontera, hemos 
                perfeccionado el arte de las experiencias náuticas durante más de una década.
              </p>
              <p class="reveal-up" data-delay="3">
                Nuestra flota de embarcaciones de primera categoría y nuestro equipo 
                de profesionales titulados garantizan que cada salida sea una aventura 
                inolvidable por las aguas más espectaculares de Andalucía.
              </p>
            </div>
            <div class="intro-features reveal-up" data-delay="4">
              <div class="feature-item">
                <div class="feature-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                </div>
                <span>Tripulación experta</span>
              </div>
              <div class="feature-item">
                <div class="feature-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                </div>
                <span>Embarcaciones premium</span>
              </div>
              <div class="feature-item">
                <div class="feature-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                </div>
                <span>Rutas exclusivas</span>
              </div>
            </div>
            <a href="/nosotros" class="link-magnetic reveal-up" data-delay="5">
              <span>Conócenos mejor</span>
              <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>
    
    <!-- ═══════════════════════════════════════════════════════════════════════
         SERVICES — Floating Cards with Depth
         ═══════════════════════════════════════════════════════════════════════ -->
    <section class="services section-pearl">
      <div class="services-header-bg">
        <svg class="services-wave" viewBox="0 0 1440 200" preserveAspectRatio="none">
          <path fill="var(--ocean-light)" d="M0,64L60,80C120,96,240,128,360,128C480,128,600,96,720,85.3C840,75,960,85,1080,101.3C1200,117,1320,139,1380,149.3L1440,160L1440,0L1380,0C1320,0,1200,0,1080,0C960,0,840,0,720,0C600,0,480,0,360,0C240,0,120,0,60,0L0,0Z"></path>
        </svg>
      </div>
      
      <div class="container">
        <div class="services-header">
          <div class="section-tag reveal-up">
            <span class="tag-number">02</span>
            <span class="tag-line"></span>
            <span class="tag-text">Servicios</span>
          </div>
          <h2 class="services-title reveal-up" data-delay="1">
            Cuatro formas de<br/>
            <span class="title-gradient">vivir el mar</span>
          </h2>
        </div>
        
        <div class="services-grid">
          <article class="service-card reveal-up" data-delay="2">
            <div class="service-visual">
              <div class="service-image-wrap img-reveal">
                <img src="https://images.unsplash.com/photo-1569263979104-865ab7cd8d13?w=800&q=85" alt="Alquiler de embarcaciones" />
              </div>
              <div class="service-number">01</div>
              <div class="service-shine"></div>
            </div>
            <div class="service-content">
              <div class="service-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M3 17h18M3 17l3-8h12l3 8M8 17v4m8-4v4m-4-4v4"/>
                </svg>
              </div>
              <h3>Alquiler</h3>
              <p>Veleros, lanchas y yates para cada aventura. Con o sin patrón, tu experiencia náutica comienza aquí.</p>
              <a href="/alquiler" class="service-link">
                <span>Ver flota</span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </article>
          
          <article class="service-card reveal-up" data-delay="3">
            <div class="service-visual">
              <div class="service-image-wrap img-reveal">
                <img src="https://images.unsplash.com/photo-1534447677768-be436bb09401?w=800&q=85" alt="Academia náutica" />
              </div>
              <div class="service-number">02</div>
              <div class="service-shine"></div>
            </div>
            <div class="service-content">
              <div class="service-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M12 14l9-5-9-5-9 5 9 5z"/>
                  <path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/>
                </svg>
              </div>
              <h3>Academia</h3>
              <p>Titulaciones oficiales homologadas. Desde Licencia de Navegación hasta Capitán de Yate.</p>
              <a href="/academia" class="service-link">
                <span>Ver cursos</span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </article>
          
          <article class="service-card reveal-up" data-delay="4">
            <div class="service-visual">
              <div class="service-image-wrap img-reveal">
                <img src="https://images.unsplash.com/photo-1554224155-6726b3ff858f?w=800&q=85" alt="Gestoría náutica" />
              </div>
              <div class="service-number">03</div>
              <div class="service-shine"></div>
            </div>
            <div class="service-content">
              <div class="service-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
              </div>
              <h3>Gestoría</h3>
              <p>Inscripciones, certificados, titularidades. Todo el papeleo náutico, gestionado por expertos.</p>
              <a href="/gestoria" class="service-link">
                <span>Ver servicios</span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </article>
          
          <article class="service-card reveal-up" data-delay="5">
            <div class="service-visual">
              <div class="service-image-wrap img-reveal">
                <img src="https://images.unsplash.com/photo-1500930287596-c1ecaa373bb2?w=800&q=85" alt="Traslados de embarcaciones" />
              </div>
              <div class="service-number">04</div>
              <div class="service-shine"></div>
            </div>
            <div class="service-content">
              <div class="service-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
                </svg>
              </div>
              <h3>Traslados</h3>
              <p>Transporte nacional e internacional de embarcaciones. Tripulación experta y seguro completo.</p>
              <a href="/traslados" class="service-link">
                <span>Solicitar info</span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </article>
        </div>
      </div>
    </section>
    
    <!-- ═══════════════════════════════════════════════════════════════════════
         EXPERIENCE SHOWCASE — Immersive Dark Section
         ═══════════════════════════════════════════════════════════════════════ -->
    <section class="showcase section-deep">
      <div class="showcase-backdrop">
        <div class="showcase-image-wrap">
          <img 
            src="https://images.unsplash.com/photo-1533105079780-92b9be482077?w=2400&q=85" 
            alt="Mediterranean coastline"
            class="showcase-image parallax-img"
            data-speed="0.04"
          />
        </div>
        <div class="showcase-overlay"></div>
        <div class="showcase-vignette"></div>
      </div>
      
      <div class="container">
        <div class="showcase-content">
          <div class="showcase-tag reveal-up">
            <span class="tag-star">✦</span>
            <span>Experiencia</span>
          </div>
          <blockquote class="showcase-quote reveal-up" data-delay="1">
            <span class="quote-mark">"</span>
            El mar, una vez que lanza su hechizo, nos retiene para siempre en su red de maravilla.
            <span class="quote-mark closing">"</span>
          </blockquote>
          <div class="showcase-author reveal-up" data-delay="2">
            <div class="author-avatar">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="12" cy="8" r="4"/>
                <path d="M4 20c0-4 4-6 8-6s8 2 8 6"/>
              </svg>
            </div>
            <div class="author-info">
              <cite>Jacques Cousteau</cite>
              <span>Explorador oceánico</span>
            </div>
          </div>
        </div>
      </div>
      
      <div class="showcase-decoration">
        <div class="deco-circle"></div>
        <div class="deco-line"></div>
      </div>
    </section>
    
    <!-- ═══════════════════════════════════════════════════════════════════════
         GALLERY — Masonry with Hover Reveals
         ═══════════════════════════════════════════════════════════════════════ -->
    <section class="gallery section-ocean">
      <div class="container">
        <div class="gallery-header">
          <div class="section-tag reveal-up">
            <span class="tag-number">03</span>
            <span class="tag-line"></span>
            <span class="tag-text">Galería</span>
          </div>
          <h2 class="gallery-title reveal-up" data-delay="1">
            Momentos que<br/>
            <span class="title-accent">trascienden</span>
          </h2>
        </div>
      </div>
      
      <div class="gallery-masonry">
        <div class="gallery-item gallery-item-featured img-reveal">
          <img src="https://images.unsplash.com/photo-1605281317010-fe5ffe79ba66?w=1200&q=85" alt="Sailing at sunset" />
          <div class="gallery-item-overlay">
            <div class="overlay-content">
              <span class="overlay-tag">Atardecer</span>
              <h4>Atlántico Sur</h4>
            </div>
          </div>
        </div>
        
        <div class="gallery-column">
          <div class="gallery-item img-reveal" data-delay="1">
            <img src="https://images.unsplash.com/photo-1544551763-77ef2d0cfc6c?w=800&q=85" alt="Yacht deck" />
            <div class="gallery-item-overlay">
              <div class="overlay-content">
                <span class="overlay-tag">Lujo</span>
                <h4>Detalles</h4>
              </div>
            </div>
          </div>
          <div class="gallery-item img-reveal" data-delay="2">
            <img src="https://images.unsplash.com/photo-1540946485063-a40da27545f8?w=800&q=85" alt="Navigation" />
            <div class="gallery-item-overlay">
              <div class="overlay-content">
                <span class="overlay-tag">Aventura</span>
                <h4>Navegación</h4>
              </div>
            </div>
          </div>
        </div>
        
        <div class="gallery-column">
          <div class="gallery-item img-reveal" data-delay="3">
            <img src="https://images.unsplash.com/photo-1507525428034-b723cf961d3e?w=800&q=85" alt="Crystal waters" />
            <div class="gallery-item-overlay">
              <div class="overlay-content">
                <span class="overlay-tag">Paraíso</span>
                <h4>Aguas cristalinas</h4>
              </div>
            </div>
          </div>
          <div class="gallery-item img-reveal" data-delay="4">
            <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?w=800&q=85" alt="Marina" />
            <div class="gallery-item-overlay">
              <div class="overlay-content">
                <span class="overlay-tag">Puerto</span>
                <h4>Conil de la Frontera</h4>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
    
    <!-- ═══════════════════════════════════════════════════════════════════════
         STATS — Animated Counter Grid
         ═══════════════════════════════════════════════════════════════════════ -->
    <section class="stats section-gold">
      <div class="stats-pattern"></div>
      <div class="container">
        <div class="stats-grid">
          <div class="stat-card reveal-scale">
            <div class="stat-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="12" cy="12" r="10"/>
                <path d="M12 6v6l4 2"/>
              </svg>
            </div>
            <div class="stat-content">
              <span class="stat-number" data-count="14">0</span>
              <span class="stat-suffix">+</span>
            </div>
            <span class="stat-label">Años de experiencia</span>
          </div>
          
          <div class="stat-card reveal-scale" data-delay="1">
            <div class="stat-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
              </svg>
            </div>
            <div class="stat-content">
              <span class="stat-number" data-count="500">0</span>
              <span class="stat-suffix">+</span>
            </div>
            <span class="stat-label">Alumnos formados</span>
          </div>
          
          <div class="stat-card reveal-scale" data-delay="2">
            <div class="stat-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div class="stat-content">
              <span class="stat-number" data-count="98">0</span>
              <span class="stat-suffix">%</span>
            </div>
            <span class="stat-label">Tasa de éxito</span>
          </div>
          
          <div class="stat-card reveal-scale" data-delay="3">
            <div class="stat-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M3 17h18M3 17l3-8h12l3 8"/>
              </svg>
            </div>
            <div class="stat-content">
              <span class="stat-number" data-count="15">0</span>
            </div>
            <span class="stat-label">Embarcaciones</span>
          </div>
        </div>
      </div>
    </section>
    
    <!-- ═══════════════════════════════════════════════════════════════════════
         LOCATION — Interactive Map Section
         ═══════════════════════════════════════════════════════════════════════ -->
    <section class="location section-pearl">
      <div class="container">
        <div class="location-grid">
          <div class="location-content">
            <div class="section-tag reveal-up">
              <span class="tag-number">04</span>
              <span class="tag-line"></span>
              <span class="tag-text">Ubicación</span>
            </div>
            <h2 class="location-title reveal-up" data-delay="1">
              Conil de<br/>
              <span class="title-accent">la Frontera</span>
            </h2>
            <p class="location-desc reveal-up" data-delay="2">
              Nuestro puerto base se encuentra en uno de los enclaves más 
              privilegiados de la costa gaditana, con acceso directo a las 
              mejores rutas náuticas del sur de España.
            </p>
            <div class="location-coords reveal-up" data-delay="3">
              <div class="coord-card">
                <div class="coord-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <circle cx="12" cy="12" r="3"/>
                    <path d="M12 2v4m0 12v4M2 12h4m12 0h4"/>
                  </svg>
                </div>
                <div class="coord-data">
                  <span class="coord-label">Latitud</span>
                  <span class="coord-value">36°16'N</span>
                </div>
              </div>
              <div class="coord-card">
                <div class="coord-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <circle cx="12" cy="12" r="3"/>
                    <path d="M12 2v4m0 12v4M2 12h4m12 0h4"/>
                  </svg>
                </div>
                <div class="coord-data">
                  <span class="coord-label">Longitud</span>
                  <span class="coord-value">6°05'O</span>
                </div>
              </div>
            </div>
            <a href="https://maps.google.com/?q=Conil+de+la+Frontera+Cádiz" target="_blank" class="btn btn-primary reveal-up" data-delay="4">
              <span>Cómo llegar</span>
