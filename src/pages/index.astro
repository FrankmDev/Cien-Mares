---
/**
 * Cien Mares - Homepage
 * 
 * Arquitectura: Component-based sections con:
 * - TypeScript stricto
 * - Scripts GSAP extraídos a archivos dedicados
 * - Componentes UI atómicos reutilizables
 * - Constantes compartidas (colores, easing, etc.)
 * - Cleanup apropiado de animaciones
 */

import Layout from '@/layouts/Layout.astro';
import {
	HeroSection,
	StorySection,
	ServicesSection,
	MethodologySection,
	TestimonialsSection,
	CTASection,
} from '@/components/home';

// ═══════════════════════════════════════════════════════════════════════════════
// PAGE METADATA
// ═══════════════════════════════════════════════════════════════════════════════

const pageMeta = {
	title: "Cien Mares | Experiencias Náuticas Premium en Cádiz",
	description:
		"Servicios náuticos de excelencia en Conil de la Frontera. Alquiler de embarcaciones, academia homologada, gestoría y traslados internacionales desde 2010.",
};
---

<Layout
	title={pageMeta.title}
	description={pageMeta.description}
	transparentHeader={true}
>
	<main class="home">
		<HeroSection />
		<StorySection />
		<ServicesSection />
		<MethodologySection />
		<TestimonialsSection />
		<CTASection />
	</main>
</Layout>

<style>
	.home {
		position: relative;
		overflow-x: hidden;
		background-color: #050505;
	}
</style>
