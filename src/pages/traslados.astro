---
import Layout from "../layouts/Layout.astro";
---

<Layout 
  title="Traslados Internacionales | Cien Mares"
  description="Servicio exclusivo de transporte de embarcaciones. Tripulación experta, seguro completo y seguimiento GPS. Cádiz, Canarias, Mediterráneo, Portugal, Italia."
>
  <main class="traslados-page">
    
    <!-- ═══════════════════════════════════════════════════════════════
         HERO SECTION — LIGHT — Airy & International
         ═══════════════════════════════════════════════════════════════ -->
    <section class="hero-traslados">
      <div class="hero-bg">
        <img 
          src="https://images.unsplash.com/photo-1500930287596-c1ecaa373bb2?w=2400&q=85&auto=format&fit=crop" 
          alt="Yacht at sea"
          class="hero-image"
        />
        <div class="hero-overlay"></div>
      </div>
      
      <div class="hero-content">
        <div class="hero-meta reveal">
          <span class="label-line"></span>
          <span>Logística Premium</span>
        </div>
        
        <h1 class="hero-title reveal" data-delay="1">
          Traslados Internacionales
        </h1>
        
        <p class="hero-subtitle reveal" data-delay="2">
          Su embarcación, donde usted la necesite. Servicio concierge de transporte 
          náutico con tripulación certificada, seguros premium y seguimiento en tiempo real.
        </p>
        
        <div class="hero-cta reveal" data-delay="3">
          <a href="#presupuesto" class="btn btn-primary">
            <span>Solicitar presupuesto</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M7 17L17 7M17 7H7M17 7V17"/>
            </svg>
          </a>
          <a href="tel:+34605183785" class="btn btn-outline">
            <span>+34 605 18 37 85</span>
          </a>
        </div>
      </div>
      
      <div class="hero-scroll">
        <div class="scroll-line"></div>
      </div>
    </section>
    
    <!-- ═══════════════════════════════════════════════════════════════
         FEATURES SECTION — LIGHT — Four Pillars
         ═══════════════════════════════════════════════════════════════ -->
    <section class="features-section">
      <div class="container-wide">
        <div class="section-header">
          <span class="label reveal">Por qué elegirnos</span>
          <h2 class="section-title reveal" data-delay="1">
            Excelencia en cada milla
          </h2>
        </div>
        
        <div class="features-grid">
          <article class="feature-card reveal" data-delay="1">
            <div class="feature-icon">
              <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1">
                <path d="M24 4L27 18H41L30 26L33 40L24 32L15 40L18 26L7 18H21L24 4Z"/>
                <circle cx="24" cy="24" r="20" stroke-dasharray="4 4"/>
              </svg>
            </div>
            <h3 class="feature-title">Tripulación Experta</h3>
            <p class="feature-desc">Patrones y capitanes certificados con miles de millas navegadas en travesías oceánicas y mediterráneas.</p>
          </article>
          
          <article class="feature-card reveal" data-delay="2">
            <div class="feature-icon">
              <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1">
                <path d="M24 44C24 44 40 36 40 20C40 11.163 32.837 4 24 4C15.163 4 8 11.163 8 20C8 36 24 44 24 44Z"/>
                <path d="M17 20L22 25L32 15" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3 class="feature-title">Seguro Completo</h3>
            <p class="feature-desc">Cobertura premium todo riesgo durante todo el traslado. Su embarcación protegida en cada milla.</p>
          </article>
          
          <article class="feature-card reveal" data-delay="3">
            <div class="feature-icon">
              <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1">
                <circle cx="24" cy="24" r="20"/>
                <path d="M24 12V24L32 28" stroke-linecap="round"/>
                <circle cx="24" cy="24" r="4" fill="currentColor"/>
              </svg>
            </div>
            <h3 class="feature-title">Seguimiento GPS</h3>
            <p class="feature-desc">Localización en tiempo real las 24 horas. Informes diarios de posición, estado del mar y condiciones.</p>
          </article>
          
          <article class="feature-card reveal" data-delay="4">
            <div class="feature-icon">
              <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1">
                <circle cx="24" cy="24" r="20"/>
                <path d="M12 24C12 24 16 14 24 14C32 14 36 24 36 24C36 24 32 34 24 34C16 34 12 24 12 24Z"/>
                <circle cx="24" cy="24" r="4" fill="currentColor"/>
                <path d="M24 4V10M44 24H38M24 44V38M4 24H10" stroke-linecap="round"/>
              </svg>
            </div>
            <h3 class="feature-title">Cualquier Destino</h3>
            <p class="feature-desc">Desde Cádiz a cualquier puerto del mundo. Mediterráneo, Atlántico, Canarias, Caribe y más allá.</p>
          </article>
        </div>
      </div>
    </section>
    
    <!-- ═══════════════════════════════════════════════════════════════
         DESTINATIONS SECTION — LIGHT — Asymmetric Grid
         ═══════════════════════════════════════════════════════════════ -->
    <section class="destinations-section" id="destinos">
      <div class="container">
        <div class="section-header center">
          <span class="label reveal">Destinos</span>
          <h2 class="section-title reveal" data-delay="1">
            Rutas principales
          </h2>
          <p class="section-subtitle reveal" data-delay="2">
            Desde Cádiz, conectamos su embarcación con los destinos más exclusivos del Mediterráneo y el Atlántico.
          </p>
        </div>
      </div>
      
      <div class="destinations-grid container-wide">
        <!-- Mediterranean Spain — Large Feature -->
        <article class="destination-card destination-featured reveal-left">
          <div class="destination-image">
            <img 
              src="https://images.unsplash.com/photo-1533105079780-92b9be482077?w=1400&q=85&auto=format&fit=crop" 
              alt="Mediterráneo Español"
            />
            <div class="destination-overlay">
              <span class="destination-tag">Nacional</span>
            </div>
          </div>
          <div class="destination-content">
            <span class="destination-distance">350—650 MN</span>
            <h3 class="destination-title">Mediterráneo Español</h3>
            <p class="destination-desc">
              Traslados entre puertos del litoral mediterráneo: Barcelona, Valencia, Alicante, 
              Islas Baleares, Málaga y Cartagena.
            </p>
            <div class="destination-routes">
              <span class="route-tag">Cádiz → Baleares</span>
              <span class="route-tag">Cádiz → Barcelona</span>
              <span class="route-tag">Cádiz → Málaga</span>
            </div>
          </div>
        </article>
        
        <!-- Canary Islands -->
        <article class="destination-card reveal">
          <div class="destination-image">
            <img 
              src="https://images.unsplash.com/photo-1518548419970-58e3b4079ab2?w=800&q=85&auto=format&fit=crop" 
              alt="Islas Canarias"
            />
            <div class="destination-overlay">
              <span class="destination-tag">Nacional</span>
            </div>
          </div>
          <div class="destination-content">
            <span class="destination-distance">750—850 MN</span>
            <h3 class="destination-title">Islas Canarias</h3>
            <p class="destination-desc">
              Travesía oceánica desde Cádiz hasta el archipiélago canario. Tenerife, Lanzarote, Gran Canaria.
            </p>
            <div class="destination-routes">
              <span class="route-tag">Cádiz → Tenerife</span>
              <span class="route-tag">Cádiz → Lanzarote</span>
            </div>
          </div>
        </article>
        
        <!-- Portugal -->
        <article class="destination-card reveal" data-delay="1">
          <div class="destination-image">
            <img 
              src="https://images.unsplash.com/photo-1555881400-74d7acaacd8b?w=800&q=85&auto=format&fit=crop" 
              alt="Portugal"
            />
            <div class="destination-overlay">
              <span class="destination-tag">Internacional</span>
            </div>
          </div>
          <div class="destination-content">
            <span class="destination-distance">180—400 MN</span>
            <h3 class="destination-title">Portugal</h3>
            <p class="destination-desc">
              Rutas al Algarve y Lisboa. Destino frecuente para armadores europeos que buscan nuevas rutas.
            </p>
            <div class="destination-routes">
              <span class="route-tag">Cádiz → Algarve</span>
              <span class="route-tag">Cádiz → Lisboa</span>
            </div>
          </div>
        </article>
        
        <!-- French Mediterranean -->
        <article class="destination-card reveal">
          <div class="destination-image">
            <img 
              src="https://images.unsplash.com/photo-1499856871958-5b9627545d1a?w=800&q=85&auto=format&fit=crop" 
              alt="Mediterráneo Francés"
            />
            <div class="destination-overlay">
              <span class="destination-tag">Internacional</span>
            </div>
          </div>
          <div class="destination-content">
            <span class="destination-distance">500—750 MN</span>
            <h3 class="destination-title">Mediterráneo Francés</h3>
            <p class="destination-desc">
              Traslados a puertos de la Costa Azul: Marsella, Cannes, Saint-Tropez, y Córcega.
            </p>
            <div class="destination-routes">
              <span class="route-tag">Cádiz → Marsella</span>
              <span class="route-tag">Cádiz → Córcega</span>
            </div>
          </div>
        </article>
        
        <!-- Italy & Croatia — Large Feature -->
        <article class="destination-card destination-featured reveal-right">
          <div class="destination-image">
            <img 
              src="https://images.unsplash.com/photo-1516483638261-f4dbaf036963?w=1400&q=85&auto=format&fit=crop" 
              alt="Italia y Croacia"
            />
            <div class="destination-overlay">
              <span class="destination-tag">Internacional</span>
            </div>
          </div>
          <div class="destination-content">
            <span class="destination-distance">900—1.200 MN</span>
            <h3 class="destination-title">Italia y Croacia</h3>
            <p class="destination-desc">
              Travesías al Adriático: desde Venecia hasta Dubrovnik, pasando por Sicilia, 
              Cerdeña y las costas de Amalfi.
            </p>
            <div class="destination-routes">
              <span class="route-tag">Cádiz → Cerdeña</span>
              <span class="route-tag">Cádiz → Sicilia</span>
              <span class="route-tag">Cádiz → Croacia</span>
            </div>
          </div>
        </article>
      </div>
    </section>
    
    <!-- ═══════════════════════════════════════════════════════════════
         PROCESS SECTION — LIGHT — 4 Steps
         ═══════════════════════════════════════════════════════════════ -->
    <section class="process-section">
      <div class="container">
        <div class="section-header center">
          <span class="label reveal">Proceso</span>
          <h2 class="section-title reveal" data-delay="1">
            Así trabajamos
          </h2>
        </div>
        
        <div class="process-timeline">
          <div class="timeline-line reveal-scale"></div>
          
          <div class="process-steps">
            <article class="process-step reveal">
              <div class="step-number">01</div>
              <div class="step-content">
                <h3 class="step-title">Consulta</h3>
                <p class="step-desc">
                  Analizamos sus necesidades: origen, destino, tipo de embarcación y calendario. 
                  Presupuesto detallado en 24 horas.
                </p>
              </div>
              <div class="step-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                </svg>
              </div>
            </article>
            
            <article class="process-step reveal" data-delay="1">
              <div class="step-number">02</div>
              <div class="step-content">
                <h3 class="step-title">Planificación</h3>
                <p class="step-desc">
                  Estudiamos la ruta óptima, condiciones meteorológicas, puertos intermedios 
                  y asignamos la tripulación especializada.
                </p>
              </div>
              <div class="step-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7"/>
                </svg>
              </div>
            </article>
            
            <article class="process-step reveal" data-delay="2">
              <div class="step-number">03</div>
              <div class="step-content">
                <h3 class="step-title">Embarque</h3>
                <p class="step-desc">
                  Inspección completa de la embarcación, firma de documentación y salida. 
                  Comienza el seguimiento GPS en tiempo real.
                </p>
              </div>
              <div class="step-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M13 10V3L4 14h7v7l9-11h-7z"/>
                </svg>
              </div>
            </article>
            
            <article class="process-step reveal" data-delay="3">
              <div class="step-number">04</div>
              <div class="step-content">
                <h3 class="step-title">Entrega</h3>
                <p class="step-desc">
                  Llegada al destino, inspección final y entrega de documentación. 
                  Su embarcación lista para navegar.
                </p>
              </div>
              <div class="step-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
            </article>
          </div>
        </div>
      </div>
    </section>
    
    <!-- ═══════════════════════════════════════════════════════════════
         QUOTE SECTION — DARK — Sophisticated Form (contrast)
         ═══════════════════════════════════════════════════════════════ -->
    <section class="quote-section" id="presupuesto">
      <div class="container">
        <div class="quote-grid">
          <div class="quote-info reveal-left">
            <span class="label">Presupuesto</span>
            <h2 class="quote-title">
              Solicite su traslado
            </h2>
            <p class="quote-desc">
              Cuéntenos los detalles de su traslado y le prepararemos un presupuesto 
              detallado sin compromiso. Incluye tripulación, combustible, puertos 
              intermedios y seguro premium.
            </p>
            
            <div class="quote-features">
              <div class="quote-feature">
                <div class="feature-check">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <span>Respuesta en 24h</span>
              </div>
              <div class="quote-feature">
                <div class="feature-check">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <span>Sin compromiso</span>
              </div>
              <div class="quote-feature">
                <div class="feature-check">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <span>Precio cerrado</span>
              </div>
            </div>
          </div>
          
          <form class="quote-form reveal-right" action="/contacto" method="POST">
            <div class="form-row">
              <div class="form-group">
                <label class="form-label" for="origen">Puerto de origen</label>
                <input 
                  type="text" 
                  id="origen" 
                  name="origen" 
                  class="form-input" 
                  placeholder="Ej: Puerto de Cádiz"
                  required 
                />
              </div>
              <div class="form-group">
                <label class="form-label" for="destino">Puerto de destino</label>
                <input 
                  type="text" 
                  id="destino" 
                  name="destino" 
                  class="form-input" 
                  placeholder="Ej: Palma de Mallorca"
                  required 
                />
              </div>
            </div>
            
            <div class="form-row">
              <div class="form-group">
                <label class="form-label" for="nombre">Nombre completo</label>
                <input 
                  type="text" 
                  id="nombre" 
                  name="nombre" 
                  class="form-input" 
                  required 
                />
              </div>
              <div class="form-group">
                <label class="form-label" for="email">Email</label>
                <input 
                  type="email" 
                  id="email" 
                  name="email" 
                  class="form-input" 
                  required 
                />
              </div>
            </div>
            
            <div class="form-row">
              <div class="form-group">
                <label class="form-label" for="telefono">Teléfono</label>
                <input 
                  type="tel" 
                  id="telefono" 
                  name="telefono" 
                  class="form-input" 
                  required 
                />
              </div>
              <div class="form-group">
                <label class="form-label" for="embarcacion">Embarcación</label>
                <input 
                  type="text" 
                  id="embarcacion" 
                  name="embarcacion" 
                  class="form-input" 
                  placeholder="Tipo, modelo y eslora"
                />
              </div>
            </div>
            
            <div class="form-row">
              <div class="form-group">
                <label class="form-label" for="fecha">Fecha deseada</label>
                <input 
                  type="date" 
                  id="fecha" 
                  name="fecha" 
                  class="form-input" 
                />
              </div>
              <div class="form-group">
                <label class="form-label" for="flexibilidad">Flexibilidad</label>
                <select id="flexibilidad" name="flexibilidad" class="form-select">
                  <option value="exacta">Fecha exacta</option>
                  <option value="semana">± 1 semana</option>
                  <option value="mes">± 1 mes</option>
                </select>
              </div>
            </div>
            
            <div class="form-group">
              <label class="form-label" for="mensaje">Detalles adicionales</label>
              <textarea 
                id="mensaje" 
                name="mensaje" 
                class="form-textarea" 
                rows="3" 
                placeholder="Condiciones especiales, equipamiento adicional, requisitos particulares..."
              ></textarea>
            </div>
            
            <button type="submit" class="btn btn-primary form-submit">
              <span>Solicitar presupuesto</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </button>
          </form>
        </div>
      </div>
    </section>
    
  </main>
</Layout>

<style>
  /* ═══════════════════════════════════════════════════════════════
     TRASLADOS v3.5 — Airy · Sophisticated · Light-First
     ═══════════════════════════════════════════════════════════════ */
  
  /* ─── HERO SECTION — LIGHT ───────────────────────────────────── */
  .hero-traslados {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--ivory);
    overflow: hidden;
  }
  
  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  
  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.5) contrast(1.1) brightness(1.15);
  }
  
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(250, 250, 248, 0.9) 0%,
      rgba(250, 250, 248, 0.75) 50%,
      rgba(250, 250, 248, 0.95) 100%
    );
  }
  
  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 800px;
    padding: calc(var(--space-lg) + 80px) clamp(1.5rem, 5vw, 4rem) var(--space-xl);
  }
  
  .hero-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--gold);
  }
  
  .label-line {
    width: 40px;
    height: 1px;
    background: var(--gold);
  }
  
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--void);
    margin-bottom: 1.5rem;
  }
  
  .hero-subtitle {
    font-size: 1.0625rem;
    color: var(--stone);
    max-width: 550px;
    margin: 0 auto 2.5rem;
    line-height: 1.8;
  }
  
  .hero-cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  
  .hero-scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
  }
  
  .scroll-line {
    width: 1px;
    height: 60px;
    background: linear-gradient(180deg, var(--gold), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }
  
  @keyframes scrollPulse {
    0%, 100% { transform: scaleY(1); opacity: 0.6; }
    50% { transform: scaleY(0.6); opacity: 0.3; }
  }
  
  /* ─── SECTION HEADERS ────────────────────────────────────────── */
  .section-header {
    margin-bottom: var(--space-lg);
  }
  
  .section-header.center {
    text-align: center;
  }
  
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--void);
  }
  
  .section-subtitle {
    font-size: 1rem;
    color: var(--stone);
    max-width: 500px;
    margin: 1rem auto 0;
    line-height: 1.7;
  }
  
  /* ─── FEATURES SECTION — LIGHT ───────────────────────────────── */
  .features-section {
    padding: var(--space-xxl) 0;
    background: var(--ivory);
  }
  
  .container-wide {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 5vw, 4rem);
  }
  
  .features-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }
  
  .feature-card {
    padding: clamp(2rem, 4vw, 2.5rem);
    background: var(--white);
    border: 1px solid var(--mist);
    transition: all 0.5s var(--ease-out);
  }
  
  .feature-card:hover {
    border-color: var(--gold);
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.05);
  }
  
  .feature-icon {
    width: 48px;
    height: 48px;
    margin-bottom: 1.5rem;
    color: var(--gold);
  }
  
  .feature-icon svg {
    width: 100%;
    height: 100%;
  }
  
  .feature-title {
    font-family: var(--font-body);
    font-size: 1.0625rem;
