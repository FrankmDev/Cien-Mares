---
import Layout from "@/layouts/Layout.astro";
---

<Layout
  title="Página no encontrada | Cien Mares"
  description="La página que buscas no existe."
>
  <section
    class="min-h-screen flex items-center justify-center bg-[#050505] text-[#F2F2F2]"
    data-theme="dark"
  >
    <div class="text-center px-6">
      <span
        class="font-display font-black text-[clamp(6rem,20vw,12rem)] leading-none text-white/[0.06] block mb-4"
        >404</span
      >
      <h1
        class="font-display font-black text-[clamp(2rem,5vw,4rem)] leading-[0.9] tracking-tighter uppercase mb-4"
      >
        Página <span class="text-[#CFA35A]">no encontrada</span>
      </h1>
      <p class="font-body text-[#F2F2F2]/60 text-lg max-w-md mx-auto mb-8">
        Parece que te has perdido en alta mar. Te ayudamos a volver a puerto.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/"
          class="inline-flex items-center gap-3 px-8 py-4 bg-[#CFA35A] text-[#050505] font-display font-bold rounded-full hover:bg-[#E8CB8E] transition-colors"
        >
          Volver al inicio
        </a>
        <a
          href="/contacto"
          class="inline-flex items-center gap-3 px-8 py-4 border border-white/20 text-white font-display font-medium rounded-full hover:border-[#CFA35A] hover:text-[#CFA35A] transition-colors"
        >
          Contactar
        </a>
      </div>
      <p
        class="font-mono text-[0.6rem] uppercase tracking-[0.3em] text-white/30 mt-16 pt-8 border-t border-white/10"
      >
        36°31'N · 6°17'W · ERROR 404
      </p>
    </div>
  </section>
</Layout>
