---
import Layout from "@/layouts/Layout.astro";
---

<Layout
  title="Aprender | Cien Mares"
  description="Academia náutica homologada en Cádiz."
>
  <section
    class="min-h-screen flex items-center justify-center bg-[#FAFAFA] text-[#0A0A0A]"
    data-theme="light"
  >
    <div class="text-center px-6">
      <span
        class="font-mono text-[0.65rem] uppercase tracking-[0.3em] font-bold text-[#CFA35A] block mb-6"
        >Próximamente</span
      >
      <h1
        class="font-display font-black text-[clamp(2.5rem,6vw,5rem)] leading-[0.9] tracking-tighter uppercase mb-4"
      >
        Academia
      </h1>
      <p class="font-body text-[#0A0A0A]/60 text-lg max-w-md mx-auto">
        Estamos preparando esta sección. Vuelve pronto.
      </p>
      <a
        href="/"
        class="inline-flex items-center gap-3 mt-8 font-mono text-[0.65rem] uppercase tracking-[0.3em] font-bold text-[#CFA35A] hover:text-[#0A0A0A] transition-colors"
      >
        <span>← Volver al inicio</span>
      </a>
    </div>
  </section>
</Layout>
