---
import Layout from "../layouts/Layout.astro";
---

<Layout 
  title="Gestoría Náutica en Cádiz | Cien Mares"
  description="Gestoría náutica integral en Conil de la Frontera. Inscripciones, certificados, licencias, cambios de titularidad y trámites ante Capitanía. Abanderamiento en Polonia."
>
  <main class="gestoria-page">
    
    <!-- ═══════════════════════════════════════════════════════════════════════
         HERO — LIGHT SECTION — Airy & Sophisticated
         ═══════════════════════════════════════════════════════════════════════ -->
    <section class="hero-gestoria">
      <div class="hero-visual">
        <div class="hero-image-wrap">
          <img 
            src="https://images.unsplash.com/photo-1450101499163-c8848c66ca85?w=2400&q=85&auto=format&fit=crop" 
            alt="Documentación náutica y gestoría"
            class="hero-image"
          />
        </div>
        <div class="hero-overlay"></div>
      </div>
      
      <div class="container">
        <div class="hero-content">
          <div class="hero-label reveal">
            <span class="label-line"></span>
            <span>Trámites Oficiales</span>
          </div>
          
          <h1 class="hero-title reveal" data-delay="1">
            Gestoría Náutica
          </h1>
          
          <p class="hero-desc reveal" data-delay="2">
            Documentación de embarcaciones con la precisión de un reloj suizo. 
            Trámites ante Capitanía Marítima gestionados por expertos en Conil de la Frontera.
          </p>
          
          <div class="hero-features reveal" data-delay="3">
            <div class="hero-feature">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <span>Tasas incluidas</span>
            </div>
            <div class="hero-feature">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="12" cy="12" r="10"/>
                <path d="M12 6v6l4 2"/>
              </svg>
              <span>Plazos garantizados</span>
            </div>
            <div class="hero-feature">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
                <path d="M22 4L12 14.01l-3-3"/>
              </svg>
              <span>Asesoramiento personal</span>
            </div>
          </div>
          
          <div class="hero-cta reveal" data-delay="4">
            <a href="#servicios" class="btn btn-primary">Ver Servicios</a>
            <a href="tel:+34605183785" class="btn btn-outline">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
              </svg>
              <span>605 18 37 85</span>
            </a>
          </div>
        </div>
      </div>
      
      <div class="hero-scroll">
        <div class="scroll-line"></div>
      </div>
    </section>
    
    <!-- ═══════════════════════════════════════════════════════════════════════
         SERVICES — LIGHT SECTION — Elegant Menu Style
         ═══════════════════════════════════════════════════════════════════════ -->
    <section class="services-section" id="servicios">
      <div class="container">
        <div class="section-header">
          <span class="label reveal">Tarifas 2025</span>
          <h2 class="section-title reveal" data-delay="1">
            Servicios & Precios
          </h2>
          <p class="section-subtitle reveal" data-delay="2">
            Todos nuestros precios incluyen tasas oficiales de la 
            Dirección General de la Marina Mercante. Sin sorpresas.
          </p>
        </div>
        
        <div class="services-grid">
          <!-- Left Column -->
          <div class="services-column">
            <div class="service-category reveal">
              <span class="category-num">01</span>
              <h3 class="category-title">Inscripciones & Altas</h3>
            </div>
            
            <article class="service-item reveal" data-delay="1">
              <div class="service-info">
                <h4 class="service-name">Inscripción de embarcación</h4>
                <p class="service-desc">Alta completa en el Registro de Embarcaciones de Recreo. Incluye tasas administrativas y gestión documental.</p>
              </div>
              <div class="service-price">
                <span class="price-currency">€</span>
                <span class="price-value">130</span>
              </div>
            </article>
            
            <article class="service-item reveal" data-delay="2">
              <div class="service-info">
                <h4 class="service-name">Certificado de navegabilidad</h4>
                <p class="service-desc">Renovación del certificado de seguridad y navegabilidad. Vigencia 5 años.</p>
              </div>
              <div class="service-price">
                <span class="price-currency">€</span>
                <span class="price-value">120</span>
              </div>
            </article>
            
            <article class="service-item reveal" data-delay="3">
              <div class="service-info">
                <h4 class="service-name">Licencia de estación radioeléctrica</h4>
                <p class="service-desc">Tramitación de licencia para equipos VHF y sistemas de comunicación.</p>
              </div>
              <div class="service-price">
                <span class="price-currency">€</span>
                <span class="price-value">90</span>
              </div>
            </article>
            
            <div class="service-category reveal" data-delay="4">
              <span class="category-num">02</span>
              <h3 class="category-title">Gestión Fiscal</h3>
            </div>
            
            <article class="service-item reveal" data-delay="5">
              <div class="service-info">
                <h4 class="service-name">Gestión de impuestos IVTM</h4>
                <p class="service-desc">Asesoramiento y gestión del Impuesto sobre Determinados Medios de Transporte.</p>
              </div>
              <div class="service-price">
                <span class="price-currency">€</span>
                <span class="price-value">50</span>
              </div>
            </article>
          </div>
          
          <!-- Divider -->
          <div class="services-divider reveal">
            <div class="divider-line"></div>
            <div class="divider-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                <circle cx="12" cy="12" r="10"/>
                <circle cx="12" cy="12" r="3"/>
              </svg>
            </div>
            <div class="divider-line"></div>
          </div>
          
          <!-- Right Column -->
          <div class="services-column">
            <div class="service-category reveal">
              <span class="category-num">03</span>
              <h3 class="category-title">Modificaciones & Bajas</h3>
            </div>
            
            <article class="service-item reveal" data-delay="1">
              <div class="service-info">
                <h4 class="service-name">Cambio de titularidad</h4>
                <p class="service-desc">Transmisión de propiedad con inscripción del nuevo titular en el RER.</p>
              </div>
              <div class="service-price">
                <span class="price-currency">€</span>
                <span class="price-value">75</span>
              </div>
            </article>
            
            <article class="service-item reveal" data-delay="2">
              <div class="service-info">
                <h4 class="service-name">Renovación de permiso</h4>
                <p class="service-desc">Prórroga de licencias para navegación extranjera y permisos temporales.</p>
              </div>
              <div class="service-price">
                <span class="price-currency">€</span>
                <span class="price-value">55</span>
              </div>
            </article>
            
            <article class="service-item reveal" data-delay="3">
              <div class="service-info">
                <h4 class="service-name">Cambio de lista</h4>
                <p class="service-desc">Transferencia entre listas séptima y octava del Registro de Buques.</p>
              </div>
              <div class="service-price">
                <span class="price-currency">€</span>
                <span class="price-value">90</span>
              </div>
            </article>
            
            <article class="service-item reveal" data-delay="4">
              <div class="service-info">
                <h4 class="service-name">Baja de registro</h4>
                <p class="service-desc">Cancelación definitiva por desguace, exportación u otras causas.</p>
              </div>
              <div class="service-price">
                <span class="price-currency">€</span>
                <span class="price-value">90</span>
              </div>
            </article>
          </div>
        </div>
        
        <div class="services-note reveal">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="12" cy="12" r="10"/>
            <path d="M12 16v-4M12 8h.01"/>
          </svg>
          <p>Los precios incluyen tasas administrativas. Embarcaciones especiales o trámites complejos pueden requerir presupuesto adicional.</p>
        </div>
      </div>
    </section>
    
    <!-- ═══════════════════════════════════════════════════════════════════════
         POLAND — DARK SECTION — Flag Visualization (contrast)
         ═══════════════════════════════════════════════════════════════════════ -->
    <section class="poland-section" id="polonia">
      <div class="container">
        <div class="poland-grid">
          <div class="poland-visual reveal-left">
            <div class="flag-container">
              <div class="flag-pole">
                <div class="pole-top"></div>
                <div class="pole-body"></div>
                <div class="pole-base"></div>
              </div>
              <div class="flag-banner">
                <div class="flag-white"></div>
                <div class="flag-red"></div>
                <div class="flag-fold"></div>
              </div>
              <div class="flag-shadow"></div>
            </div>
            <div class="poland-badge">
              <span class="badge-code">PL</span>
              <span class="badge-text">Registro Internacional</span>
            </div>
          </div>
          
          <div class="poland-content">
            <span class="label reveal">Abanderamiento</span>
            <h2 class="section-title reveal" data-delay="1">
              Bandera Polaca
            </h2>
            <p class="poland-intro reveal" data-delay="2">
              Gestión completa para el registro de embarcaciones en Polonia. 
              Una alternativa rápida, económica y totalmente legal para su embarcación.
            </p>
            
            <div class="poland-services">
              <article class="poland-card reveal" data-delay="3">
                <div class="poland-card-header">
                  <h3>Abanderamiento completo</h3>
                  <div class="poland-card-price">
                    <span class="price-label">desde</span>
                    <span class="price-amount">400€</span>
                  </div>
                </div>
                <p class="poland-card-desc">Inscripción completa en el registro polaco. Incluye documentación, traducciones juradas y gestión integral ante autoridades.</p>
                <ul class="poland-features">
                  <li>Documentación completa</li>
                  <li>Traducciones juradas</li>
                  <li>Asesoramiento legal</li>
                  <li>Plazo 15-20 días</li>
                </ul>
              </article>
              
              <article class="poland-card reveal" data-delay="4">
                <div class="poland-card-header">
                  <h3>Cambio de titularidad</h3>
                  <div class="poland-card-price">
                    <span class="price-label">desde</span>
                    <span class="price-amount">350€</span>
                  </div>
                </div>
                <p class="poland-card-desc">Transmisión de propiedad para embarcaciones ya registradas en Polonia. Toda la documentación legal gestionada.</p>
                <ul class="poland-features">
                  <li>Contrato de compraventa</li>
                  <li>Actualización registro</li>
                  <li>Documentación nueva</li>
                  <li>Plazo 10-15 días</li>
                </ul>
              </article>
            </div>
          </div>
        </div>
      </div>
    </section>
    
    <!-- ═══════════════════════════════════════════════════════════════════════
         PROCESS — LIGHT SECTION — Elegant Timeline
         ═══════════════════════════════════════════════════════════════════════ -->
    <section class="process-section" id="proceso">
      <div class="container">
        <div class="section-header">
          <span class="label reveal">Cómo trabajamos</span>
          <h2 class="section-title reveal" data-delay="1">
            El Proceso
          </h2>
          <p class="section-subtitle reveal" data-delay="2">
            Cuatro pasos simples para dejar su documentación en las mejores manos.
          </p>
        </div>
        
        <div class="process-timeline">
          <div class="timeline-line reveal"></div>
          
          <div class="process-steps">
            <article class="process-step reveal">
              <div class="step-number">01</div>
              <div class="step-content">
                <div class="step-image">
                  <img src="https://images.unsplash.com/photo-1556761175-5973dc0f32e7?w=600&q=80&auto=format&fit=crop" alt="Contacto inicial" />
                </div>
                <h3 class="step-title">Contacto inicial</h3>
                <p class="step-desc">Explíquenos qué trámite necesita. Le informaremos de la documentación requerida y el tiempo estimado.</p>
              </div>
            </article>
            
            <article class="process-step reveal" data-delay="1">
              <div class="step-number">02</div>
              <div class="step-content">
                <div class="step-image">
                  <img src="https://images.unsplash.com/photo-1554224155-6726b3ff858f?w=600&q=80&auto=format&fit=crop" alt="Documentación" />
                </div>
                <h3 class="step-title">Documentación</h3>
                <p class="step-desc">Nos facilita los documentos. Nosotros revisamos, completamos formularios y preparamos el expediente.</p>
              </div>
            </article>
            
            <article class="process-step reveal" data-delay="2">
              <div class="step-number">03</div>
              <div class="step-content">
                <div class="step-image">
                  <img src="https://images.unsplash.com/photo-1551836022-d5d88e9218df?w=600&q=80&auto=format&fit=crop" alt="Tramitación" />
                </div>
                <h3 class="step-title">Tramitación</h3>
                <p class="step-desc">Presentación ante Capitanía Marítima de Cádiz y seguimiento continuo hasta la resolución.</p>
              </div>
            </article>
            
            <article class="process-step reveal" data-delay="3">
              <div class="step-number">04</div>
              <div class="step-content">
                <div class="step-image">
                  <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?w=600&q=80&auto=format&fit=crop" alt="Entrega" />
                </div>
                <h3 class="step-title">Entrega</h3>
                <p class="step-desc">Recoja su documentación tramitada en nuestra oficina o se la enviamos por correo certificado.</p>
              </div>
            </article>
          </div>
        </div>
      </div>
    </section>
    
    <!-- ═══════════════════════════════════════════════════════════════════════
         CTA — LIGHT SECTION — Refined Call to Action
         ═══════════════════════════════════════════════════════════════════════ -->
    <section class="cta-section">
      <div class="container">
        <div class="cta-content">
          <span class="label reveal">Contacto</span>
          <h2 class="cta-title reveal" data-delay="1">
            ¿Necesita hacer un trámite?
          </h2>
          <p class="cta-desc reveal" data-delay="2">
            Contacte con nosotros y le informaremos de todo lo necesario. 
            Rápido, fácil y sin complicaciones.
          </p>
          <div class="cta-actions reveal" data-delay="3">
            <a href="/contacto" class="btn btn-primary">
              <span>Solicitar información</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
            <a href="tel:+34605183785" class="btn btn-outline">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
              </svg>
              <span>+34 605 18 37 85</span>
            </a>
          </div>
        </div>
      </div>
    </section>
    
  </main>
</Layout>

<style>
  /* ═══════════════════════════════════════════════════════════════════════════════
     GESTORÍA PAGE — v3.5 Design System
     Airy · Sophisticated · Light-First
     ═══════════════════════════════════════════════════════════════════════════════ */
  
  /* ─── HERO SECTION — LIGHT ───────────────────────────────────────────────────── */
  .hero-gestoria {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    background: var(--ivory);
    overflow: hidden;
  }
  
  .hero-visual {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  
  .hero-image-wrap {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  
  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.4) contrast(1.1) brightness(1.1);
  }
  
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(250, 250, 248, 0.95) 0%,
      rgba(250, 250, 248, 0.85) 40%,
      rgba(250, 250, 248, 0.6) 100%
    );
  }
  
  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 700px;
    padding: calc(var(--space-lg) + 80px) 0 var(--space-xl);
  }
  
  .hero-label {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--gold);
  }
  
  .label-line {
    width: 40px;
    height: 1px;
    background: var(--gold);
  }
  
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--void);
    margin-bottom: 1.5rem;
  }
  
  .hero-desc {
    max-width: 500px;
    font-size: 1.0625rem;
    color: var(--stone);
    line-height: 1.8;
    margin-bottom: 2.5rem;
  }
  
  .hero-features {
    display: flex;
    gap: 2.5rem;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
  }
  
  .hero-feature {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--void);
  }
  
  .hero-feature svg {
    width: 20px;
    height: 20px;
    color: var(--gold);
    flex-shrink: 0;
  }
  
  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  
  .hero-scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
  }
  
  .scroll-line {
    width: 1px;
    height: 60px;
    background: linear-gradient(180deg, var(--gold), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }
  
  @keyframes scrollPulse {
    0%, 100% { transform: scaleY(1); opacity: 0.6; }
    50% { transform: scaleY(0.6); opacity: 0.3; }
  }
  
  /* ─── SERVICES SECTION — LIGHT ───────────────────────────────────────────────── */
  .services-section {
    padding: var(--space-xxl) 0;
    background: var(--ivory);
  }
  
  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }
  
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--void);
    margin: 1rem 0;
  }
  
  .section-subtitle {
    font-size: 1rem;
    color: var(--stone);
    max-width: 500px;
    margin: 0 auto;
  }
  
  .services-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 4rem;
    max-width: 1200px;
    margin: 0 auto;
  }
  
  .services-column {
    display: flex;
    flex-direction: column;
  }
  
  .service-category {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: 2rem 0 1.5rem;
    border-bottom: 1px solid var(--void);
    margin-bottom: 1.5rem;
  }
  
  .category-num {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--gold);
    letter-spacing: 0.1em;
  }
  
  .category-title {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--void);
  }
  
  .service-item {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--mist);
    transition: all 0.4s var(--ease-out);
  }
  
  .service-item:hover {
    padding-left: 0.75rem;
    background: var(--gold-subtle);
    border-color: var(--gold);
  }
  
  .service-info {
    flex: 1;
  }
  
  .service-name {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 500;
    color: var(--void);
    margin-bottom: 0.375rem;
  }
  
  .service-desc {
    font-size: 0.875rem;
    color: var(--stone);
    line-height: 1.6;
  }
  
  .service-price {
    display: flex;
    align-items: flex-start;
    gap: 0.25rem;
    flex-shrink: 0;
  }
  
  .price-currency {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--gold);
    margin-top: 0.25rem;
  }
  
  .price-value {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 400;
    color: var(--void);
    line-height: 1;
  }
  
  .services-divider {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding-top: 6rem;
  }
  
  .divider-line {
    width: 1px;
    flex: 1;
    min-height: 100px;
    background: linear-gradient(180deg, transparent, var(--gold), transparent);
