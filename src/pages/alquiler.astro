---
import Layout from "../layouts/Layout.astro";
---

<Layout 
  title="Alquiler de Yates en Cádiz | Cien Mares"
  description="Alquiler de veleros, lanchas y yates de lujo en Conil de la Frontera, Cádiz. Flota premium con o sin patrón. Reserve su experiencia náutica exclusiva."
>
  <main class="charter-page">
    
    <!-- ═══════════════════════════════════════════════════════════════════════
         HERO — LIGHT — Full-bleed with Elegant Typography
         ═══════════════════════════════════════════════════════════════════════ -->
    <section class="hero-charter-light">
      <div class="hero-visual-light">
        <div class="hero-image-wrap parallax-wrap">
          <img 
            src="https://images.unsplash.com/photo-1566073771259-6a8506099945?w=2400&q=90" 
            alt="Luxury yacht charter in Cádiz"
            class="hero-image parallax-img"
            data-speed="0.06"
          />
        </div>
        <div class="hero-overlay-light"></div>
        <div class="hero-gradient-accent"></div>
      </div>
      
      <div class="container">
        <div class="hero-content-light">
          <div class="hero-label reveal">
            <span class="label-line"></span>
            <span>Flota Premium</span>
          </div>
          
          <h1 class="hero-title-light reveal" data-delay="1">
            Alquiler de<br/>
            <span class="title-accent">Embarcaciones</span>
          </h1>
          
          <p class="hero-desc-light reveal" data-delay="2">
            Veleros, lanchas y yates seleccionados para una experiencia náutica 
            sin igual en las costas de Cádiz. Con o sin patrón.
          </p>
          
          <div class="hero-cta reveal" data-delay="3">
            <a href="#flota" class="btn btn-gold">Ver Embarcaciones</a>
            <a href="#presupuesto" class="btn btn-outline-dark">Solicitar Presupuesto</a>
          </div>
        </div>
      </div>
      
      <div class="hero-meta reveal" data-delay="4">
        <div class="meta-item">
          <span class="meta-num">15+</span>
          <span class="meta-label">Embarcaciones</span>
        </div>
        <div class="meta-divider"></div>
        <div class="meta-item">
          <span class="meta-num">2-12</span>
          <span class="meta-label">Plazas</span>
        </div>
        <div class="meta-divider"></div>
        <div class="meta-item">
          <span class="meta-num">100%</span>
          <span class="meta-label">Satisfacción</span>
        </div>
      </div>
      
      <div class="hero-scroll-indicator">
        <div class="scroll-line"></div>
      </div>
    </section>
    
    <!-- ═══════════════════════════════════════════════════════════════════════
         INTRO — LIGHT — Overlapping Text & Image
         ═══════════════════════════════════════════════════════════════════════ -->
    <section class="intro-section section-light" id="intro">
      <div class="container">
        <div class="intro-grid">
          <div class="intro-content">
            <span class="label reveal">Experiencia</span>
            <h2 class="intro-title reveal" data-delay="1">
              Navegue sin<br/>
              <em>preocupaciones</em>
            </h2>
            <div class="intro-text reveal" data-delay="2">
              <p>
                En Cien Mares entendemos que cada salida al mar es única. Por eso 
                ofrecemos una flota meticulosamente mantenida y un servicio 
                personalizado que se adapta a sus necesidades.
              </p>
              <p>
                Desde un día de relax en calas vírgenes hasta celebraciones 
                exclusivas a bordo, hacemos realidad su experiencia náutica perfecta.
              </p>
            </div>
            <div class="intro-features reveal" data-delay="3">
              <div class="feature-item">
                <div class="feature-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                    <path d="M2 17l10 5 10-5"/>
                    <path d="M2 12l10 5 10-5"/>
                  </svg>
                </div>
                <div class="feature-text">
                  <strong>Embarcaciones homologadas</strong>
                  <span>Máxima seguridad</span>
                </div>
              </div>
              <div class="feature-item">
                <div class="feature-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <circle cx="12" cy="12" r="10"/>
                    <path d="M12 6v6l4 2"/>
                  </svg>
                </div>
                <div class="feature-text">
                  <strong>Reserva flexible</strong>
                  <span>Cancelación gratuita 48h</span>
                </div>
              </div>
              <div class="feature-item">
                <div class="feature-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                    <circle cx="9" cy="7" r="4"/>
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                    <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                  </svg>
                </div>
                <div class="feature-text">
                  <strong>Patrones expertos</strong>
                  <span>Conozca cada rincón</span>
                </div>
              </div>
            </div>
          </div>
          
          <div class="intro-visual reveal-scale" data-delay="2">
            <div class="intro-image-wrap">
              <img 
                src="https://images.unsplash.com/photo-1544551763-46a013bb70d5?w=1000&q=85" 
                alt="Experiencia náutica en Cádiz"
                class="intro-image"
              />
              <div class="intro-image-frame"></div>
            </div>
            <div class="intro-badge">
              <span class="badge-year">Desde</span>
              <span class="badge-num">2010</span>
            </div>
          </div>
        </div>
      </div>
    </section>
    
    <!-- ═══════════════════════════════════════════════════════════════════════
         FLEET — LIGHT — Refined Cards Grid
         ═══════════════════════════════════════════════════════════════════════ -->
    <section class="fleet-section section-light" id="flota">
      <div class="container">
        <div class="fleet-header">
          <span class="label reveal">Nuestra Flota</span>
          <h2 class="fleet-title reveal" data-delay="1">
            Embarcaciones <em>de Ensueño</em>
          </h2>
        </div>
        
        <!-- Filters -->
        <div class="fleet-filters reveal" data-delay="2">
          <button class="filter-btn active" data-filter="all">Todas</button>
          <button class="filter-btn" data-filter="velero">Veleros</button>
          <button class="filter-btn" data-filter="lancha">Lanchas</button>
          <button class="filter-btn" data-filter="yate">Yates</button>
        </div>
        
        <!-- Fleet Grid -->
        <div class="fleet-grid">
          <!-- Featured Yate -->
          <article class="fleet-card fleet-card-featured reveal" data-category="yate">
            <div class="fleet-image">
              <img src="https://images.unsplash.com/photo-1567899378494-47b22a2ae96a?w=1400&q=85" alt="Yate Azimut Atlantis" />
              <div class="fleet-overlay">
                <div class="fleet-specs">
                  <div class="spec">
                    <span class="spec-label">Eslora</span>
                    <span class="spec-value">15.8 m</span>
                  </div>
                  <div class="spec">
                    <span class="spec-label">Capacidad</span>
                    <span class="spec-value">12 pax</span>
                  </div>
                  <div class="spec">
                    <span class="spec-label">Cabinas</span>
                    <span class="spec-value">3</span>
                  </div>
                </div>
              </div>
              <span class="fleet-badge fleet-badge-premium">Yate Premium</span>
            </div>
            <div class="fleet-content">
              <div class="fleet-meta">
                <span class="fleet-type">Yate a motor</span>
                <div class="fleet-rating">
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                  <span>4.9</span>
                </div>
              </div>
              <h3 class="fleet-name">Azimut Atlantis 51</h3>
              <p class="fleet-desc">Yate de lujo con diseño italiano. Espacios exteriores generosos, interior refinado y performance inigualable.</p>
              <div class="fleet-footer">
                <div class="fleet-price">
                  <span class="price-from">Desde</span>
                  <span class="price-value">1.200€</span>
                  <span class="price-unit">/día</span>
                </div>
                <a href="#presupuesto" class="fleet-link">
                  <span>Reservar</span>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </a>
              </div>
            </div>
          </article>
          
          <!-- Velero 1 -->
          <article class="fleet-card reveal" data-category="velero" data-delay="1">
            <div class="fleet-image">
              <img src="https://images.unsplash.com/photo-1534447677768-be436bb09401?w=800&q=85" alt="Velero Beneteau Oceanis" />
              <div class="fleet-overlay">
                <div class="fleet-specs">
                  <div class="spec">
                    <span class="spec-label">Eslora</span>
                    <span class="spec-value">10.5 m</span>
                  </div>
                  <div class="spec">
                    <span class="spec-label">Capacidad</span>
                    <span class="spec-value">8 pax</span>
                  </div>
                  <div class="spec">
                    <span class="spec-label">Cabinas</span>
                    <span class="spec-value">2</span>
                  </div>
                </div>
              </div>
              <span class="fleet-badge">Velero</span>
            </div>
            <div class="fleet-content">
              <div class="fleet-meta">
                <span class="fleet-type">Velero</span>
              </div>
              <h3 class="fleet-name">Beneteau Oceanis 35</h3>
              <p class="fleet-desc">Velero cruiser ideal para navegación costera. Espacioso, estable y elegante.</p>
              <div class="fleet-footer">
                <div class="fleet-price">
                  <span class="price-from">Desde</span>
                  <span class="price-value">350€</span>
                  <span class="price-unit">/día</span>
                </div>
                <a href="#presupuesto" class="fleet-link">
                  <span>Reservar</span>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </a>
              </div>
            </div>
          </article>
          
          <!-- Velero 2 -->
          <article class="fleet-card reveal" data-category="velero" data-delay="2">
            <div class="fleet-image">
              <img src="https://images.unsplash.com/photo-1605281317010-fe5ffe79ba66?w=800&q=85" alt="Velero Jeanneau Sun Odyssey" />
              <div class="fleet-overlay">
                <div class="fleet-specs">
                  <div class="spec">
                    <span class="spec-label">Eslora</span>
                    <span class="spec-value">12.3 m</span>
                  </div>
                  <div class="spec">
                    <span class="spec-label">Capacidad</span>
                    <span class="spec-value">10 pax</span>
                  </div>
                  <div class="spec">
                    <span class="spec-label">Cabinas</span>
                    <span class="spec-value">3</span>
                  </div>
                </div>
              </div>
              <span class="fleet-badge">Velero</span>
            </div>
            <div class="fleet-content">
              <div class="fleet-meta">
                <span class="fleet-type">Velero</span>
              </div>
              <h3 class="fleet-name">Jeanneau Sun Odyssey 410</h3>
              <p class="fleet-desc">Diseño moderno y performance excepcional. Perfecto para quienes buscan emoción.</p>
              <div class="fleet-footer">
                <div class="fleet-price">
                  <span class="price-from">Desde</span>
                  <span class="price-value">450€</span>
                  <span class="price-unit">/día</span>
                </div>
                <a href="#presupuesto" class="fleet-link">
                  <span>Reservar</span>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </a>
              </div>
            </div>
          </article>
          
          <!-- Lancha 1 -->
          <article class="fleet-card reveal" data-category="lancha" data-delay="1">
            <div class="fleet-image">
              <img src="https://images.unsplash.com/photo-1599939571322-792a326991f2?w=800&q=85" alt="Lancha Sessa Key Largo" />
              <div class="fleet-overlay">
                <div class="fleet-specs">
                  <div class="spec">
                    <span class="spec-label">Eslora</span>
                    <span class="spec-value">8.2 m</span>
                  </div>
                  <div class="spec">
                    <span class="spec-label">Capacidad</span>
                    <span class="spec-value">7 pax</span>
                  </div>
                  <div class="spec">
                    <span class="spec-label">Motor</span>
                    <span class="spec-value">300 CV</span>
                  </div>
                </div>
              </div>
              <span class="fleet-badge">Lancha</span>
            </div>
            <div class="fleet-content">
              <div class="fleet-meta">
                <span class="fleet-type">Lancha</span>
              </div>
              <h3 class="fleet-name">Sessa Key Largo 27</h3>
              <p class="fleet-desc">Lancha versátil para día de playa y deportes acuáticos. Rápida y ágil.</p>
              <div class="fleet-footer">
                <div class="fleet-price">
                  <span class="price-from">Desde</span>
                  <span class="price-value">280€</span>
                  <span class="price-unit">/día</span>
                </div>
                <a href="#presupuesto" class="fleet-link">
                  <span>Reservar</span>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </a>
              </div>
            </div>
          </article>
          
          <!-- Lancha 2 -->
          <article class="fleet-card reveal" data-category="lancha" data-delay="2">
            <div class="fleet-image">
              <img src="https://images.unsplash.com/photo-1540946485063-a40da27545f8?w=800&q=85" alt="Lancha Atlantic Sun Cruiser" />
              <div class="fleet-overlay">
                <div class="fleet-specs">
                  <div class="spec">
                    <span class="spec-label">Eslora</span>
                    <span class="spec-value">7.5 m</span>
                  </div>
                  <div class="spec">
                    <span class="spec-label">Capacidad</span>
                    <span class="spec-value">8 pax</span>
                  </div>
                  <div class="spec">
                    <span class="spec-label">Motor</span>
                    <span class="spec-value">250 CV</span>
                  </div>
                </div>
              </div>
              <span class="fleet-badge">Lancha</span>
            </div>
            <div class="fleet-content">
              <div class="fleet-meta">
                <span class="fleet-type">Lancha</span>
              </div>
              <h3 class="fleet-name">Atlantic Sun Cruiser 730</h3>
              <p class="fleet-desc">Elegancia y potencia en formato compacto. Ideal para explorar la costa.</p>
              <div class="fleet-footer">
                <div class="fleet-price">
                  <span class="price-from">Desde</span>
                  <span class="price-value">220€</span>
                  <span class="price-unit">/día</span>
                </div>
                <a href="#presupuesto" class="fleet-link">
                  <span>Reservar</span>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </a>
              </div>
            </div>
          </article>
          
          <!-- Yate 2 -->
          <article class="fleet-card reveal" data-category="yate" data-delay="3">
            <div class="fleet-image">
              <img src="https://images.unsplash.com/photo-1559827260-dc66d52bef19?w=800&q=85" alt="Yate Princess V40" />
              <div class="fleet-overlay">
                <div class="fleet-specs">
                  <div class="spec">
                    <span class="spec-label">Eslora</span>
                    <span class="spec-value">12.4 m</span>
                  </div>
                  <div class="spec">
                    <span class="spec-label">Capacidad</span>
                    <span class="spec-value">8 pax</span>
                  </div>
                  <div class="spec">
                    <span class="spec-label">Cabinas</span>
                    <span class="spec-value">2</span>
                  </div>
                </div>
              </div>
              <span class="fleet-badge">Yate</span>
            </div>
            <div class="fleet-content">
              <div class="fleet-meta">
                <span class="fleet-type">Yate</span>
              </div>
              <h3 class="fleet-name">Princess V40</h3>
              <p class="fleet-desc">Sport yacht británico con líneas agresivas y acabados impecables.</p>
              <div class="fleet-footer">
                <div class="fleet-price">
                  <span class="price-from">Desde</span>
                  <span class="price-value">850€</span>
                  <span class="price-unit">/día</span>
                </div>
                <a href="#presupuesto" class="fleet-link">
                  <span>Reservar</span>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </a>
              </div>
            </div>
          </article>
        </div>
      </div>
    </section>
    
    <!-- ═══════════════════════════════════════════════════════════════════════
         WATER TOYS — MUTED SECTION — Bento Grid
         ═══════════════════════════════════════════════════════════════════════ -->
    <section class="toys-section section-muted" id="toys">
      <div class="container">
        <div class="toys-header">
          <span class="label reveal">Extras</span>
          <h2 class="toys-title reveal" data-delay="1">
            Juguetes <em>Náuticos</em>
          </h2>
          <p class="toys-subtitle reveal" data-delay="2">
            Complete su experiencia con equipamiento premium para deportes acuáticos 
            y captura de recuerdos inolvidables.
          </p>
        </div>
        
        <div class="toys-bento">
          <!-- Large Feature -->
          <div class="bento-item bento-large reveal-scale">
            <div class="bento-image">
              <img src="https://images.unsplash.com/photo-1544551763-77ef2d0cfc6c?w=1000&q=85" alt="Paddle Surf" />
            </div>
            <div class="bento-content">
              <h4>Paddle Surf</h4>
              <p>Tablas hinchables de alta calidad para explorar calas tranquilas</p>
              <span class="bento-price">30€ / día</span>
            </div>
          </div>
          
          <!-- Medium Items -->
          <div class="bento-item bento-medium reveal" data-delay="1">
            <div class="bento-image">
              <img src="https://images.unsplash.com/photo-1596451190630-186aff535bf2?w=600&q=85" alt="GoPro Hero" />
            </div>
            <div class="bento-content">
              <h4>GoPro Hero 11</h4>
              <p>Capture cada momento en 4K</p>
              <span class="bento-price">25€ / día</span>
            </div>
          </div>
          
          <div class="bento-item bento-medium reveal" data-delay="2">
            <div class="bento-image">
              <img src="https://images.unsplash.com/photo-1544551763-46a013bb70d5?w=600&q=85" alt="Equipo Snorkel" />
            </div>
            <div class="bento-content">
              <h4>Equipo Snorkel</h4>
              <p>Máscaras y aletas profesionales</p>
              <span class="bento-price">15€ / día</span>
            </div>
          </div>
          
          <!-- Small Items -->
          <div class="bento-item reveal" data-delay="1">
            <div class="bento-image">
              <img src="https://images.unsplash.com/photo-1473968512647-3e447244af8f?w=600&q=85" alt="Insta360" />
            </div>
            <div class="bento-content">
              <h4>Insta360 X3</h4>
              <p>Vídeo 360° inmersivo</p>
              <span class="bento-price">35€ / día</span>
            </div>
          </div>
          
          <div class="bento-item reveal" data-delay="2">
            <div class="bento-image">
              <img src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=600&q=85" alt="Dron DJI" />
            </div>
            <div class="bento-content">
              <h4>Dron DJI Mini 3</h4>
              <p>Fotografía aérea con operador</p>
              <span class="bento-price">120€ / día</span>
            </div>
          </div>
          
          <div class="bento-item reveal" data-delay="3">
            <div class="bento-image">
              <img src="https://images.unsplash.com/photo-1545454675-3531b543be5d?w=600&q=85" alt="Altavoz impermeable" />
            </div>
            <div class="bento-content">
              <h4>Sonido JBL</h4>
              <p>Altavoz waterproof 300W</p>
              <span class="bento-price">40€ / día</span>
            </div>
          </div>
          
          <div class="bento-item reveal" data-delay="3">
            <div class="bento-image">
              <img src="https://images.unsplash.com/photo-1530549387789-4c1017266635?w=600&q=85" alt="Colchoneta flotante" />
            </div>
            <div class="bento-content">
              <h4>Colchoneta XXL</h4>
              <p>Plataforma flotante 5x2m</p>
              <span class="bento-price">50€ / día</span>
            </div>
          </div>
        </div>
      </div>
    </section>
    
    <!-- ═══════════════════════════════════════════════════════════════════════
         ROUTES — LIGHT SECTION — Destination Cards
         ═══════════════════════════════════════════════════════════════════════ -->
    <section class="routes-section section-light" id="rutas">
      <div class="container">
        <div class="routes-header">
          <span class="label reveal">Descubra</span>
          <h2 class="routes-title reveal" data-delay="1">
            Rutas <em>Recomendadas</em>
          </h2>
        </div>
        
        <div class="routes-grid">
          <article class="route-card reveal-left">
            <div class="route-image">
              <img src="https://images.unsplash.com/photo-1507525428034-b723cf961d3e?w=1000&q=85" alt="Ruta de las Calas" />
              <div class="route-duration">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <circle cx="12" cy="12" r="10"/>
                  <path d="M12 6v6l4 2"/>
                </svg>
                <span>4-5 horas</span>
              </div>
            </div>
            <div class="route-content">
              <div class="route-num">01</div>
              <h3 class="route-title">Ruta de las Calas</h3>
              <p class="route-desc">
                Navegue desde Conil hasta Zahara descubriendo calas vírgenes de aguas cristalinas.
              </p>
              <div class="route-highlights">
                <span class="highlight">Cala Camacho</span>
                <span class="highlight">Cabo Roche</span>
                <span class="highlight">Atlanterra</span>
              </div>
            </div>
          </article>
          
