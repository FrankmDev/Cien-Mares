---
import Layout from "@/layouts/Layout.astro";
import PageHero from "@/components/shared/PageHero.astro";
import FleetSection from "@/components/navegar/FleetSection.astro";
import RoutesSection from "@/components/navegar/RoutesSection.astro";
import EquipmentSection from "@/components/navegar/EquipmentSection.astro";
import HowItWorksSection from "@/components/navegar/HowItWorksSection.astro";
import CTABanner from "@/components/navegar/CTABanner.astro";

const HERO_CONTENT = {
  backgroundImage: "https://images.unsplash.com/photo-1500930287596-c1ecaa373bb2?w=1920&q=85",
  badge: { 
    text: "Alquiler de Embarcaciones", 
    subtext: "Cádiz — Costa de la Luz" 
  },
  title: {
    line1: "Alquila un velero",
    line2: "lancha o yate",
  },
  subtitle: "Excursiones personalizadas o rutas recomendadas por nuestros patrones. Vive la costa gaditana desde el mar.",
  cta: {
    primary: { text: "Consultar disponibilidad", href: "/contacto" },
    secondary: { text: "Ver rutas", href: "#routes-section" },
  },
  stats: [
    { value: "50+", label: "Embarcaciones" },
    { value: "6", label: "Destinos" },
    { value: "15+", label: "Años experiencia" },
  ],
};
---

<Layout
  title="Navegar | Alquiler de Barcos en Cádiz | Cien Mares"
  description="Alquila velero, lancha o yate en la costa de Cádiz. Excursiones personalizadas desde El Puerto de Santa María. Equipamiento premium y patrón profesional incluido."
>
  {/* Hero Section */}
  <PageHero {...HERO_CONTENT} />

  {/* Fleet Section - La Flota */}
  <FleetSection />

  {/* Routes Section - Rutas Disponibles */}
  <RoutesSection />

  {/* Equipment Section - Equipamiento */}
  <EquipmentSection />

  {/* How It Works Section - Proceso */}
  <HowItWorksSection />

  {/* CTA Banner - Llamada a la acción final */}
  <CTABanner />
</Layout>
