---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import Preloader from "../components/shared/Preloader.astro";

interface Props {
  title?: string;
  description?: string;
  transparentHeader?: boolean;
}

const {
  title = "Cien Mares | Experiencias Nauticas Premium en Cadiz",
  description = "Servicios nauticos de excelencia en Conil de la Frontera. Alquiler de embarcaciones, academia homologada, gestoria y traslados internacionales.",
  transparentHeader = false,
} = Astro.props;

const canonicalURL = new URL(
  Astro.url.pathname,
  Astro.site || "https://cienmares.es",
);
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#050505" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&family=Work+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,300;1,400&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@300;400;500&display=swap"
    />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="es_ES" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <ClientRouter />
  </head>

  <body class="bg-[#050505] text-[#F2F2F2] cursor-none lg:cursor-none">
    <Preloader />
    <!-- Grain Overlay -->
    <div class="grain-overlay" aria-hidden="true"></div>

    <!-- Custom Cursor -->
    <div
      id="custom-cursor"
      class="custom-cursor hidden lg:block"
      aria-hidden="true"
    >
      <div class="cursor-dot"></div>
      <div class="cursor-ring"></div>
    </div>

    <Header transparent={transparentHeader} />

    <main id="main-content">
      <slot />
    </main>

    <Footer />

    <script>
      document.addEventListener("astro:after-swap", () => {
        window.scrollTo(0, 0);
      });
    </script>

    <script>
      document.addEventListener("astro:page-load", () => {
        if (window.innerWidth < 1024) return;

        const cursor = document.getElementById("custom-cursor");
        if (!cursor) return;

        let mouseX = 0,
          mouseY = 0;
        let cursorX = 0,
          cursorY = 0;
        let isActive = true;
        let inactivityTimeout: ReturnType<typeof setTimeout> | undefined;

        function updateCursor() {
          if (!isActive) return;

          cursorX += (mouseX - cursorX) * 0.15;
          cursorY += (mouseY - cursorY) * 0.15;

          if (cursor) {
            cursor.style.transform = `translate(${cursorX - 20}px, ${cursorY - 20}px)`;
          }

          requestAnimationFrame(updateCursor);
        }

        document.addEventListener("mousemove", (e) => {
          mouseX = e.clientX;
          mouseY = e.clientY;

          cursor.style.opacity = "1";

          clearTimeout(inactivityTimeout);
          inactivityTimeout = setTimeout(() => {
            cursor.style.opacity = "0";
          }, 3000);
        });

        document.addEventListener("mouseenter", () => {
          cursor.style.opacity = "1";
          isActive = true;
          updateCursor();
        });

        document.addEventListener("mouseleave", () => {
          cursor.style.opacity = "0";
        });

        // Interactive elements
        const interactives = document.querySelectorAll(
          "a, button, [role='button'], input, textarea, select, .service-panel",
        );

        interactives.forEach((el) => {
          el.addEventListener("mouseenter", () => {
            cursor.classList.add("cursor-hover");
          });
          el.addEventListener("mouseleave", () => {
            cursor.classList.remove("cursor-hover");
          });
        });

        updateCursor();
      });
    </script>
  </body>
</html>

<style is:global>
  /* Hide default cursor on desktop */
  @media (min-width: 1024px) {
    * {
      cursor: none !important;
    }
  }

  /* Custom Cursor Styles */
  .custom-cursor {
    position: fixed;
    top: 0;
    left: 0;
    width: 40px;
    height: 40px;
    pointer-events: none;
    z-index: 99999;
    will-change: transform;
    opacity: 0;
    transition: opacity 0.3s ease;
    mix-blend-mode: difference;
  }

  .cursor-dot {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 8px;
    height: 8px;
    background-color: #ffffff;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    transition:
      transform 0.15s ease,
      background-color 0.15s ease;
  }

  .cursor-ring {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 32px;
    height: 32px;
    border: 1px solid rgba(255, 255, 255, 0.4);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    transition: all 0.2s ease;
  }

  .cursor-hover .cursor-dot {
    transform: translate(-50%, -50%) scale(0);
  }

  .cursor-hover .cursor-ring {
    width: 64px;
    height: 64px;
    border-color: #ffffff;
    background-color: rgba(255, 255, 255, 1);
  }

  /* Grain Overlay */
  .grain-overlay {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 9999;
    opacity: 0.025;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
  }

  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
