---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Cien Mares | Experiencias Náuticas en Cádiz",
  description = "Servicios náuticos premium en Conil de la Frontera, Cádiz. Alquiler de embarcaciones, academia homologada, gestoría y traslados.",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || "https://cienmares.es");
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#fafaf8" />
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="es_ES" />
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://api.fontshare.com/v2/css?f[]=satoshi@300,400,500,700&display=swap" rel="stylesheet" />
    
    <ClientRouter />
  </head>
  
  <body>
    <!-- Grain Overlay -->
    <div class="grain"></div>
    
    <!-- Navigation — Refined -->
    <header class="nav" id="nav" transition:persist>
      <div class="nav-container">
        <a href="/" class="nav-logo" transition:name="logo">
          <span class="nav-logo-icon">
            <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="20" cy="20" r="19" stroke="currentColor" stroke-width="1"/>
              <path d="M20 8v24M8 20h24" stroke="currentColor" stroke-width="1"/>
              <circle cx="20" cy="20" r="4" fill="currentColor"/>
            </svg>
          </span>
          <span class="nav-logo-text">Cien Mares</span>
        </a>
        
        <nav class="nav-menu">
          <a href="/alquiler" class="nav-link" class:list={[{ active: currentPath === '/alquiler' }]}>
            <span>Alquiler</span>
          </a>
          <a href="/academia" class="nav-link" class:list={[{ active: currentPath === '/academia' }]}>
            <span>Academia</span>
          </a>
          <a href="/gestoria" class="nav-link" class:list={[{ active: currentPath === '/gestoria' }]}>
            <span>Gestoría</span>
          </a>
          <a href="/traslados" class="nav-link" class:list={[{ active: currentPath === '/traslados' }]}>
            <span>Traslados</span>
          </a>
          <a href="/nosotros" class="nav-link" class:list={[{ active: currentPath === '/nosotros' }]}>
            <span>Nosotros</span>
          </a>
        </nav>
        
        <a href="/contacto" class="nav-cta">
          <span>Contacto</span>
        </a>
        
        <button class="nav-toggle" id="nav-toggle" aria-label="Menu">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </header>
    
    <!-- Mobile Menu -->
    <div class="mobile-menu" id="mobile-menu">
      <div class="mobile-menu-inner">
        <nav class="mobile-nav">
          <a href="/alquiler" class="mobile-link">Alquiler</a>
          <a href="/academia" class="mobile-link">Academia</a>
          <a href="/gestoria" class="mobile-link">Gestoría</a>
          <a href="/traslados" class="mobile-link">Traslados</a>
          <a href="/nosotros" class="mobile-link">Nosotros</a>
          <a href="/contacto" class="mobile-link">Contacto</a>
        </nav>
        <div class="mobile-info">
          <a href="tel:+34605183785">+34 605 18 37 85</a>
          <a href="mailto:info@cienmares.es">info@cienmares.es</a>
        </div>
      </div>
    </div>
    
    <main id="main" transition:animate="fade">
      <slot />
    </main>
    
    <!-- Footer — Refined -->
    <footer class="footer section-light">
      <div class="container">
        <div class="footer-top">
          <div class="footer-brand">
            <span class="footer-logo">Cien Mares</span>
            <p>Excelencia náutica desde 2010.<br/>Conil de la Frontera, Cádiz.</p>
          </div>
          <div class="footer-links">
            <div class="footer-col">
              <h4>Servicios</h4>
              <a href="/alquiler">Alquiler</a>
              <a href="/academia">Academia</a>
              <a href="/gestoria">Gestoría</a>
              <a href="/traslados">Traslados</a>
            </div>
            <div class="footer-col">
              <h4>Empresa</h4>
              <a href="/nosotros">Nosotros</a>
              <a href="/contacto">Contacto</a>
            </div>
            <div class="footer-col">
              <h4>Contacto</h4>
              <a href="tel:+34605183785">+34 605 18 37 85</a>
              <a href="mailto:info@cienmares.es">info@cienmares.es</a>
              <p>Puerto de Conil de la Frontera<br/>11140 Cádiz, España</p>
            </div>
          </div>
        </div>
        <div class="footer-bottom">
          <span>© 2026 Cien Mares</span>
          <div class="footer-social">
            <a href="https://instagram.com/cienmares" target="_blank" rel="noopener">Instagram</a>
            <a href="https://wa.me/34605183785" target="_blank" rel="noopener">WhatsApp</a>
          </div>
        </div>
      </div>
    </footer>
    
    <script>
      // Navigation scroll effect
      const nav = document.getElementById('nav');
      let lastScroll = 0;
      
      window.addEventListener('scroll', () => {
        const currentScroll = window.scrollY;
        
        if (currentScroll > 100) {
          nav?.classList.add('scrolled');
        } else {
          nav?.classList.remove('scrolled');
        }
        
        lastScroll = currentScroll;
      }, { passive: true });
      
      // Mobile menu
      const navToggle = document.getElementById('nav-toggle');
      const mobileMenu = document.getElementById('mobile-menu');
      
      navToggle?.addEventListener('click', () => {
        navToggle.classList.toggle('active');
        mobileMenu?.classList.toggle('active');
        document.body.classList.toggle('menu-open');
      });
      
      // Close mobile menu on link click
      document.querySelectorAll('.mobile-link').forEach(link => {
        link.addEventListener('click', () => {
          navToggle?.classList.remove('active');
          mobileMenu?.classList.remove('active');
          document.body.classList.remove('menu-open');
        });
      });
      
      // Reveal animations
      const observerOptions = {
        threshold: 0.1,
        rootMargin: '0px 0px -50px 0px'
      };
      
      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('active');
            revealObserver.unobserve(entry.target);
          }
        });
      }, observerOptions);
      
      document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale, .img-reveal').forEach(el => {
        revealObserver.observe(el);
      });
      
      // Parallax
      const parallaxImages = document.querySelectorAll('.parallax-img');
      
      if (!window.matchMedia('(pointer: coarse)').matches) {
        window.addEventListener('scroll', () => {
          const scrolled = window.scrollY;
          
          parallaxImages.forEach(img => {
            const rect = img.getBoundingClientRect();
            const speed = parseFloat(img.dataset.speed) || 0.05;
            
            if (rect.top < window.innerHeight && rect.bottom > 0) {
              const yPos = scrolled * speed;
              img.style.transform = `translateY(${yPos}px) scale(1.05)`;
            }
          });
        }, { passive: true });
      }
    </script>
  </body>
</html>

<style is:global>
  /* Navigation Styles */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    padding: 1.5rem 0;
    transition: all 0.4s var(--ease-out);
    background: transparent;
  }
  
  .nav.scrolled {
    padding: 1rem 0;
    background: rgba(250, 250, 248, 0.95);
    backdrop-filter: blur(20px);
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.05);
  }
  
  .nav.scrolled .nav-logo,
  .nav.scrolled .nav-link,
  .nav.scrolled .nav-cta {
    color: var(--void);
  }
  
  .nav-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: var(--container);
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 5vw, 3rem);
  }
  
  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    color: var(--void);
    transition: color 0.3s ease;
  }
  
  .nav-logo-icon {
    width: 36px;
    height: 36px;
  }
  
  .nav-logo-icon svg {
    width: 100%;
    height: 100%;
  }
  
  .nav-logo-text {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 500;
    letter-spacing: 0.02em;
  }
  
  .nav-menu {
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }
  
  .nav-link {
    position: relative;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--void);
    text-decoration: none;
    opacity: 0.7;
    transition: opacity 0.3s ease;
  }
  
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--gold);
    transition: width 0.4s var(--ease-out);
  }
  
  .nav-link:hover,
  .nav-link.active {
    opacity: 1;
  }
  
  .nav-link:hover::after,
  .nav-link.active::after {
    width: 100%;
  }
  
  .nav-cta {
    padding: 0.75rem 1.5rem;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: var(--void);
    color: var(--ivory);
    text-decoration: none;
    transition: all 0.3s ease;
  }
  
  .nav-cta:hover {
    background: var(--gold);
    color: var(--white);
  }
  
  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 0.5rem;
    background: none;
    border: none;
    cursor: pointer;
  }
  
  .nav-toggle span {
    display: block;
    width: 24px;
    height: 1.5px;
    background: var(--void);
    transition: all 0.4s var(--ease-out);
  }
  
  .nav-toggle.active span:first-child {
    transform: rotate(45deg) translate(5px, 5px);
  }
  
  .nav-toggle.active span:nth-child(2) {
    opacity: 0;
  }
  
  .nav-toggle.active span:last-child {
    transform: rotate(-45deg) translate(5px, -5px);
  }
  
  /* Mobile Menu */
  .mobile-menu {
    position: fixed;
    inset: 0;
    background: var(--ivory);
    z-index: 999;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: all 0.5s var(--ease-out);
  }
  
  .mobile-menu.active {
    opacity: 1;
    visibility: visible;
  }
  
  .mobile-menu-inner {
    text-align: center;
  }
  
  .mobile-nav {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  
  .mobile-link {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 3rem);
    font-weight: 500;
    color: var(--void);
    text-decoration: none;
  }
  
  .mobile-info {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--mist);
  }
  
  .mobile-info a {
    display: block;
    font-size: 0.9375rem;
    color: var(--stone);
    text-decoration: none;
    margin: 0.5rem 0;
  }
  
  @media (max-width: 1024px) {
    .nav-menu,
    .nav-cta {
      display: none;
    }
    
    .nav-toggle {
      display: flex;
    }
  }
  
  body.menu-open {
    overflow: hidden;
  }
  
  /* Footer */
  .footer {
    padding: var(--space-lg) 0 var(--space-md);
  }
  
  .footer-top {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 4rem;
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--mist);
  }
  
  .footer-logo {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--void);
    display: block;
    margin-bottom: 1rem;
  }
  
  .footer-brand p {
    font-size: 0.9375rem;
    color: var(--stone);
    line-height: 1.7;
  }
  
  .footer-links {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  
  .footer-col h4 {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--stone);
    margin-bottom: 1.5rem;
  }
  
  .footer-col a,
  .footer-col p {
    display: block;
    font-size: 0.9375rem;
    color: var(--void);
    text-decoration: none;
    margin-bottom: 0.75rem;
    opacity: 0.7;
    transition: opacity 0.3s ease;
  }
  
  .footer-col a:hover {
    opacity: 1;
    color: var(--gold);
  }
  
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--space-md);
  }
  
  .footer-bottom span {
    font-size: 0.8125rem;
    color: var(--stone);
  }
  
  .footer-social {
    display: flex;
    gap: 2rem;
  }
  
  .footer-social a {
    font-size: 0.8125rem;
    color: var(--void);
    text-decoration: none;
    opacity: 0.7;
    transition: opacity 0.3s ease;
  }
  
  .footer-social a:hover {
    opacity: 1;
    color: var(--gold);
  }
  
  @media (max-width: 768px) {
    .footer-top {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    
    .footer-links {
      grid-template-columns: 1fr;
    }
    
    .footer-bottom {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }
  }
  
  /* Page Transitions */
  main {
    min-height: 100vh;
  }
</style>
