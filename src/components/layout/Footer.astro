---
import { footerLinks, socialLinks, contactInfo } from "../../data/navigation";
const currentYear = new Date().getFullYear();
---

<footer
  class="relative bg-[#02060a] text-white pt-24 lg:pt-32 pb-8 overflow-hidden"
  id="site-footer"
>
  <!-- Background -->
  <div class="absolute inset-0 z-0">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-[#CFA35A]/5 blur-[200px] rounded-full pointer-events-none"></div>
  </div>

  <!-- Top Border -->
  <div class="absolute top-0 left-0 right-0 h-[1px] bg-gradient-to-r from-transparent via-[#CFA35A]/30 to-transparent"></div>

  <div class="container mx-auto px-6 lg:px-12 relative z-10 max-w-[1400px]">
    
    <!-- Main Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8 mb-20">
      
      <!-- Brand Column -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-flex items-center gap-3 mb-6 group">
          <div class="w-11 h-11 relative">
            <svg viewBox="0 0 48 48" fill="none" class="w-full h-full">
              <circle cx="24" cy="24" r="22" stroke="currentColor" stroke-width="1.5" class="text-[#CFA35A]"/>
              <path d="M24 8v32M8 24h32" stroke="currentColor" stroke-width="1.5" class="text-[#CFA35A]"/>
              <circle cx="24" cy="24" r="8" fill="currentColor" class="text-[#CFA35A]"/>
            </svg>
          </div>
          <span class="font-display font-black text-xl tracking-tight">CIEN MARES</span>
        </a>
        <p class="font-body text-white/50 leading-relaxed mb-6 text-sm">
          Experiencias náuticas de élite en la costa de Cádiz. Excelencia y pasión por el mar desde 2010.
        </p>
        
        <!-- Contact Info -->
        <div class="space-y-3">
          <a href={`tel:${contactInfo.phone.replace(/\s/g, "")}`} class="flex items-center gap-3 group">
            <span class="font-mono text-[0.6rem] uppercase tracking-[0.2em] text-[#CFA35A]">Tlf</span>
            <span class="font-body text-sm text-white/70 group-hover:text-white transition-colors">{contactInfo.phone}</span>
          </a>
          <a href={`mailto:${contactInfo.email}`} class="flex items-center gap-3 group">
            <span class="font-mono text-[0.6rem] uppercase tracking-[0.2em] text-[#CFA35A]">Email</span>
            <span class="font-body text-sm text-white/70 group-hover:text-white transition-colors">{contactInfo.email}</span>
          </a>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h4 class="font-mono text-[0.7rem] uppercase tracking-[0.25em] text-[#CFA35A] font-bold mb-6">Servicios</h4>
        <ul class="space-y-3">
          {footerLinks.services.map((link) => (
            <li>
              <a href={link.href} class="font-body text-sm text-white/50 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="font-mono text-[0.7rem] uppercase tracking-[0.25em] text-[#CFA35A] font-bold mb-6">Empresa</h4>
        <ul class="space-y-3">
          {footerLinks.company.map((link) => (
            <li>
              <a href={link.href} class="font-body text-sm text-white/50 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Social & Location -->
      <div>
        <h4 class="font-mono text-[0.7rem] uppercase tracking-[0.25em] text-[#CFA35A] font-bold mb-6">Síguenos</h4>
        <div class="flex gap-3 mb-6">
          {socialLinks.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center hover:bg-[#CFA35A] hover:border-[#CFA35A] group transition-all duration-300"
            >
              <span class="font-mono text-xs font-bold text-white/50 group-hover:text-[#02060a] transition-colors">
                {link.label.substring(0, 2)}
              </span>
            </a>
          ))}
        </div>

        <h4 class="font-mono text-[0.7rem] uppercase tracking-[0.25em] text-[#CFA35A] font-bold mb-3">Ubicación</h4>
        <p class="font-body text-sm text-white/50 leading-relaxed">
          {contactInfo.address.join(", ")}
        </p>
      </div>
    </div>

    <!-- Large Brand Text -->
    <div class="py-12 border-t border-b border-white/5 overflow-hidden">
      <h2 class="font-display font-black text-[clamp(5rem,18vw,14rem)] leading-none text-white/[0.06] text-center select-none whitespace-nowrap tracking-tighter">
        CIEN MARES
      </h2>
    </div>

    <!-- Bottom Bar -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-4 pt-8">
      <p class="font-mono text-[0.6rem] uppercase tracking-[0.2em] text-white/30">
        © {currentYear} Cien Mares S.L. Todos los derechos reservados.
      </p>
      <div class="flex gap-6">
        <a href="/privacidad" class="font-mono text-[0.6rem] uppercase tracking-[0.2em] text-white/30 hover:text-[#CFA35A] transition-colors">
          Privacidad
        </a>
        <a href="/legal" class="font-mono text-[0.6rem] uppercase tracking-[0.2em] text-white/30 hover:text-[#CFA35A] transition-colors">
          Legal
        </a>
      </div>
    </div>
  </div>
</footer>
