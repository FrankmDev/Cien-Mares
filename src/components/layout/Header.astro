---
import { navLinks } from "../../data/navigation";

interface Props {
  transparent?: boolean;
}

const { transparent = false } = Astro.props;
---

<header
  id="site-header"
  class:list={[
    "fixed top-0 left-0 right-0 z-[1000] transition-all duration-500 ease-premium",
    transparent 
      ? "bg-transparent" 
      : "bg-cm-bg/90 backdrop-blur-xl border-b border-white/5"
  ]}
>
  <div class="container mx-auto px-6 lg:px-12 max-w-[1400px]">
    <div class="flex items-center justify-between py-5 lg:py-6">
      
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group">
        <div class="w-10 h-10 lg:w-11 lg:h-11 relative">
          <div class="absolute inset-0 rounded-full border border-cm-accent/0 group-hover:border-cm-accent/30 group-hover:scale-150 transition-all duration-500"></div>
          <div class="absolute inset-0 rounded-full bg-cm-accent/0 group-hover:bg-cm-accent/10 group-hover:scale-125 transition-all duration-500"></div>
          <svg viewBox="0 0 48 48" fill="none" class="w-full h-full relative">
            <circle cx="24" cy="24" r="22" stroke="#CFA35A" stroke-width="1.5"/>
            <path d="M24 8v32M8 24h32" stroke="#CFA35A" stroke-width="1.5"/>
            <circle cx="24" cy="24" r="8" fill="#CFA35A" class="group-hover:animate-pulse"/>
          </svg>
        </div>
        <span class="font-display font-black text-lg lg:text-xl tracking-tight text-white group-hover:tracking-wider transition-all duration-300">
          CIEN MARES
        </span>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center gap-10">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="group relative py-2"
          >
            <span class="font-mono text-[0.7rem] uppercase tracking-[0.2em] font-bold text-white/70 group-hover:text-cm-accent transition-colors duration-300">
              {link.label}
            </span>
            <span class="absolute -bottom-1 left-0 w-0 h-[2px] bg-cm-accent group-hover:w-full transition-all duration-300"></span>
          </a>
        ))}
      </nav>

      <!-- CTA Button -->
      <a
        href="/contacto"
        class="hidden lg:flex items-center gap-2 px-6 py-3 bg-cm-accent text-cm-bg rounded-full font-display font-bold text-xs uppercase tracking-[0.15em] hover:bg-white hover:shadow-glow hover:scale-105 active:scale-95 transition-all duration-300 group"
      >
        <span>Contacto</span>
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>

      <!-- Mobile Toggle -->
      <button
        class="lg:hidden relative z-[1001] w-10 h-10 flex flex-col items-center justify-center gap-1.5"
        id="mobile-toggle"
        aria-label="Menu"
      >
        <span class="mobile-line w-6 h-[2px] bg-white transition-all duration-300 origin-center"></span>
        <span class="mobile-line w-6 h-[2px] bg-white transition-all duration-300"></span>
        <span class="mobile-line w-6 h-[2px] bg-white transition-all duration-300 origin-center"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    class="fixed inset-0 bg-cm-bg z-[999] flex flex-col justify-center px-8 lg:hidden opacity-0 pointer-events-none transition-opacity duration-500"
    id="mobile-menu"
  >
    <nav class="relative z-10 space-y-6">
      {navLinks.map((link, i) => (
        <a
          href={link.href}
          class="mobile-link block font-display font-black text-3xl uppercase tracking-tight text-white/90 hover:text-cm-accent transition-colors"
          style="transform: translateY(20px); opacity: 0;"
        >
          <span class="font-mono text-cm-accent text-sm block mb-1">0{i + 1}</span>
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<style>
  /* Scrolled state - darker background */
  :global(#site-header.scrolled) {
    background: rgba(2, 6, 10, 0.98) !important;
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.4);
  }

  /* Mobile Menu Open */
  :global(.menu-open) .mobile-line:first-child {
    transform: rotate(45deg) translateY(5px);
  }
  :global(.menu-open) .mobile-line:nth-child(2) {
    opacity: 0;
  }
  :global(.menu-open) .mobile-line:last-child {
    transform: rotate(-45deg) translateY(-5px);
  }
</style>

<script>
  import { gsap } from "gsap";

  // Mobile menu
  const toggle = document.getElementById("mobile-toggle");
  const menu = document.getElementById("mobile-menu");
  const mobileLinks = document.querySelectorAll(".mobile-link");
  let isMenuOpen = false;

  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      isMenuOpen = !isMenuOpen;
      document.body.classList.toggle("menu-open", isMenuOpen);

      if (isMenuOpen) {
        menu.classList.remove("opacity-0", "pointer-events-none");
        gsap.to(mobileLinks, {
          y: 0,
          opacity: 1,
          duration: 0.5,
          stagger: 0.08,
          ease: "power3.out",
        });
      } else {
        menu.classList.add("opacity-0", "pointer-events-none");
        gsap.set(mobileLinks, { y: 20, opacity: 0 });
      }
    });

    mobileLinks.forEach((link) => {
      link.addEventListener("click", () => {
        if (isMenuOpen) toggle.click();
      });
    });
  }

  // Simple scroll handler - solo añade efecto de fondo
  const header = document.getElementById("site-header");

  window.addEventListener("scroll", () => {
    if (window.scrollY > 50) {
      header?.classList.add("scrolled");
    } else {
      header?.classList.remove("scrolled");
    }
  }, { passive: true });
</script>
