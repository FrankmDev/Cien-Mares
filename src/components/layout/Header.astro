---
import { navLinks } from "../../data/navigation";
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-[1000] pointer-events-none">
  
  <!-- Header Principal -->
  <div id="header-main" class="pointer-events-auto transition-all duration-700 ease-premium">
    <div class="absolute inset-x-0 top-0 h-32 bg-gradient-to-b from-cm-bg via-cm-bg/80 to-transparent pointer-events-none"></div>
    
    <div class="container mx-auto px-6 lg:px-12 max-w-[1400px] relative">
      <div class="flex items-center justify-between py-5 lg:py-6">
        
        <!-- Logo -->
        <a href="/" class="flex items-center gap-3 group">
          <div class="w-10 h-10 lg:w-11 lg:h-11 relative">
            <div class="absolute inset-0 rounded-full border border-cm-accent/0 group-hover:border-cm-accent/30 group-hover:scale-150 transition-all duration-500"></div>
            <svg viewBox="0 0 48 48" fill="none" class="w-full h-full">
              <circle cx="24" cy="24" r="22" stroke="#CFA35A" stroke-width="1.5"/>
              <path d="M24 8v32M8 24h32" stroke="#CFA35A" stroke-width="1.5"/>
              <circle cx="24" cy="24" r="8" fill="#CFA35A" class="group-hover:animate-pulse"/>
            </svg>
          </div>
          <span class="font-display font-black text-lg lg:text-xl tracking-tight text-white group-hover:tracking-wider transition-all duration-300">
            CIEN MARES
          </span>
        </a>

        <!-- Desktop Navigation -->
        <nav class="hidden lg:flex items-center gap-10">
          {navLinks.map((link) => (
            <a href={link.href} class="group relative py-2">
              <span class="font-mono text-[0.7rem] uppercase tracking-[0.2em] font-bold text-white/70 group-hover:text-cm-accent transition-colors duration-300">
                {link.label}
              </span>
              <span class="absolute -bottom-1 left-0 w-0 h-[2px] bg-cm-accent group-hover:w-full transition-all duration-300"></span>
            </a>
          ))}
        </nav>

        <!-- CTA Button -->
        <a href="/contacto" class="hidden lg:flex items-center gap-2 px-6 py-3 bg-cm-accent text-cm-bg rounded-full font-display font-bold text-xs uppercase tracking-[0.15em] hover:bg-white hover:shadow-glow hover:scale-105 active:scale-95 transition-all duration-300 group">
          <span>Contacto</span>
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>

        <!-- Mobile Toggle -->
        <button id="mobile-toggle" class="lg:hidden relative z-[1001] w-10 h-10 flex flex-col items-center justify-center gap-1.5" aria-label="Menu">
          <span class="mobile-line w-6 h-[2px] bg-white transition-all duration-300 origin-center"></span>
          <span class="mobile-line w-6 h-[2px] bg-white transition-all duration-300"></span>
          <span class="mobile-line w-6 h-[2px] bg-white transition-all duration-300 origin-center"></span>
        </button>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════════════
       BARRA DE MANDO PREMIUM (Aparece al hacer scroll)
       ═══════════════════════════════════════════════════════════════ -->
  <div id="command-bar" class="fixed bottom-8 left-1/2 -translate-x-1/2 pointer-events-auto opacity-0 translate-y-32 scale-90 transition-all duration-700 ease-premium">
    
    <!-- Contenedor principal con efectos premium -->
    <div class="relative">
      
      <!-- Glow difuso trasero -->
      <div class="absolute -inset-4 bg-cm-accent/10 rounded-full blur-2xl opacity-0 glow-back transition-opacity duration-700"></div>
      
      <!-- Líneas decorativas tipo "cuerda" -->
      <div class="absolute -top-6 left-1/2 -translate-x-1/2 flex gap-8 opacity-0 rope-lines transition-all duration-700">
        <div class="w-px h-6 bg-gradient-to-b from-cm-accent/0 via-cm-accent/40 to-cm-accent/0"></div>
        <div class="w-px h-8 bg-gradient-to-b from-cm-accent/0 via-cm-accent/60 to-cm-accent/0"></div>
        <div class="w-px h-6 bg-gradient-to-b from-cm-accent/0 via-cm-accent/40 to-cm-accent/0"></div>
      </div>

      <!-- Barra principal premium -->
      <div class="relative bg-cm-surface/95 backdrop-blur-2xl rounded-full px-2 py-2 border border-white/[0.08] shadow-[0_8px_32px_rgba(0,0,0,0.4),inset_0_1px_0_rgba(255,255,255,0.05)] flex items-center gap-1">
        
        <!-- Línea de brillo superior -->
        <div class="absolute top-0 left-4 right-4 h-px bg-gradient-to-r from-transparent via-white/20 to-transparent"></div>
        
        <!-- Logo/Home con efecto especial -->
        <a href="/" class="relative w-14 h-14 rounded-full flex items-center justify-center group overflow-hidden flex-shrink-0">
          <!-- Fondo animado -->
          <div class="absolute inset-0 bg-gradient-to-br from-cm-accent/20 to-cm-accent/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="absolute inset-0 rounded-full border border-cm-accent/0 group-hover:border-cm-accent/40 group-hover:scale-110 transition-all duration-500"></div>
          
          <!-- Logo -->
          <svg viewBox="0 0 48 48" fill="none" class="w-7 h-7 relative z-10 group-hover:scale-110 transition-transform duration-300">
            <circle cx="24" cy="24" r="22" stroke="#CFA35A" stroke-width="2" class="drop-shadow-[0_0_8px_rgba(207,163,90,0.5)]"/>
            <circle cx="24" cy="24" r="6" fill="#CFA35A" class="drop-shadow-[0_0_8px_rgba(207,163,90,0.8)]"/>
          </svg>
          
          <!-- Efecto de pulso en hover -->
          <div class="absolute inset-0 rounded-full bg-cm-accent/20 scale-0 group-hover:scale-150 group-hover:opacity-0 transition-all duration-700"></div>
        </a>

        <!-- Separador elegante -->
        <div class="w-px h-8 bg-gradient-to-b from-transparent via-white/20 to-transparent mx-1 hidden sm:block"></div>

        <!-- Navegación tipo "Mandos" -->
        <nav class="hidden sm:flex items-center gap-1">
          {navLinks.map((link) => (
            <a 
              href={link.href} 
              class="nav-dial relative w-12 h-12 rounded-full flex items-center justify-center text-white/50 hover:text-cm-accent transition-all duration-300 group"
              title={link.label}
            >
              <!-- Anillo exterior -->
              <span class="absolute inset-0 rounded-full border border-white/5 group-hover:border-cm-accent/30 transition-colors duration-300"></span>
              
              <!-- Brillo en hover -->
              <span class="absolute inset-0 rounded-full bg-cm-accent/0 group-hover:bg-cm-accent/5 transition-colors duration-300"></span>
              
              <!-- Indicador activo (punto dorado) -->
              <span class="absolute top-1.5 left-1/2 -translate-x-1/2 w-1 h-1 rounded-full bg-cm-accent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
              
              <!-- Letra -->
              <span class="font-display font-bold text-sm tracking-tight relative z-10 group-hover:scale-110 transition-transform duration-300">{link.label.charAt(0)}</span>
              
              <!-- Tooltip premium -->
              <span class="absolute -top-12 left-1/2 -translate-x-1/2 px-3 py-1.5 bg-cm-surface rounded-lg text-[0.65rem] font-mono uppercase tracking-[0.15em] text-cm-accent opacity-0 group-hover:opacity-100 transition-all duration-300 whitespace-nowrap pointer-events-none border border-cm-accent/20 shadow-lg shadow-black/20 translate-y-2 group-hover:translate-y-0">
                {link.label}
              </span>
            </a>
          ))}
        </nav>

        <!-- Botón Menú Móvil -->
        <button id="expand-btn" class="sm:hidden w-12 h-12 rounded-full bg-cm-accent/10 border border-cm-accent/20 flex items-center justify-center hover:bg-cm-accent/20 hover:border-cm-accent/40 transition-all duration-300 group">
          <svg class="w-5 h-5 text-cm-accent group-hover:scale-110 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>

        <!-- Separador -->
        <div class="w-px h-8 bg-gradient-to-b from-transparent via-white/20 to-transparent mx-1"></div>

        <!-- CTA Principal Premium -->
        <a href="/contacto" class="flex items-center gap-2 pl-4 pr-5 py-3 bg-gradient-to-r from-cm-accent to-cm-accent-light text-cm-bg rounded-full font-display font-bold text-xs uppercase tracking-wider hover:shadow-[0_0_30px_rgba(207,163,90,0.4)] hover:scale-105 active:scale-95 transition-all duration-300 group relative overflow-hidden">
          <!-- Brillo animado -->
          <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/30 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-700"></div>
          
          <svg class="w-4 h-4 relative z-10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
          </svg>
          <span class="relative z-10 hidden sm:inline">Contacto</span>
        </a>
      </div>

      <!-- Brújula decorativa flotante mejorada -->
      <div class="absolute -right-6 -top-6 opacity-0 compass-float">
        <div class="w-12 h-12 rounded-full bg-cm-surface/80 backdrop-blur border border-cm-accent/20 flex items-center justify-center shadow-lg shadow-black/30">
          <svg viewBox="0 0 24 24" fill="none" class="w-6 h-6 text-cm-accent/70 animate-spin" style="animation-duration: 25s;">
            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1"/>
            <path d="M12 2v3M12 19v3M2 12h3M19 12h3M4.93 4.93l2.12 2.12M16.95 16.95l2.12 2.12M4.93 19.07l2.12-2.12M16.95 7.05l2.12-2.12" stroke="currentColor" stroke-width="1"/>
          </svg>
        </div>
        <!-- Punto central brillante -->
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-2 h-2 rounded-full bg-cm-accent shadow-[0_0_10px_rgba(207,163,90,0.8)]"></div>
      </div>

      <!-- Indicadores de posición tipo "nivel" -->
      <div class="absolute -left-8 top-1/2 -translate-y-1/2 flex flex-col gap-1 opacity-0 level-indicators">
        <div class="w-1.5 h-1.5 rounded-full bg-cm-accent/60"></div>
        <div class="w-1.5 h-3 rounded-full bg-cm-accent"></div>
        <div class="w-1.5 h-1.5 rounded-full bg-cm-accent/60"></div>
      </div>
    </div>

    <!-- Menú Expandible (Móvil) -->
    <div id="expand-menu" class="absolute bottom-full left-1/2 -translate-x-1/2 mb-6 w-72 opacity-0 translate-y-4 pointer-events-none transition-all duration-500 ease-premium">
      <div class="bg-cm-surface/95 backdrop-blur-2xl rounded-3xl border border-white/[0.08] overflow-hidden shadow-2xl shadow-black/40 p-2">
        <!-- Header -->
        <div class="px-4 py-3 border-b border-white/5 mb-2">
          <span class="font-mono text-[0.6rem] uppercase tracking-[0.2em] text-cm-accent">Navegación</span>
        </div>
        
        <!-- Links -->
        {navLinks.map((link) => (
          <a 
            href={link.href} 
            class="flex items-center gap-4 px-4 py-4 rounded-2xl text-white/70 hover:text-white hover:bg-white/5 transition-all duration-300 group"
          >
            <span class="w-10 h-10 rounded-full bg-cm-accent/10 flex items-center justify-center font-display font-bold text-cm-accent group-hover:bg-cm-accent group-hover:text-cm-bg transition-all duration-300 border border-cm-accent/20 group-hover:border-cm-accent">
              {link.label.charAt(0)}
            </span>
            <span class="font-display font-bold text-sm uppercase tracking-wide">{link.label}</span>
            <svg class="w-4 h-4 ml-auto opacity-0 -translate-x-2 text-cm-accent group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M9 18l6-6-6-6"/>
            </svg>
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- Mobile Menu Full Screen -->
  <div id="mobile-menu" class="fixed inset-0 bg-cm-bg z-[999] flex flex-col justify-center px-8 lg:hidden opacity-0 pointer-events-none transition-opacity duration-500">
    <nav class="relative z-10 space-y-6">
      {navLinks.map((link, i) => (
        <a href={link.href} class="mobile-link block font-display font-black text-3xl uppercase tracking-tight text-white/90 hover:text-cm-accent transition-colors" style="transform: translateY(20px); opacity: 0;">
          <span class="font-mono text-cm-accent text-sm block mb-1">0{i + 1}</span>
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<style>
  /* ═══════════════════════════════════════════════════════════════
     TRANSICIONES PRINCIPALES
     ═══════════════════════════════════════════════════════════════ */
  
  /* Header principal se desliza hacia arriba */
  #site-header.scrolled #header-main {
    opacity: 0;
    transform: translateY(-30px);
    pointer-events: none;
  }

  /* Barra de mando aparece desde abajo */
  #site-header.scrolled #command-bar {
    opacity: 1;
    transform: translateX(-50%) translateY(0) scale(1);
  }

  /* ═══════════════════════════════════════════════════════════════
     EFECTOS VISUALES AL APARECER
     ═══════════════════════════════════════════════════════════════ */
  
  /* Glow trasero */
  #site-header.scrolled .glow-back {
    opacity: 1;
  }

  /* Líneas tipo cuerda */
  #site-header.scrolled .rope-lines {
    opacity: 1;
    animation: rope-sway 4s ease-in-out infinite;
  }

  /* Brújula flotante */
  #site-header.scrolled .compass-float {
    opacity: 1;
    animation: compass-bob 5s ease-in-out infinite;
  }

  /* Indicadores de nivel */
  #site-header.scrolled .level-indicators {
    opacity: 1;
    animation: level-pulse 3s ease-in-out infinite;
  }

  /* ═══════════════════════════════════════════════════════════════
     ANIMACIONES
     ═══════════════════════════════════════════════════════════════ */
  
  @keyframes rope-sway {
    0%, 100% { transform: translateX(-50%) translateY(0) rotate(0deg); }
    25% { transform: translateX(-50%) translateY(-2px) rotate(1deg); }
    75% { transform: translateX(-50%) translateY(-2px) rotate(-1deg); }
  }

  @keyframes compass-bob {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-8px) rotate(3deg); }
  }

  @keyframes level-pulse {
    0%, 100% { opacity: 0.6; }
    50% { opacity: 1; }
  }

  /* Menú expandible */
  #site-header.expand-open #expand-menu {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
    pointer-events: auto;
  }

  /* Mobile Menu */
  .menu-open-mobile .mobile-line:first-child {
    transform: rotate(45deg) translateY(5px);
  }
  .menu-open-mobile .mobile-line:nth-child(2) {
    opacity: 0;
  }
  .menu-open-mobile .mobile-line:last-child {
    transform: rotate(-45deg) translateY(-5px);
  }
</style>

<script>
  import { gsap } from "gsap";

  const header = document.getElementById("site-header");
  const expandBtn = document.getElementById("expand-btn");
  const mobileToggle = document.getElementById("mobile-toggle");
  const mobileMenu = document.getElementById("mobile-menu");
  const mobileLinks = document.querySelectorAll(".mobile-link");
  
  let isExpanded = false;
  let isMobileOpen = false;
  let ticking = false;

  // Scroll handler optimizado
  function updateHeader() {
    const scrollY = window.scrollY;
    
    if (scrollY > 150) {
      header?.classList.add("scrolled");
    } else {
      header?.classList.remove("scrolled");
      if (isExpanded) toggleExpand();
    }
    
    ticking = false;
  }

  window.addEventListener("scroll", () => {
    if (!ticking) {
      requestAnimationFrame(updateHeader);
      ticking = true;
    }
  }, { passive: true });

  // Toggle menú expandible
  function toggleExpand() {
    isExpanded = !isExpanded;
    header?.classList.toggle("expand-open", isExpanded);
  }

  expandBtn?.addEventListener("click", toggleExpand);

  // Cerrar al hacer click fuera
  document.addEventListener("click", (e) => {
    if (isExpanded && !header?.contains(e.target as Node)) {
      toggleExpand();
    }
  });

  // Mobile menu
  mobileToggle?.addEventListener("click", () => {
    isMobileOpen = !isMobileOpen;
    document.body.classList.toggle("menu-open-mobile", isMobileOpen);

    if (isMobileOpen) {
      mobileMenu?.classList.remove("opacity-0", "pointer-events-none");
      gsap.to(mobileLinks, {
        y: 0,
        opacity: 1,
        duration: 0.5,
        stagger: 0.08,
        ease: "power3.out",
      });
    } else {
      mobileMenu?.classList.add("opacity-0", "pointer-events-none");
      gsap.set(mobileLinks, { y: 20, opacity: 0 });
    }
  });

  mobileLinks.forEach((link) => {
    link.addEventListener("click", () => {
      if (isMobileOpen) mobileToggle?.click();
    });
  });
</script>
