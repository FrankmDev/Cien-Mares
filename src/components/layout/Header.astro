---
import { navLinks } from "../../data/navigation";

interface Props {
  transparent?: boolean;
}

const { transparent = false } = Astro.props;
---

<header
  id="site-header"
  class:list={[
    "fixed top-0 left-0 right-0 z-[1000] transition-all duration-500",
    transparent ? "bg-transparent" : "bg-[#02060a]/90 backdrop-blur-xl border-b border-white/5"
  ]}
>
  <div class="container mx-auto px-6 lg:px-12 max-w-[1400px]">
    <div class="flex items-center justify-between py-5 lg:py-6">
      
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group">
        <div class="w-10 h-10 lg:w-11 lg:h-11 relative">
          <svg viewBox="0 0 48 48" fill="none" class="w-full h-full">
            <circle cx="24" cy="24" r="22" stroke="currentColor" stroke-width="1.5" class="text-[#CFA35A]"/>
            <path d="M24 8v32M8 24h32" stroke="currentColor" stroke-width="1.5" class="text-[#CFA35A]"/>
            <circle cx="24" cy="24" r="8" fill="currentColor" class="text-[#CFA35A]"/>
          </svg>
        </div>
        <span class="header-logo-text font-display font-black text-lg lg:text-xl tracking-tight text-white transition-colors duration-300">
          CIEN MARES
        </span>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center gap-10">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="group relative py-2"
          >
            <span class="header-nav-text font-mono text-[0.7rem] uppercase tracking-[0.2em] font-bold text-white/70 group-hover:text-[#CFA35A] transition-colors duration-300">
              {link.label}
            </span>
            <span class="absolute -bottom-1 left-0 w-0 h-[2px] bg-[#CFA35A] group-hover:w-full transition-all duration-300"></span>
          </a>
        ))}
      </nav>

      <!-- CTA Button -->
      <a
        href="/contacto"
        class="header-cta hidden lg:flex items-center gap-2 px-6 py-3 bg-[#CFA35A] text-[#02060a] rounded-full font-display font-bold text-xs uppercase tracking-[0.15em] hover:bg-white transition-all duration-300"
      >
        <span>Contacto</span>
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>

      <!-- Mobile Toggle -->
      <button
        class="lg:hidden relative z-[1001] w-10 h-10 flex flex-col items-center justify-center gap-1.5"
        id="mobile-toggle"
        aria-label="Menu"
      >
        <span class="mobile-line w-6 h-[2px] bg-white transition-all duration-300 origin-center"></span>
        <span class="mobile-line w-6 h-[2px] bg-white transition-all duration-300"></span>
        <span class="mobile-line w-6 h-[2px] bg-white transition-all duration-300 origin-center"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    class="fixed inset-0 bg-[#02060a] z-[999] flex flex-col justify-center px-8 lg:hidden opacity-0 pointer-events-none transition-opacity duration-500"
    id="mobile-menu"
  >
    <nav class="relative z-10 space-y-6">
      {navLinks.map((link, i) => (
        <a
          href={link.href}
          class="mobile-link block font-display font-black text-3xl uppercase tracking-tight text-white/90 hover:text-[#CFA35A] transition-colors"
          style="transform: translateY(20px); opacity: 0;"
        >
          <span class="font-mono text-[#CFA35A] text-sm block mb-1">0{i + 1}</span>
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<style>
  /* Light theme - when header has header-light class */
  :global(#site-header.header-light) {
    background: rgba(250, 250, 250, 0.95) !important;
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(10, 10, 10, 0.05);
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.05);
  }
  
  :global(#site-header.header-light) .header-logo-text {
    color: #0A0A0A;
  }
  
  :global(#site-header.header-light) .header-nav-text {
    color: rgba(10, 10, 10, 0.7);
  }
  
  :global(#site-header.header-light) .header-nav-text:hover {
    color: #CFA35A;
  }
  
  :global(#site-header.header-light) .header-cta {
    background: #0A0A0A;
    color: #FAFAFA;
  }
  
  :global(#site-header.header-light) .header-cta:hover {
    background: #CFA35A;
    color: #02060a;
  }
  
  :global(#site-header.header-light) .mobile-line {
    background: #0A0A0A;
  }

  /* Scrolled state - dark background with blur */
  :global(#site-header.scrolled) {
    background: rgba(2, 6, 10, 0.95) !important;
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.3);
  }

  /* Mobile Menu Open */
  :global(.menu-open) .mobile-line:first-child {
    transform: rotate(45deg) translateY(5px);
  }
  :global(.menu-open) .mobile-line:nth-child(2) {
    opacity: 0;
  }
  :global(.menu-open) .mobile-line:last-child {
    transform: rotate(-45deg) translateY(-5px);
  }
</style>

<script>
  import { gsap } from "gsap";

  // Mobile menu
  const toggle = document.getElementById("mobile-toggle");
  const menu = document.getElementById("mobile-menu");
  const mobileLinks = document.querySelectorAll(".mobile-link");
  let isMenuOpen = false;

  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      isMenuOpen = !isMenuOpen;
      document.body.classList.toggle("menu-open", isMenuOpen);

      if (isMenuOpen) {
        menu.classList.remove("opacity-0", "pointer-events-none");
        gsap.to(mobileLinks, {
          y: 0,
          opacity: 1,
          duration: 0.5,
          stagger: 0.08,
          ease: "power3.out",
        });
      } else {
        menu.classList.add("opacity-0", "pointer-events-none");
        gsap.set(mobileLinks, { y: 20, opacity: 0 });
      }
    });

    mobileLinks.forEach((link) => {
      link.addEventListener("click", () => {
        if (isMenuOpen) toggle.click();
      });
    });
  }

  // Scroll handler for background and light/dark sections
  const header = document.getElementById("site-header");
  let lastScrollY = 0;

  window.addEventListener("scroll", () => {
    const scrollY = window.scrollY;
    
    // Add scrolled class for background effect
    if (scrollY > 50) {
      header?.classList.add("scrolled");
    } else {
      header?.classList.remove("scrolled");
    }
    
    lastScrollY = scrollY;
  }, { passive: true });

  // Intersection Observer for light/dark sections
  const observerOptions = {
    root: null,
    rootMargin: "-10% 0px -80% 0px",
    threshold: 0
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      const theme = entry.target.getAttribute("data-theme");
      
      if (entry.isIntersecting) {
        if (theme === "light") {
          header?.classList.add("header-light");
          header?.classList.remove("scrolled");
        } else {
          header?.classList.remove("header-light");
        }
      }
    });
  }, observerOptions);

  document.querySelectorAll("[data-theme]").forEach((section) => {
    observer.observe(section);
  });
</script>
