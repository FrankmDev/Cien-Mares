---
/**
 * Label de seccion con punto pulsante
 */
interface Props {
  label: string;
  variant?: "dark" | "light";
}

const { label, variant = "dark" } = Astro.props;

const variants = {
  dark: "bg-[#0A0A0A] text-white",
  light: "bg-white text-[#0A0A0A] border border-[#0A0A0A]/10",
};
---

<div class={`inline-flex items-center gap-2 px-4 py-2 rounded-full ${variants[variant]}`}>
  <span class="w-1.5 h-1.5 rounded-full bg-[#CFA35A] animate-pulse"></span>
  <span class="font-mono text-[0.65rem] uppercase tracking-[0.2em] font-bold">
    {label}
  </span>
</div>
