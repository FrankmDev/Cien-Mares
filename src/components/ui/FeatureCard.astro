---
/**
 * FeatureCard - Tarjeta de características/servicio
 * 
 * Props:
 * - icon?: string | Astro.Component - Icono (nombre de icono o componente)
 * - title: string (requerido) - Título
 * - description?: string - Descripción
 * - features?: string[] - Lista de características
 * - link?: { href: string; text: string } - Link opcional
 * - variant?: 'default' | 'highlighted' | 'minimal'
 * - size?: 'sm' | 'md' | 'lg'
 */

interface Props {
  icon?: string;
  title: string;
  description?: string;
  features?: string[];
  link?: {
    href: string;
    text: string;
    external?: boolean;
  };
  variant?: 'default' | 'highlighted' | 'minimal';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const {
  icon,
  title,
  description,
  features = [],
  link,
  variant = 'default',
  size = 'md',
  class: className = '',
} = Astro.props;

// Size configurations
const sizeClasses = {
  sm: 'p-6',
  md: 'p-8',
  lg: 'p-10',
};

const iconSizes = {
  sm: 'w-10 h-10',
  md: 'w-12 h-12',
  lg: 'w-14 h-14',
};

// Variant classes
const variantClasses = {
  default: 'bg-cm-surface border border-cm-border hover:border-cm-accent/30',
  highlighted: 'bg-gradient-to-br from-cm-accent/10 to-transparent border border-cm-accent/30',
  minimal: 'bg-transparent border border-cm-border/50 hover:border-cm-border',
};
---

<div 
  class={`
    relative group rounded-card-lg 
    ${sizeClasses[size]} 
    ${variantClasses[variant]}
    transition-all duration-500 ease-premium
    hover:shadow-card-hover hover:-translate-y-1
    ${className}
  `}
  data-reveal="fade"
>
  <!-- Icon -->
  {icon && (
    <div class={`
      ${iconSizes[size]} 
      rounded-icon-lg 
      flex items-center justify-center mb-6
      ${variant === 'highlighted' ? 'bg-cm-accent text-cm-bg' : 'bg-white/5 text-cm-accent'}
      transition-all duration-300
      group-hover:bg-cm-accent group-hover:text-cm-bg group-hover:scale-110
    `}>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5">
        <path stroke-linecap="round" stroke-linejoin="round" d={icon} />
      </svg>
    </div>
  )}
  
  <!-- Title -->
  <h3 class="font-display font-bold text-xl lg:text-2xl text-white mb-3">
    {title}
  </h3>
  
  <!-- Description -->
  {description && (
    <p class="text-cm-text-muted leading-relaxed mb-4">
      {description}
    </p>
  )}
  
  <!-- Features List -->
  {features.length > 0 && (
    <ul class="space-y-2 mt-4">
      {features.map((feature) => (
        <li class="flex items-start gap-3 text-sm text-cm-text-muted">
          <span class="w-1.5 h-1.5 rounded-full bg-cm-accent mt-2 flex-shrink-0"></span>
          <span>{feature}</span>
        </li>
      ))}
    </ul>
  )}
  
  <!-- Link -->
  {link && (
    <div class="mt-6 pt-6 border-t border-cm-border">
      <a 
        href={link.href}
        class="inline-flex items-center gap-2 font-mono text-xs uppercase tracking-wider text-cm-accent hover:text-white transition-colors group/link"
        {...(link.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
      >
        <span>{link.text}</span>
        <svg 
          class="w-4 h-4 transition-transform group-hover/link:translate-x-1" 
          fill="none" 
          viewBox="0 0 24 24" 
          stroke="currentColor"
        >
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  )}
</div>
