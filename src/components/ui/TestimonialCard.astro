---
/**
 * Tarjeta de testimonio reutilizable
 */
interface Props {
  quote: string;
  author: string;
  role: string;
  location: string;
  rating: number;
  index?: number;
}

const { quote, author, role, location, rating, index = 0 } = Astro.props;

const initials = author
  .split(" ")
  .map((n) => n[0])
  .join("")
  .substring(0, 2);
---

<div class="test-card group relative" data-index={index}>
  <div
    class="relative h-full p-8 lg:p-10 rounded-[2rem] bg-white border border-[#0A0A0A]/5 hover:border-[#CFA35A]/20 transition-all duration-500 hover:shadow-[0_20px_60px_-15px_rgba(207,163,90,0.15)] hover:-translate-y-1"
  >
    {/* Top accent line */}
    <div
      class="absolute top-0 left-10 right-10 h-[2px] bg-gradient-to-r from-transparent via-[#CFA35A] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"
    >
    </div>

    {/* Quote Icon */}
    <div
      class="absolute -top-4 -right-4 w-16 h-16 rounded-full bg-gradient-to-br from-[#CFA35A] to-[#8e6f38] flex items-center justify-center shadow-lg shadow-[#CFA35A]/20 group-hover:scale-110 group-hover:rotate-12 transition-all duration-300"
    >
      <svg class="w-7 h-7 text-white" viewBox="0 0 24 24" fill="currentColor">
        <path
          d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"
        ></path>
      </svg>
    </div>

    {/* Stars */}
    <div class="flex gap-1 mb-6">
      {
        Array(rating)
          .fill(0)
          .map(() => (
            <svg class="w-5 h-5 text-[#CFA35A]" viewBox="0 0 20 20" fill="currentColor">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))
      }
    </div>

    {/* Quote */}
    <blockquote class="font-body text-[#0A0A0A]/80 leading-relaxed mb-8 text-lg italic">
      "{quote}"
    </blockquote>

    {/* Author */}
    <div class="flex items-center gap-4 pt-6 border-t border-[#0A0A0A]/5">
      <div
        class="w-14 h-14 rounded-full bg-gradient-to-br from-[#CFA35A] to-[#8e6f38] flex items-center justify-center shadow-lg group-hover:shadow-[0_0_20px_rgba(207,163,90,0.3)] transition-shadow"
      >
        <span class="font-display font-bold text-base text-white">{initials}</span>
      </div>
      <div class="flex-1">
        <span class="font-display font-bold text-[#0A0A0A] block">{author}</span>
        <span class="font-mono text-[0.65rem] uppercase tracking-[0.15em] text-[#0A0A0A]/50">
          {role}
        </span>
      </div>
      <div class="text-right">
        <span
          class="font-mono text-[0.6rem] uppercase tracking-[0.1em] text-[#CFA35A]/70 flex items-center gap-1"
        >
          <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"></path>
            <circle cx="12" cy="10" r="3"></circle>
          </svg>
          {location}
        </span>
      </div>
    </div>
  </div>
</div>
