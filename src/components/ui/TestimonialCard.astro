---
/**
 * Tarjeta de testimonio reutilizable - Diseño premium
 */
interface Props {
  quote: string;
  author: string;
  role: string;
  location: string;
  rating: number;
  index?: number;
}

const { quote, author, role, location, rating, index = 0 } = Astro.props;

const initials = author
  .split(" ")
  .map((n) => n[0])
  .join("")
  .substring(0, 2);
---

<div class="test-card group relative h-full" data-index={index}>
  {/* Card container */}
  <div
    class="relative h-full p-8 lg:p-10 rounded-[2rem] bg-white border border-[#0A0A0A]/5 transition-all duration-500 overflow-hidden"
  >
    {/* Background gradient on hover */}
    <div class="absolute inset-0 bg-gradient-to-br from-[#CFA35A]/5 via-transparent to-[#CFA35A]/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
    
    {/* Top accent line */}
    <div
      class="absolute top-0 left-8 right-8 h-[2px] bg-gradient-to-r from-transparent via-[#CFA35A] to-transparent opacity-0 group-hover:opacity-100 transition-all duration-500"
    ></div>

    {/* Decorative corner */}
    <div class="absolute top-0 right-0 w-24 h-24 overflow-hidden opacity-0 group-hover:opacity-100 transition-opacity duration-500">
      <div class="absolute top-0 right-0 w-full h-full bg-gradient-to-bl from-[#CFA35A]/10 to-transparent transform translate-x-8 -translate-y-8 rotate-45"></div>
    </div>

    {/* Quote Icon - Fixed position */}
    <div
      class="absolute top-4 right-4 w-12 h-12 rounded-full bg-gradient-to-br from-[#CFA35A] to-[#8e6f38] flex items-center justify-center shadow-lg shadow-[#CFA35A]/30 group-hover:shadow-[#CFA35A]/50 group-hover:scale-110 transition-all duration-500 z-10"
    >
      <svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="currentColor">
        <path
          d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"
        ></path>
      </svg>
    </div>

    {/* Stars */}
    <div class="flex gap-1 mb-6">
      {
        Array(rating)
          .fill(0)
          .map((_, i) => (
            <svg 
              class="w-5 h-5 text-[#CFA35A] transform transition-transform duration-300 group-hover:scale-110" 
              style={`transition-delay: ${i * 50}ms`}
              viewBox="0 0 20 20" 
              fill="currentColor"
            >
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))
      }
    </div>

    {/* Quote */}
    <blockquote class="font-body text-[#0A0A0A]/80 leading-relaxed mb-8 text-base lg:text-lg pr-8">
      "{quote}"
    </blockquote>

    {/* Author section */}
    <div class="flex items-center gap-4 pt-6 border-t border-[#0A0A0A]/5">
      {/* Avatar */}
      <div class="relative">
        <div
          class="w-12 h-12 lg:w-14 lg:h-14 rounded-full bg-gradient-to-br from-[#CFA35A] to-[#8e6f38] flex items-center justify-center shadow-lg group-hover:shadow-[0_0_20px_rgba(207,163,90,0.4)] transition-all duration-500"
        >
          <span class="font-display font-bold text-sm lg:text-base text-white">{initials}</span>
        </div>
        {/* Ring animation */}
        <div class="absolute inset-0 rounded-full border-2 border-[#CFA35A]/0 group-hover:border-[#CFA35A]/50 scale-125 group-hover:scale-150 opacity-0 group-hover:opacity-100 transition-all duration-500"></div>
      </div>
      
      <div class="flex-1 min-w-0">
        <span class="font-display font-bold text-[#0A0A0A] block text-sm lg:text-base group-hover:text-[#CFA35A] transition-colors duration-300">{author}</span>
        <span class="font-mono text-[0.6rem] uppercase tracking-[0.15em] text-[#0A0A0A]/50">
          {role}
        </span>
      </div>
      
      {/* Location */}
      <div class="hidden sm:block">
        <span
          class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-[#CFA35A]/10 text-[#CFA35A] font-mono text-[0.55rem] uppercase tracking-[0.1em] group-hover:bg-[#CFA35A] group-hover:text-white transition-all duration-300"
        >
          <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"></path>
            <circle cx="12" cy="10" r="3"></circle>
          </svg>
          {location}
        </span>
      </div>
    </div>

    {/* Mobile location */}
    <div class="sm:hidden mt-4">
      <span
        class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-[#CFA35A]/10 text-[#CFA35A] font-mono text-[0.55rem] uppercase tracking-[0.1em]"
      >
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"></path>
          <circle cx="12" cy="10" r="3"></circle>
        </svg>
        {location}
      </span>
    </div>
  </div>
</div>

<style>
  .test-card {
    perspective: 1000px;
  }
  
  .test-card > div {
    transform-style: preserve-3d;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.5s ease, border-color 0.3s ease;
  }
  
  .test-card:hover > div {
    transform: translateY(-6px);
    box-shadow: 0 25px 50px -12px rgba(207, 163, 90, 0.15);
    border-color: rgba(207, 163, 90, 0.2);
  }
</style>
