---
/**
 * CTABanner - Banner de llamada a la acción
 * 
 * Props:
 * - title: string (requerido)
 * - highlighted?: string - Texto resaltado
 * - description?: string
 * - primaryButton?: { text: string; href: string; external?: boolean }
 * - secondaryButton?: { text: string; href: string; external?: boolean }
 * - background?: 'dark' | 'gold' | 'gradient'
 * - size?: 'default' | 'large'
 */

interface Props {
  title: string;
  highlighted?: string;
  description?: string;
  primaryButton?: {
    text: string;
    href: string;
    external?: boolean;
  };
  secondaryButton?: {
    text: string;
    href: string;
    external?: boolean;
  };
  background?: 'dark' | 'gold' | 'gradient';
  size?: 'default' | 'large';
  class?: string;
}

const {
  title,
  highlighted,
  description,
  primaryButton,
  secondaryButton,
  background = 'gradient',
  size = 'default',
  class: className = '',
} = Astro.props;

// Background classes
const bgClasses = {
  dark: 'bg-cm-surface',
  gold: 'bg-cm-accent',
  gradient: 'bg-gradient-to-br from-cm-surface via-cm-surface to-cm-accent/10',
};

// Title size
const titleClasses = size === 'large' 
  ? 'text-3xl sm:text-4xl lg:text-5xl xl:text-6xl' 
  : 'text-2xl sm:text-3xl lg:text-4xl';

// Text colors based on background
const textColorClass = background === 'gold' ? 'text-cm-bg' : 'text-white';
const mutedColorClass = background === 'gold' ? 'text-cm-bg/70' : 'text-cm-text-muted';
---

<section 
  class={`cta-banner section-sm relative overflow-hidden ${bgClasses[background]} ${className}`}
>
  <!-- Decorative elements -->
  {background === 'gradient' && (
    <div class="cta-deco absolute top-0 right-0 w-96 h-96 bg-cm-accent/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
    <div class="cta-deco absolute bottom-0 left-0 w-64 h-64 bg-cm-accent/5 rounded-full blur-3xl translate-y-1/2 -translate-x-1/2"></div>
  )}
  
  <div class="container-main relative z-10">
    <div class="text-center max-w-4xl mx-auto">
      <h2 class={`cta-title font-display font-black uppercase tracking-tighter leading-[0.9] ${titleClasses} ${textColorClass} mb-6`}>
        {title}
        {highlighted && (
          <>
            <br />
            <span class={background === 'gold' ? 'text-white' : 'text-cm-accent'}>{highlighted}</span>
          </>
        )}
      </h2>
      
      {description && (
        <p class={`cta-desc text-lg lg:text-xl ${mutedColorClass} mb-10 max-w-2xl mx-auto`}>
          {description}
        </p>
      )}
      
      <!-- Buttons -->
      {(primaryButton || secondaryButton) && (
        <div class="cta-buttons flex flex-col sm:flex-row items-center justify-center gap-4">
          {primaryButton && (
            <a 
              href={primaryButton.href}
              class={`btn btn-lg ${background === 'gold' ? 'bg-cm-bg text-white hover:bg-cm-surface' : 'btn-primary'}`}
              {...(primaryButton.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
            >
              <span>{primaryButton.text}</span>
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          )}
          
          {secondaryButton && (
            <a 
              href={secondaryButton.href}
              class={`btn btn-lg ${background === 'gold' ? 'border-cm-bg/30 text-cm-bg hover:bg-cm-bg/10' : 'btn-secondary'}`}
              {...(secondaryButton.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
            >
              {secondaryButton.text}
            </a>
          )}
        </div>
      )}
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  
  gsap.registerPlugin(ScrollTrigger);
  
  // Only run animations on desktop (pointer: fine) to avoid mobile issues
  const isTouchDevice = window.matchMedia('(pointer: coarse)').matches;
  
  if (!isTouchDevice) {
    document.querySelectorAll('.cta-banner').forEach((banner) => {
      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: banner,
          start: "top 85%",
          toggleActions: "play none none none",
          once: true
        }
      });
      
      tl.fromTo(banner.querySelector('.cta-title'), 
        { opacity: 0, y: 30 },
        { opacity: 1, y: 0, duration: 0.6, ease: "power2.out" }
      )
      .fromTo(banner.querySelector('.cta-desc'), 
        { opacity: 0, y: 20 },
        { opacity: 1, y: 0, duration: 0.5, ease: "power2.out" },
        "-=0.3"
      )
      .fromTo(banner.querySelector('.cta-buttons'), 
        { opacity: 0, y: 20 },
        { opacity: 1, y: 0, duration: 0.5, ease: "power2.out" },
        "-=0.3"
      )
      .fromTo(banner.querySelectorAll('.cta-deco'), 
        { opacity: 0, scale: 0.8 },
        { opacity: 1, scale: 1, duration: 0.8, ease: "power2.out", stagger: 0.1 },
        "-=0.5"
      );
    });
  }
</script>
