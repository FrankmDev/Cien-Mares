---
/**
 * QuoteBlock - Bloque de cita/testimonio destacado
 * 
 * Props:
 * - quote: string (requerido)
 * - author?: string
 * - role?: string
 * - variant?: 'default' | 'large' | 'minimal'
 */

interface Props {
  quote: string;
  author?: string;
  role?: string;
  variant?: 'default' | 'large' | 'minimal';
  class?: string;
}

const {
  quote,
  author,
  role,
  variant = 'default',
  class: className = '',
} = Astro.props;

const quoteClasses = {
  default: 'text-xl lg:text-2xl font-light italic',
  large: 'text-2xl lg:text-3xl xl:text-4xl font-light italic',
  minimal: 'text-lg font-normal',
};
---

<blockquote 
  class={`
    relative pl-8 border-l-2 border-cm-accent
    ${className}
  `}
  data-reveal="fade"
>
  <!-- Quote icon -->
  <div class="absolute -top-2 -left-3 w-6 h-6 flex items-center justify-center bg-cm-accent rounded-full">
    <svg class="w-3 h-3 text-cm-bg" fill="currentColor" viewBox="0 0 24 24">
      <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
    </svg>
  </div>
  
  <p class={`text-white ${quoteClasses[variant]} leading-relaxed`}>
    "{quote}"
  </p>
  
  {(author || role) && (
    <footer class="mt-4">
      {author && (
        <cite class="not-italic font-display font-bold text-cm-accent">
          {author}
        </cite>
      )}
      {role && (
        <span class="text-cm-text-muted text-sm ml-2">
          {role}
        </span>
      )}
    </footer>
  )}
</blockquote>
