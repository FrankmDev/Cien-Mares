---
/**
 * ServicesSection — Horizontal Scroll Gallery
 * Cinematic service showcase with immersive transitions
 */

const services = [
  {
    id: 'alquiler',
    number: '01',
    title: 'Alquiler',
    subtitle: 'Chárter Premium',
    description: 'Embarcaciones de élite seleccionadas para experiencias inolvidables. Desde veleros íntimos hasta megayates de lujo.',
    image: 'https://images.unsplash.com/photo-1567899378494-47b22a2ae96a?w=1600&q=85',
    link: '/navegar',
    stat: { value: '50+', label: 'Embarcaciones' }
  },
  {
    id: 'academia',
    number: '02',
    title: 'Academia',
    subtitle: 'Formación Elite',
    description: 'Titulaciones homologadas con instructores de décadas de experiencia. Aprende a dominar el mar con los mejores.',
    image: 'https://images.unsplash.com/photo-1544551763-46a013bb70d5?w=1600&q=85',
    link: '/aprender',
    stat: { value: '99%', label: 'Éxito' }
  },
  {
    id: 'gestoria',
    number: '03',
    title: 'Gestoría',
    subtitle: 'Gestión Integral',
    description: 'Gestión documental completa para tu embarcación. Permisos, matriculaciones, seguros y todo el papeleo naval.',
    image: 'https://images.unsplash.com/photo-1605281317010-fe5ffe798166?w=1600&q=85',
    link: '/gestionar',
    stat: { value: '100%', label: 'Eficacia' }
  },
  {
    id: 'traslados',
    number: '04',
    title: 'Traslados',
    subtitle: 'Logística Global',
    description: 'Transporte internacional de embarcaciones por vía marítima y terrestre. Tu barco donde lo necesites.',
    image: 'https://images.unsplash.com/photo-1500930287596-c1ecaa373bb2?w=1600&q=85',
    link: '/contacto',
    stat: { value: '3K+', label: 'Millas' }
  },
];
---

<section
  class="bg-[#02060a] text-white relative z-20"
  id="services-wrapper"
  data-theme="dark"
>
  <!-- Fixed Header -->
  <div class="absolute top-8 left-8 lg:left-16 z-40">
    <div class="flex items-center gap-3">
      <span class="font-mono text-[0.65rem] uppercase tracking-[0.4em] text-[#CFA35A] font-bold">04</span>
      <div class="w-10 h-[1px] bg-[#CFA35A]"></div>
      <span class="font-mono text-[0.65rem] uppercase tracking-[0.4em] text-white/50">Servicios</span>
    </div>
  </div>

  <!-- Progress Dots -->
  <div class="absolute right-8 lg:right-16 top-1/2 -translate-y-1/2 z-40 hidden lg:flex flex-col items-center gap-3">
    {services.map((_, i) => (
      <div class="service-dot w-2 h-2 rounded-full bg-white/20 transition-all duration-500" data-index={i}></div>
    ))}
  </div>

  <!-- Main Content -->
  <div class="h-screen w-full flex overflow-hidden" id="services-pinned">
    <!-- Horizontal Track -->
    <div class="flex flex-nowrap h-full w-[400vw] will-change-transform" id="services-track">
      {services.map((service, i) => (
        <div class="w-[100vw] h-screen shrink-0 relative flex items-center overflow-hidden service-panel">
          <!-- Background Image -->
          <div class="absolute inset-0 w-[120%] h-full -left-[10%]" data-srv-bg>
            <img 
              src={service.image} 
              alt={service.title}
              class="w-full h-full object-cover"
              style="filter: grayscale(40%) brightness(0.5);"
              loading={i === 0 ? "eager" : "lazy"}
            />
            <div class="absolute inset-0 bg-gradient-to-r from-[#02060a] via-[#02060a]/80 to-transparent" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#02060a] via-transparent to-[#02060a]/50" />
          </div>

          <!-- Large Background Number -->
          <div class="absolute right-[5%] top-1/2 -translate-y-1/2 font-display font-black text-[35vh] leading-none text-white/[0.03] select-none pointer-events-none">
            {service.number}
          </div>

          <!-- Content -->
          <div class="relative z-10 w-full px-8 lg:px-20 py-16 flex flex-col justify-center h-full max-w-[1600px] mx-auto" data-srv-content>
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
              
              <!-- Left Content -->
              <div class="space-y-8">
                <!-- Service Number -->
                <div class="flex items-center gap-4">
                  <span class="font-display font-black text-6xl lg:text-8xl text-[#CFA35A]/20">{service.number}</span>
                  <div class="h-[1px] w-12 bg-[#CFA35A]/40"></div>
                </div>

                <!-- Title Block -->
                <div>
                  <span class="font-mono text-[0.65rem] uppercase tracking-[0.3em] text-[#CFA35A] block mb-3">
                    {service.subtitle}
                  </span>
                  <h3 class="font-display font-black text-[clamp(3rem,8vw,6rem)] uppercase leading-[0.8] tracking-tighter">
                    {service.title}
                  </h3>
                </div>

                <!-- Description -->
                <p class="font-body text-lg text-white/70 max-w-md leading-relaxed">
                  {service.description}
                </p>

                <!-- CTA Row -->
                <div class="flex items-center gap-8 pt-4">
                  <a href={service.link} class="group inline-flex items-center gap-4">
                    <span class="font-display font-bold text-sm uppercase tracking-[0.15em] text-white group-hover:text-[#CFA35A] transition-colors">
                      Ver más
                    </span>
                    <div class="w-12 h-12 rounded-full border border-white/30 flex items-center justify-center group-hover:bg-[#CFA35A] group-hover:border-[#CFA35A] transition-all duration-300">
                      <svg class="w-4 h-4 -rotate-45 group-hover:rotate-0 text-white transition-all duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M5 12h14M12 5l7 7-7 7"/>
                      </svg>
                    </div>
                  </a>

                  <!-- Stat -->
                  <div class="flex flex-col">
                    <span class="font-display font-black text-2xl text-[#CFA35A]">{service.stat.value}</span>
                    <span class="font-mono text-[0.55rem] uppercase tracking-[0.15em] text-white/40">{service.stat.label}</span>
                  </div>
                </div>
              </div>

              <!-- Right Visual -->
              <div class="hidden lg:flex justify-end items-center">
                <div class="relative w-80 h-80 xl:w-96 xl:h-96">
                  <div class="absolute inset-0 rounded-full border border-white/10 animate-spin-slow" style="animation-duration: 30s;"></div>
                  <div class="absolute inset-8 rounded-full border border-[#CFA35A]/20"></div>
                  <div class="absolute inset-16 rounded-full border border-white/5"></div>
                  <div class="absolute inset-0 flex items-center justify-center">
                    <span class="font-display font-black text-7xl xl:text-8xl text-white/10">{service.number}</span>
                  </div>
                  <div class="absolute inset-0 animate-orbit" style="animation-duration: 15s;">
                    <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 w-4 h-4 bg-[#CFA35A] rounded-full shadow-[0_0_20px_rgba(207,163,90,0.5)]"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom Progress -->
    <div class="absolute bottom-8 left-8 right-8 lg:left-20 lg:right-20 h-[2px] bg-white/10 z-40 rounded-full">
      <div class="h-full bg-[#CFA35A] w-0 rounded-full shadow-[0_0_10px_rgba(207,163,90,0.5)]" id="services-progress"></div>
    </div>
  </div>
</section>

<style>
  @keyframes spin-slow {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  
  .animate-spin-slow {
    animation: spin-slow linear infinite;
  }

  @keyframes orbit {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  
  .animate-orbit {
    animation: orbit linear infinite;
  }

  .service-dot.active {
    background-color: #CFA35A;
    box-shadow: 0 0 10px rgba(207, 163, 90, 0.5);
    transform: scale(1.5);
  }

  @media (min-width: 1024px) {
    .service-panel { cursor: default; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener('astro:page-load', () => {
    if (window.innerWidth > 1024) {
      const track = document.getElementById('services-track');
      const wrapper = document.getElementById('services-wrapper');
      const dots = document.querySelectorAll('.service-dot');
      
      if (!track || !wrapper) return;

      const tl = gsap.timeline({
        scrollTrigger: { 
          trigger: wrapper, 
          start: 'top top', 
          end: '+=400%', 
          pin: '#services-pinned', 
          scrub: 1.5,
          onUpdate: (self) => {
            const progress = self.progress;
            const activeIndex = Math.min(Math.floor(progress * 4), 3);
            dots.forEach((dot, i) => {
              dot.classList.toggle('active', i === activeIndex);
            });
          }
        },
      });
      
      tl.to(track, { 
        x: () => -(track.scrollWidth - window.innerWidth) + 'px', 
        ease: 'none' 
      });

      gsap.to('#services-progress', {
        width: '100%', 
        ease: 'none',
        scrollTrigger: { 
          trigger: wrapper, 
          start: 'top top', 
          end: '+=400%', 
          scrub: 1.5 
        },
      });

      const panels = gsap.utils.toArray('.service-panel');
      panels.forEach((panel) => {
        const bg = panel.querySelector('[data-srv-bg]');
        if (bg) {
          gsap.fromTo(bg, 
            { xPercent: -5 }, 
            { xPercent: 5, ease: 'none', scrollTrigger: { trigger: wrapper, start: 'top top', end: '+=400%', scrub: 2 } }
          );
        }
      });

    } else {
      const track = document.getElementById('services-track');
      if (track) { 
        track.classList.remove('w-[400vw]', 'flex-nowrap'); 
        track.classList.add('w-full', 'flex-col'); 
      }
      gsap.utils.toArray('.service-panel').forEach((panel) => { 
        panel.classList.remove('h-screen'); 
        panel.classList.add('min-h-screen'); 
      });
    }
  });

  document.addEventListener('astro:before-swap', () => {
    ScrollTrigger.getAll().filter(st => (st.vars as any).trigger === '#services-wrapper').forEach(st => st.kill());
  });
</script>
