---
/**
 * StorySection — Ultra-Premium Editorial
 * Self-contained: animations inlined, no external .ts dependencies
 */
---

<section
  class="relative bg-[#FAFAFA] text-[#0A0A0A] border-b border-[#0A0A0A]/10 py-32 lg:py-56 overflow-hidden"
  id="story-section"
  data-theme="light"
>
  <!-- Noise Texture -->
  <div
    class="absolute inset-0 opacity-[0.04] mix-blend-multiply pointer-events-none z-[1]"
    style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%270 0 200 200%27 xmlns=%27http://www.w3.org/2000/svg%27%3E%3Cfilter id=%27n%27%3E%3CfeTurbulence type=%27fractalNoise%27 baseFrequency=%270.8%27 numOctaves=%273%27 stitchTiles=%27stitch%27/%3E%3C/filter%3E%3Crect width=%27100%25%27 height=%27100%25%27 filter=%27url(%23n)%27/%3E%3C/svg%3E')"
  >
  </div>

  <!-- Background Decor Letters -->
  <div
    class="absolute top-0 right-0 pointer-events-none overflow-hidden select-none opacity-[0.03] w-full h-full flex justify-end items-center z-0"
  >
    <span
      class="font-display font-black text-[25vw] leading-none tracking-tighter text-[#0A0A0A] translate-x-[25%]"
    >
      CM.
    </span>
  </div>

  <div
    class="container mx-auto px-6 lg:px-12 xl:px-20 relative z-10 max-w-[1400px]"
  >
    <div class="flex flex-col lg:flex-row items-stretch gap-12 lg:gap-20">
      <!-- Left Text Content -->
      <div class="w-full lg:w-1/2 flex flex-col justify-center relative">
        <div class="flex items-center gap-4 mb-8">
          <div class="w-12 h-[1px] bg-[#CFA35A]"></div>
          <span
            class="font-mono text-[0.65rem] uppercase tracking-[0.3em] font-bold text-[#CFA35A]"
            >Quiénes Somos</span
          >
        </div>

        <h2
          class="font-display font-black text-display-section lg:text-display-hero uppercase tracking-tighter leading-[0.85] mb-8 text-[#0A0A0A] whitespace-nowrap flex flex-col"
        >
          <span class="block mb-2">EL ARTE DE LA</span>
          <span
            class="block text-transparent"
            style="-webkit-text-stroke: 2px #0A0A0A;">NAVEGACIÓN.</span
          >
        </h2>

        <div class="flex flex-col gap-5 relative z-10">
          <p class="font-body text-[#0A0A0A]/80 text-lg leading-relaxed">
            Fundada en 2010 en Conil de la Frontera, Cien Mares nació de una
            dedicación absoluta al océano. No somos una agencia tradicional;
            somos una firma de servicios náuticos que entiende el mar como el
            entorno definitivo para la libertad y la privacidad.
          </p>
          <p
            class="font-body text-[#0A0A0A]/60 text-base leading-relaxed pl-5 border-l-2 border-[#CFA35A]/30"
          >
            Cada yate que gestionamos, cada curso que impartimos y cada travesía
            que diseñamos se ejecuta con precisión milimétrica. Transformamos la
            complejidad naval en una experiencia de lujo fluido y sin
            fricciones.
          </p>
        </div>

        <!-- Stats -->
        <div
          class="flex flex-wrap items-center gap-12 lg:gap-24 mt-16 pt-10 border-t border-[#0A0A0A]/10 relative"
        >
          <!-- Editorial Decor Line -->
          <div class="absolute -top-3 left-0 w-2 h-2 bg-[#0A0A0A]"></div>

          <div class="flex flex-col">
            <span
              class="font-display text-[clamp(3.5rem,5vw,5rem)] leading-none font-black tracking-tighter text-[#0A0A0A]"
            >
              15<span
                class="text-[#CFA35A] font-light text-[clamp(2rem,3vw,3rem)] align-top"
                >+</span
              >
            </span>
            <span
              class="font-mono text-[0.6rem] uppercase tracking-[0.4em] text-[#0A0A0A]/50 font-bold mt-1 block"
              >Años en el mar</span
            >
          </div>
          <div class="hidden lg:block w-[1px] h-16 bg-[#0A0A0A]/10"></div>
          <div class="flex flex-col">
            <span
              class="font-display text-[clamp(3.5rem,5vw,5rem)] leading-none font-black tracking-tighter text-[#0A0A0A]"
            >
              2<span
                class="text-[#CFA35A] font-light text-[clamp(2rem,3vw,3rem)] align-top"
                >K</span
              ><span
                class="text-[#0A0A0A]/30 text-[clamp(2rem,3vw,3rem)] align-top"
                >+</span
              >
            </span>
            <span
              class="font-mono text-[0.6rem] uppercase tracking-[0.4em] text-[#0A0A0A]/50 font-bold mt-1 block"
              >Travesías Premium</span
            >
          </div>
        </div>
      </div>

      <!-- Right Imagery Grid -->
      <div
        class="w-full lg:w-1/2 relative min-h-[450px] lg:min-h-0 mt-8 lg:mt-0"
      >
        <!-- Floating Gold Badge -->
        <div
          class="absolute -top-4 -right-4 lg:top-[-5%] lg:right-[-5%] z-30 animate-float-subtle"
        >
          <div
            class="w-24 h-24 lg:w-28 lg:h-28 rounded-full bg-[#0A0A0A] text-[#CFA35A] flex items-center justify-center shadow-[0_20px_40px_rgba(0,0,0,0.15)]"
            style="animation: spin-slow 30s linear infinite;"
          >
            <svg viewBox="0 0 100 100" class="w-full h-full p-2">
              <path id="curve" d="M 50 15 A 35 35 0 1 1 49.9 15" fill="none"
              ></path>
              <text
                class="text-[10px] lg:text-[12px] font-mono uppercase tracking-[0.15em] font-bold fill-current"
              >
                <textPath href="#curve">Cien Mares • Est. 2010 •</textPath>
              </text>
            </svg>
            <div
              class="absolute inset-0 flex items-center justify-center pointer-events-none"
            >
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                class="w-5 h-5 lg:w-6 lg:h-6 -rotate-45"
              >
                <path d="M5 12h14M12 5l7 7-7 7"></path>
              </svg>
            </div>
          </div>
        </div>

        <!-- Main Large Image -->
        <div
          class="w-[92%] lg:w-[88%] aspect-[3/4] ml-auto rounded-[1.5rem] overflow-hidden shadow-[0_30px_60px_rgba(0,0,0,0.12)] relative z-10 story-image bg-[#E5E5E5]"
        >
          <img
            src="https://images.unsplash.com/photo-1569263979104-865ab7cd8d13?w=1200&q=85&auto=format&fit=crop"
            alt="Cubierta de yate CEO"
            class="w-full h-full object-cover grayscale-[5%] scale-[1.05] story-parallax"
            loading="lazy"
          />
          <div
            class="absolute inset-0 bg-gradient-to-tr from-black/10 via-transparent to-white/5 pointer-events-none"
          >
          </div>
        </div>

        <!-- Overlapping Small Image -->
        <div
          class="absolute bottom-[-8%] left-[-3%] w-[50%] lg:w-[45%] aspect-[3/4] rounded-2xl overflow-hidden shadow-[0_25px_50px_rgba(0,0,0,0.25)] z-20 border-4 border-[#FAFAFA] story-image bg-[#E5E5E5]"
        >
          <img
            src="https://images.unsplash.com/photo-1544551763-46a013bb70d5?w=800&q=80&auto=format&fit=crop"
            alt="Detalle de yate luminoso"
            class="w-full h-full object-cover scale-[1.1] story-parallax"
            loading="lazy"
            style="transform-origin: bottom center;"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes spin-slow {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("astro:page-load", () => {
    gsap.fromTo(
      ".story-image",
      { y: 80, opacity: 0 },
      {
        y: 0,
        opacity: 1,
        duration: 1.8,
        stagger: 0.3,
        ease: "sine.out",
        scrollTrigger: { trigger: "#story-section", start: "top 75%" },
      },
    );

    gsap.utils.toArray<HTMLElement>(".story-parallax").forEach((img) => {
      gsap.to(img, {
        yPercent: 12,
        ease: "none",
        scrollTrigger: {
          trigger: "#story-section",
          start: "top bottom",
          end: "bottom top",
          scrub: true,
        },
      });
    });
  });

  document.addEventListener("astro:before-swap", () => {
    ScrollTrigger.getAll()
      .filter((st) => (st.vars as any).trigger === "#story-section")
      .forEach((st) => st.kill());
  });
</script>
