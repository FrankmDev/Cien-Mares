---
/**
 * Methodology V19 — "Modern Clear Grid"
 *
 * - Light theme, highly modern and airy.
 * - 3-column dynamic layout on desktop with staggered vertical alignment.
 * - Extremely clear, readable, and premium without being "dark/heavy".
 */
---

<section
  class="relative bg-[#FAFAFA] text-[#0A0A0A] py-32 lg:py-56 overflow-hidden border-t border-[#0A0A0A]/5"
  id="methodology-v19"
  data-theme="light"
>
  <div
    class="container mx-auto px-6 lg:px-12 relative z-10 w-full max-w-[1400px]"
  >
    <!-- Header: Clear and Modern -->
    <div
      class="flex flex-col lg:flex-row justify-between items-start lg:items-end mb-20 lg:mb-32 gap-8"
    >
      <div class="max-w-3xl">
        <div class="flex items-center gap-4 mb-6">
          <div class="w-12 h-[1px] bg-[#0A0A0A]"></div>
          <span
            class="font-mono text-[0.65rem] uppercase tracking-[0.4em] font-bold text-[#0A0A0A]"
            >Metodología</span
          >
        </div>
        <h2
          class="font-display font-black text-display-section uppercase tracking-tighter leading-[0.85] text-[#0A0A0A]"
        >
          <span class="block mb-2">NAVEGACIÓN</span>
          <span
            class="block text-transparent"
            style="-webkit-text-stroke: 2px #0A0A0A;">SIN FRICCIONES.</span
          >
        </h2>
      </div>
      <p
        class="font-body text-body-premium text-[#0A0A0A]/60 max-w-sm lg:text-right"
      >
        Un proceso estructurado para garantizar absoluta excelencia desde la
        planificación hasta el amarre final.
      </p>
    </div>

    <!-- 3-Column Staggered Editorial Grid -->
    <div class="flex flex-col gap-24 lg:gap-32 relative z-10 w-full">
      <!-- Phase 1 -->
      <article
        class="flex flex-col lg:flex-row items-center gap-12 lg:gap-20 meth-card opacity-0 translate-y-12"
      >
        <div class="w-full lg:w-1/2 relative">
          <!-- Massive Background Number -->
          <div
            class="absolute -top-12 -left-8 font-display font-black text-[12rem] leading-none text-[#0A0A0A]/5 select-none z-0 pointer-events-none"
          >
            01
          </div>
          <div
            class="w-full aspect-[4/3] lg:aspect-[4/5] rounded-[2rem] overflow-hidden relative bg-[#EAEAEA] animate-float-subtle shadow-[0_30px_60px_rgba(0,0,0,0.08)] z-10"
          >
            <img
              src="https://images.unsplash.com/photo-1569263979104-865ab7cd8d13?auto=format&fit=crop&q=85&w=1200"
              alt="Auditoría"
              class="w-full h-full object-cover scale-[1.02] hover:scale-110 transition-transform duration-[1.5s] ease-[cubic-bezier(0.19,1,0.22,1)]"
              loading="lazy"
            />
          </div>
        </div>
        <div class="w-full lg:w-1/2 lg:pl-12">
          <h3
            class="font-display font-black text-display-section leading-none text-[#0A0A0A] uppercase mb-6 tracking-tighter"
          >
            Consultoría<br /><span
              class="text-transparent"
              style="-webkit-text-stroke: 1.5px #0A0A0A;">Exacta</span>
          </h3>
          <p
            class="font-body text-lg text-[#0A0A0A]/70 max-w-md leading-relaxed"
          >
            Analizamos la eslora requerida, preferencias gastronómicas y
            protocolos de privacidad. Diseñamos la travesía basándonos en tus
            exigencias absolutas, sin dejar margen a la improvisación.
          </p>
        </div>
      </article>

      <!-- Phase 2 (Reversed) -->
      <article
        class="flex flex-col lg:flex-row-reverse items-center gap-12 lg:gap-20 meth-card opacity-0 translate-y-12"
      >
        <div class="w-full lg:w-1/2 relative flex justify-end">
          <div
            class="absolute -top-12 -right-8 font-display font-black text-[12rem] leading-none text-[#0A0A0A]/5 select-none z-0 pointer-events-none"
          >
            02
          </div>
          <div
            class="w-[90%] lg:w-[85%] aspect-[4/3] lg:aspect-[3/4] rounded-[2rem] overflow-hidden relative bg-[#EAEAEA] animate-float-subtle shadow-[0_30px_60px_rgba(0,0,0,0.08)] z-10"
            style="animation-delay: -2s;"
          >
            <img
              src="https://images.unsplash.com/photo-1605281317010-fe5ffe798166?auto=format&fit=crop&q=85&w=1200"
              alt="Logística"
              class="w-full h-full object-cover scale-[1.02] hover:scale-110 transition-transform duration-[1.5s] ease-[cubic-bezier(0.19,1,0.22,1)]"
              loading="lazy"
            />
          </div>
        </div>
        <div
          class="w-full lg:w-1/2 lg:pr-12 lg:text-right flex flex-col items-start lg:items-end"
        >
          <h3
            class="font-display font-black text-display-section leading-none text-[#0A0A0A] uppercase mb-6 tracking-tighter"
          >
            Logística<br /><span
              class="text-transparent"
              style="-webkit-text-stroke: 1.5px #0A0A0A;">Invisible</span>
          </h3>
          <p
            class="font-body text-lg text-[#0A0A0A]/70 max-w-md leading-relaxed"
          >
            Permisos rápidos, repostaje coordinado y abastecimiento premium. El
            barco te espera en el amarre impecable, como si siempre hubiera sido
            tuyo.
          </p>
        </div>
      </article>

      <!-- Phase 3 -->
      <article
        class="flex flex-col lg:flex-row items-center gap-12 lg:gap-20 meth-card opacity-0 translate-y-12"
      >
        <div class="w-full lg:w-1/2 relative">
          <div
            class="absolute -top-12 -left-8 font-display font-black text-[12rem] leading-none text-[#CFA35A]/10 select-none z-0 pointer-events-none"
          >
            03
          </div>
          <div
            class="w-full aspect-[4/3] lg:aspect-[4/5] rounded-[2rem] overflow-hidden relative bg-[#EAEAEA] animate-float-subtle shadow-[0_40px_80px_rgba(207,163,90,0.15)] z-10"
            style="animation-delay: -4s;"
          >
            <img
              src="https://images.unsplash.com/photo-1566847464366-50e50937a72d?auto=format&fit=crop&q=85&w=1200"
              alt="Excelencia"
              class="w-full h-full object-cover scale-[1.02] hover:scale-110 transition-transform duration-[1.5s] ease-[cubic-bezier(0.19,1,0.22,1)]"
              loading="lazy"
            />
          </div>
        </div>
        <div class="w-full lg:w-1/2 lg:pl-12">
          <h3
            class="font-display font-black text-display-section leading-none text-[#0A0A0A] uppercase mb-6 tracking-tighter"
          >
            Dominio en<br /><span
              class="text-transparent"
              style="-webkit-text-stroke: 1.5px #CFA35A;">Altamar</span>
          </h3>
          <p
            class="font-body text-lg text-[#0A0A0A]/70 max-w-md leading-relaxed"
          >
            Disfruta de la máxima tranquilidad y del rigor discreto de una
            tripulación excepcional. Navegación en estado puro, de principio a
            fin, bajo tus propias reglas.
          </p>
        </div>
      </article>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("astro:page-load", () => {
    const cards = gsap.utils.toArray(".meth-card");
    if (cards.length > 0) {
      gsap.to(cards, {
        y: 0,
        opacity: 1,
        duration: 1.6,
        stagger: 0.3,
        ease: "sine.out",
        scrollTrigger: {
          trigger: "#methodology-v19",
          start: "top 70%",
        },
      });
    }
  });

  document.addEventListener("astro:before-swap", () => {
    ScrollTrigger.getAll()
      .filter((st) => (st.vars as any).trigger === "#methodology-v19")
      .forEach((st) => st.kill());
  });
</script>
