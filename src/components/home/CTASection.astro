---
/**
 * CTASection — Ultimate Cinematic Finale
 * Immersive parallax with dramatic reveal
 */
---

<section
  class="relative bg-[#02060a] text-white py-0 overflow-hidden"
  id="cta-section"
  data-theme="dark"
>
  <div class="relative min-h-screen flex items-center">
    <!-- Animated Background Layers -->
    <div class="absolute inset-0 z-0">
      <!-- Primary Image -->
      <img
        src="https://images.unsplash.com/photo-1505142468610-359e7d316be0?w=2800&q=90"
        alt="Océano al atardecer"
        class="w-full h-full object-cover cta-bg"
        style="filter: brightness(0.25) saturate(1.3); transform: scale(1.2);"
      />
      
      <!-- Gradient Overlays -->
      <div class="absolute inset-0 bg-gradient-to-t from-[#02060a] via-[#02060a]/60 to-transparent"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-[#02060a]/80 via-transparent to-[#02060a]/80"></div>
      
      <!-- Animated Light Glow -->
      <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[90%] h-[70%] bg-[#CFA35A]/15 blur-[180px] rounded-full animate-pulse-slow"></div>
      
      <!-- Noise Texture -->
      <div class="absolute inset-0 opacity-[0.03] mix-blend-overlay" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%270 0 256 256%27 xmlns=%27http://www.w3.org/2000/svg%27%3E%3Cfilter id=%27noise%27%3E%3CfeTurbulence type=%27fractalNoise%27 baseFrequency=%270.8%27 numOctaves=%274%27/%3E%3C/filter%3E%3Crect width=%27100%25%27 height=%27100%25%27 filter=%27url(%23noise)%27/%3E%3C/svg%3E');"></div>
    </div>

    <!-- Floating Particles -->
    <div class="absolute inset-0 z-[5] pointer-events-none overflow-hidden" id="cta-particles">
      <!-- JS Generated -->
    </div>

    <!-- Content -->
    <div class="container mx-auto px-6 lg:px-12 relative z-10 py-32">
      <div class="max-w-5xl mx-auto text-center">
        
        <!-- Section Label -->
        <div class="inline-flex items-center gap-3 px-5 py-2.5 rounded-full bg-white/5 backdrop-blur-xl border border-white/10 mb-12 cta-label opacity-0">
          <span class="font-display font-black text-lg text-[#CFA35A]">05</span>
          <div class="w-[1px] h-4 bg-white/20"></div>
          <span class="font-mono text-[0.65rem] uppercase tracking-[0.3em] text-white/60 font-bold">Contacto</span>
        </div>

        <!-- Main Title with 3D Effect -->
        <h2 class="font-display font-black text-[clamp(3.5rem,12vw,9rem)] leading-[0.85] tracking-tight mb-10 cta-title opacity-0">
          <span class="block text-white">Tu aventura</span>
          <span class="block text-transparent bg-clip-text bg-gradient-to-r from-[#CFA35A] via-[#e8cb8e] to-[#CFA35A] animate-shimmer">comienza hoy</span>
        </h2>

        <!-- Animated Divider -->
        <div class="flex items-center justify-center gap-6 mb-12 cta-divider opacity-0">
          <div class="w-20 h-[1px] bg-gradient-to-r from-transparent to-[#CFA35A]/50"></div>
          <div class="w-3 h-3 rounded-full bg-[#CFA35A] shadow-[0_0_20px_rgba(207,163,90,0.8)] animate-pulse"></div>
          <div class="w-20 h-[1px] bg-gradient-to-l from-transparent to-[#CFA35A]/50"></div>
        </div>

        <!-- Subtitle -->
        <p class="font-body text-xl lg:text-2xl text-white/70 max-w-2xl mx-auto mb-14 cta-subtitle opacity-0 leading-relaxed">
          No dejes que otra temporada pase sin experimentar la libertad absoluta del mar. Estamos listos para diseñar tu próxima experiencia.
        </p>

        <!-- Action Buttons -->
        <div class="flex flex-col sm:flex-row gap-5 justify-center items-center cta-buttons opacity-0">
          <a 
            href="mailto:info@cienmares.es" 
            class="group relative px-10 py-5 bg-[#CFA35A] text-[#02060a] rounded-full font-display font-bold text-sm uppercase tracking-[0.15em] overflow-hidden transition-all duration-500 hover:shadow-[0_0_80px_rgba(207,163,90,0.6)] hover:scale-105"
          >
            <span class="relative z-10 flex items-center gap-3">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
              Enviar Email
            </span>
            <div class="absolute inset-0 bg-white translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-out"></div>
          </a>
          
          <a 
            href="tel:+34605183785" 
            class="group px-10 py-5 border border-white/30 text-white rounded-full font-display font-bold text-sm uppercase tracking-[0.15em] hover:bg-white/10 hover:border-[#CFA35A]/50 hover:shadow-[0_0_40px_rgba(207,163,90,0.2)] transition-all duration-500 backdrop-blur-sm flex items-center gap-3"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
            </svg>
            Llamar Ahora
          </a>
        </div>

        <!-- Trust Indicators -->
        <div class="mt-16 flex flex-wrap justify-center items-center gap-8 cta-trust opacity-0">
          {[
            { icon: 'shield', label: '100% Seguro' },
            { icon: 'clock', label: 'Respuesta 24h' },
            { icon: 'star', label: 'Calidad Garantizada' },
          ].map((item) => (
            <div class="flex items-center gap-3 group">
              <div class="w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center group-hover:bg-[#CFA35A]/10 group-hover:border-[#CFA35A]/30 transition-all duration-300">
                {item.icon === 'shield' && (
                  <svg class="w-5 h-5 text-[#CFA35A]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                  </svg>
                )}
                {item.icon === 'clock' && (
                  <svg class="w-5 h-5 text-[#CFA35A]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <path d="M12 6v6l4 2"/>
                  </svg>
                )}
                {item.icon === 'star' && (
                  <svg class="w-5 h-5 text-[#CFA35A]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                )}
              </div>
              <span class="font-mono text-[0.65rem] uppercase tracking-[0.15em] text-white/50">{item.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Decorative Elements -->
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-4 cta-bottom opacity-0">
      <div class="w-[1px] h-20 bg-gradient-to-b from-white/20 to-transparent"></div>
      <span class="font-mono text-[0.55rem] uppercase tracking-[0.3em] text-white/30">Cien Mares · Est. 2010</span>
    </div>
  </div>
</section>

<style>
  @keyframes pulse-slow {
    0%, 100% { opacity: 0.15; transform: scale(1); }
    50% { opacity: 0.25; transform: scale(1.05); }
  }
  
  .animate-pulse-slow {
    animation: pulse-slow 6s ease-in-out infinite;
  }

  @keyframes shimmer {
    0% { background-position: -200% center; }
    100% { background-position: 200% center; }
  }
  
  .animate-shimmer {
    background-size: 200% auto;
    animation: shimmer 4s linear infinite;
  }

  .cta-particle {
    position: absolute;
    background: rgba(207, 163, 90, 0.4);
    border-radius: 50%;
    pointer-events: none;
    animation: float-cta linear infinite;
  }
  
  @keyframes float-cta {
    0% {
      transform: translateY(100vh) translateX(0) scale(0);
      opacity: 0;
    }
    10% { opacity: 1; }
    90% { opacity: 0.5; }
    100% {
      transform: translateY(-20vh) translateX(20px) scale(1);
      opacity: 0;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  // Generate particles
  const particleContainer = document.getElementById('cta-particles');
  if (particleContainer) {
    for (let i = 0; i < 20; i++) {
      const particle = document.createElement('div');
      particle.className = 'cta-particle';
      particle.style.left = Math.random() * 100 + '%';
      particle.style.width = Math.random() * 3 + 1 + 'px';
      particle.style.height = particle.style.width;
      particle.style.animationDuration = Math.random() * 12 + 8 + 's';
      particle.style.animationDelay = Math.random() * 8 + 's';
      particleContainer.appendChild(particle);
    }
  }

  document.addEventListener("astro:page-load", () => {
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: "#cta-section",
        start: "top 65%",
      },
    });

    tl.to(".cta-label", { opacity: 1, y: 0, duration: 0.8, ease: "power3.out" })
      .to(".cta-title", { opacity: 1, y: 0, duration: 1.4, ease: "power4.out" }, "-=0.4")
      .to(".cta-divider", { opacity: 1, scaleX: 1, duration: 0.8, ease: "power2.out" }, "-=0.8")
      .to(".cta-subtitle", { opacity: 1, y: 0, duration: 1, ease: "power3.out" }, "-=0.6")
      .to(".cta-buttons", { opacity: 1, y: 0, duration: 0.8, ease: "power3.out" }, "-=0.4")
      .to(".cta-trust", { opacity: 1, y: 0, duration: 0.8, ease: "power3.out" }, "-=0.4")
      .to(".cta-bottom", { opacity: 1, duration: 1, ease: "power3.out" }, "-=0.2");

    // Parallax background - fixed to prevent gap
    gsap.fromTo(".cta-bg", 
      { yPercent: -10 },
      {
        yPercent: 10,
        ease: "none",
        scrollTrigger: {
          trigger: "#cta-section",
          start: "top bottom",
          end: "bottom top",
          scrub: 1,
        },
      }
    );
  });

  document.addEventListener("astro:before-swap", () => {
    ScrollTrigger.getAll()
      .filter((st) => (st.vars as any).trigger === "#cta-section")
      .forEach((st) => st.kill());
  });
</script>
