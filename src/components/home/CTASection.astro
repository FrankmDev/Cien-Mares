---
/**
 * CTASection — Ultimate Cinematic Finale
 * Simplified with consistent data-reveal animations
 */
---

<section
  class="relative bg-[#02060a] text-white py-24 lg:py-32 overflow-hidden"
  id="cta-section"
  data-theme="dark"
  data-reveal="fade"
>
  <!-- Background Image -->
  <div class="absolute inset-0 z-0">
    <img
      src="https://images.unsplash.com/photo-1505142468610-359e7d316be0?w=1920&q=85"
      alt="Océano al atardecer"
      class="w-full h-full object-cover"
      style="filter: brightness(0.3);"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-[#02060a] via-[#02060a]/70 to-transparent"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-[#02060a]/60 via-transparent to-[#02060a]/60"></div>
  </div>

  <!-- Content -->
  <div class="container mx-auto px-6 lg:px-12 relative z-10">
    <div class="max-w-4xl mx-auto text-center">
      
      <!-- Section Label -->
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 backdrop-blur-sm border border-white/10 mb-8" data-reveal data-delay="1">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#CFA35A] opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-[#CFA35A]"></span>
        </span>
        <span class="font-mono text-[0.6rem] uppercase tracking-[0.25em] text-white/70 font-bold">Contacto</span>
      </div>

      <!-- Main Title -->
      <h2 class="font-display font-black text-3xl md:text-4xl lg:text-5xl xl:text-6xl uppercase leading-[0.95] tracking-tighter text-white mb-6" data-reveal data-delay="2">
        Tu aventura
        <span class="block text-transparent bg-clip-text bg-gradient-to-r from-[#CFA35A] via-[#f5e6c8] to-[#CFA35A]">
          comienza hoy
        </span>
      </h2>

      <!-- Divider -->
      <div class="flex items-center justify-center gap-4 mb-8" data-reveal data-delay="3">
        <div class="w-16 h-[1px] bg-gradient-to-r from-transparent to-[#CFA35A]/50"></div>
        <div class="w-2 h-2 rounded-full bg-[#CFA35A]"></div>
        <div class="w-16 h-[1px] bg-gradient-to-l from-transparent to-[#CFA35A]/50"></div>
      </div>

      <!-- Subtitle -->
      <p class="font-body text-lg lg:text-xl text-white/70 max-w-2xl mx-auto mb-10 leading-relaxed" data-reveal data-delay="4">
        No dejes que otra temporada pase sin experimentar la libertad absoluta del mar. Estamos listos para diseñar tu próxima experiencia.
      </p>

      <!-- Action Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center mb-12" data-reveal data-delay="5">
        <a 
          href="mailto:info@cienmares.es" 
          class="group relative px-8 py-4 bg-[#CFA35A] text-[#02060a] rounded-full font-display font-bold text-sm uppercase tracking-[0.15em] overflow-hidden transition-all duration-300 hover:shadow-[0_0_40px_rgba(207,163,90,0.4)] hover:scale-105"
        >
          <span class="relative z-10 flex items-center gap-2">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
            Enviar Email
          </span>
          <div class="absolute inset-0 bg-white translate-y-full group-hover:translate-y-0 transition-transform duration-300"></div>
        </a>
        
        <a 
          href="tel:+34605183785" 
          class="group px-8 py-4 border border-white/30 text-white rounded-full font-display font-bold text-sm uppercase tracking-[0.15em] hover:bg-white/10 hover:border-[#CFA35A]/50 transition-all duration-300 backdrop-blur-sm flex items-center gap-2"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
          </svg>
          Llamar Ahora
        </a>
      </div>

      <!-- Trust Indicators -->
      <div class="flex flex-wrap justify-center items-center gap-6" data-reveal data-delay="6">
        {[
          { icon: 'shield', label: '100% Seguro' },
          { icon: 'clock', label: 'Respuesta 24h' },
          { icon: 'star', label: 'Calidad Garantizada' },
        ].map((item) => (
          <div class="flex items-center gap-2">
            <div class="w-10 h-10 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center">
              {item.icon === 'shield' && (
                <svg class="w-4 h-4 text-[#CFA35A]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
              )}
              {item.icon === 'clock' && (
                <svg class="w-4 h-4 text-[#CFA35A]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10"/>
                  <path d="M12 6v6l4 2"/>
                </svg>
              )}
              {item.icon === 'star' && (
                <svg class="w-4 h-4 text-[#CFA35A]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              )}
            </div>
            <span class="font-mono text-[0.6rem] uppercase tracking-[0.15em] text-white/50">{item.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>


