---
/**
 * CTA V20 — "Light Editorial Poster"
 *
 * - Matches the pure #FAFAFA light luxury aesthetic.
 * - Massive, highly legible typography.
 * - Refined, appropriately sized luxury buttons (no chunky pills).
 * - A centerpiece panoramic image to provide the "striking" element without muddying the text.
 */
---

<section
  class="relative bg-[#FAFAFA] text-[#0A0A0A] pt-32 lg:pt-56 pb-16 overflow-hidden border-t border-[#0A0A0A]/5"
  id="cta-v20"
  data-theme="light"
>
  <div
    class="container mx-auto px-6 lg:px-12 relative z-10 w-full max-w-[1400px]"
  >
    <!-- Poster Layout Container -->
    <div
      class="w-full relative rounded-[2.5rem] overflow-hidden shadow-[0_40px_100px_rgba(0,0,0,0.15)] flex flex-col items-center justify-center py-32 lg:py-48 px-6 text-center cta-poster-reveal"
    >
      <!-- Background Image -->
      <div class="absolute inset-0 w-full h-full z-0 overflow-hidden">
        <img
          src="https://images.unsplash.com/photo-1540946485063-a40da27545f8?w=2800&q=90"
          alt="Océano Cien Mares"
          class="w-full h-full object-cover scale-[1.1] cta-image-parallax"
        />
        <!-- Deep luxury gradients for contrast -->
        <div class="absolute inset-0 bg-black/40"></div>
        <div
          class="absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_0%,rgba(0,0,0,0.6)_100%)]"
        >
        </div>
        <div
          class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-black/30"
        >
        </div>
      </div>

      <!-- Centered Content -->
      <div class="relative z-10 flex flex-col items-center w-full max-w-4xl">
        <div class="flex items-center gap-4 mb-8 overflow-hidden">
          <div class="w-12 h-[1px] bg-white/50 origin-left cta-line"></div>
          <span
            class="font-mono text-[0.65rem] uppercase tracking-[0.4em] font-bold text-white translate-y-full opacity-0 cta-lbl"
            >El Siguiente Paso</span
          >
          <div class="w-12 h-[1px] bg-white/50 origin-right cta-line"></div>
        </div>

        <h2
          class="font-display font-black text-display-massive text-white tracking-tighter uppercase leading-[0.85] mb-8"
        >
          <span class="block overflow-hidden pb-2"
            ><span
              class="block translate-y-[120%] cta-title drop-shadow-[0_10px_20px_rgba(0,0,0,0.5)]"
              >EL OCÉANO</span
            ></span
          >
          <span class="block overflow-hidden pb-4"
            ><span
              class="block translate-y-[120%] cta-title text-transparent drop-shadow-none"
              style="-webkit-text-stroke: 2px rgba(255,255,255,0.95);"
              >ES TUYO.</span
            ></span
          >
        </h2>

        <p
          class="font-body text-lg text-white/80 max-w-xl opacity-0 translate-y-8 cta-fade mb-12"
        >
          La excelencia naval no admite compromisos. Agenda tu próxima
          experiencia chárter, sesión de formación o consultoría de gestión hoy
          mismo.
        </p>

        <!-- Refined Buttons -->
        <div
          class="flex flex-col sm:flex-row gap-6 opacity-0 translate-y-8 cta-fade"
        >
          <a
            href="mailto:info@cienmares.es"
            class="group relative px-10 py-5 bg-white text-[#0A0A0A] rounded-full overflow-hidden flex items-center justify-center gap-3 hover:shadow-[0_20px_40px_rgba(255,255,255,0.2)] transition-all duration-500"
          >
            <div
              class="absolute inset-0 bg-[#CFA35A] translate-y-[101%] group-hover:translate-y-0 transition-transform duration-500 ease-[cubic-bezier(0.19,1,0.22,1)]"
            >
            </div>
            <span
              class="relative z-10 font-display font-bold text-sm uppercase tracking-widest group-hover:text-black transition-colors duration-500"
            >
              Mandar Email
            </span>
          </a>

          <a
            href="tel:+34605183785"
            class="group relative px-10 py-5 bg-transparent border border-white/30 text-white rounded-full overflow-hidden flex items-center justify-center gap-3 hover:border-white hover:bg-white/5 transition-all duration-500 backdrop-blur-sm"
          >
            <span
              class="font-display font-bold text-sm uppercase tracking-widest"
            >
              Llamada Directa
            </span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("astro:page-load", () => {
    const ctaSection = document.getElementById("cta-v20");
    if (!ctaSection) return;

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: ctaSection,
        start: "top 75%",
      },
    });

    tl.fromTo(
      ".cta-poster-reveal",
      { y: 60, opacity: 0, scale: 0.98 },
      { y: 0, opacity: 1, scale: 1, duration: 1.5, ease: "sine.out" },
    )
      .fromTo(
        ".cta-line",
        { scaleX: 0 },
        { scaleX: 1, duration: 1.2, ease: "sine.inOut" },
        "-=0.5",
      )
      .to(
        ".cta-lbl",
        { y: 0, opacity: 1, duration: 1, ease: "sine.out" },
        "-=0.8",
      )
      .to(
        ".cta-title",
        { y: 0, duration: 1.4, stagger: 0.15, ease: "sine.out" },
        "-=0.8",
      )
      .to(
        ".cta-fade",
        { y: 0, opacity: 1, duration: 1.2, stagger: 0.1, ease: "sine.out" },
        "-=0.8",
      );

    // Image Parallax
    if (window.innerWidth > 1024) {
      gsap.to(".cta-image-parallax", {
        yPercent: 15,
        ease: "none",
        scrollTrigger: {
          trigger: ctaSection,
          start: "top bottom",
          end: "bottom top",
          scrub: true,
        },
      });
    }
  });

  document.addEventListener("astro:before-swap", () => {
    ScrollTrigger.getAll()
      .filter(
        (st) =>
          (st.vars as any).trigger === "#cta-v20" ||
          (st.vars as any).trigger === ".cta-image-reveal",
      )
      .forEach((st) => st.kill());
  });
</script>
