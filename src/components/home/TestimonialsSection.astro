---
/**
 * Testimonials V16 — Light Mode Editorial
 *
 * - Perfectly aligned con la estética light luxury de Methodology V14.
 * - Reemplazamos las cards de cristal oscuro por un grid editorial limpio y bordeado.
 * - Jerarquía tipográfica sólida, fondos claros, detalles dorados al hacer hover.
 */

const testimonials = [
  {
    quote: "La privacidad absoluta y la ejecución perfecta de nuestra travesía en las Baleares superó todas nuestras expectativas. El verdadero lujo es no tener que pensar en nada.",
    author: "Alberto de la C.",
    role: "Chárter Privado, Ibiza",
    stars: 5,
  },
  {
    quote: "Confiamos la gestión integral de nuestro yate a Cien Mares hace tres años. Su nivel de meticulosidad con el mantenimiento y la documentación naval es incomparable en la costa sur.",
    author: "Familia M. Valdés",
    role: "Gestión Integral, Sotogrande",
    stars: 5,
  },
  {
    quote: "La Academia Náutica no es solo para obtener una licencia; te enseñan a leer el mar. Una experiencia formativa de élite con capitanes que tienen décadas de experiencia real.",
    author: "Elena R.",
    role: "Academia Náutica, Cádiz",
    stars: 5,
  }
];
---

<section 
  class="relative bg-[#FAFAFA] text-[#0A0A0A] py-32 lg:py-56 border-t border-[#0A0A0A]/5 overflow-hidden" 
  id="testimonials-v16" 
  data-theme="light"
>
   <!-- Subtle Noise -->
   <div class="absolute inset-0 opacity-[0.05] mix-blend-multiply pointer-events-none z-[1] animate-sway" style={`background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");`}></div>

  <div class="container mx-auto px-6 lg:px-12 relative z-10 max-w-[1400px]">
      
      <!-- Header -->
      <div class="flex flex-col lg:flex-row justify-between items-start lg:items-end mb-16 lg:mb-24 gap-8">
         <div>
           <div class="flex items-center gap-4 mb-6">
              <div class="w-8 h-[1px] bg-[#0A0A0A]"></div>
              <span class="font-mono text-[0.65rem] uppercase tracking-[0.3em] font-bold text-[#0A0A0A]">Testimonios</span>
           </div>
           <h2 class="font-display font-black text-display-hero uppercase tracking-tighter leading-[0.85]">
              <span class="block mb-2">LA VOZ DE LA</span>
              <span class="block text-transparent" style="-webkit-text-stroke: 2px #0A0A0A;">EXCELENCIA.</span>
           </h2>
         </div>
         <p class="font-body text-[#555] text-sm lg:text-base max-w-sm leading-relaxed lg:text-right">
            Lo que dicen quienes han confiado sus travesías, sus embarcaciones y su formación náutica a nuestro equipo.
         </p>
      </div>

      <!-- Testimonials Editorial Grid -->
      <div class="grid grid-cols-1 lg:grid-cols-3 border-y border-[#0A0A0A]/5 divide-y lg:divide-y-0 lg:divide-x divide-[#0A0A0A]/5 relative z-10 w-full mt-8">
        
        {testimonials.map((test) => (
          <div class="testimonial-card group relative p-10 lg:p-16 flex flex-col justify-between hover:bg-[#F0F0F0]/50 transition-colors duration-500 overflow-hidden min-h-[400px]">
             
            <!-- Gold top accent line (Animated) -->
            <div class="absolute top-0 left-0 w-0 h-[2px] bg-[#CFA35A] group-hover:w-full transition-all duration-700 ease-out z-20"></div>

            <div class="flex-1">
              <!-- Stars -->
              <div class="flex gap-1.5 mb-8">
                {[...Array(test.stars)].map(() => (
                  <svg class="w-3.5 h-3.5 text-[#CFA35A]" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
              
              <p class="font-body text-[#333] text-body-premium relative z-10 mb-12 italic leading-relaxed">
                "{test.quote}"
              </p>
            </div>

            <div class="flex items-center gap-5 mt-auto pt-8 border-t border-[#0A0A0A]/5 group-hover:border-transparent transition-colors duration-500">
               <!-- Avatar placeholder circle -->
               <div class="w-12 h-12 rounded-full bg-[#EAEAEA] border border-[#0A0A0A]/10 flex items-center justify-center flex-shrink-0 group-hover:bg-[#CFA35A]/10 group-hover:border-[#CFA35A]/30 transition-colors duration-500">
                  <span class="font-display font-bold text-sm text-[#0A0A0A] group-hover:text-[#CFA35A] transition-colors duration-500">{test.author.charAt(0)}</span>
               </div>
               <div class="flex flex-col gap-1">
                  <span class="font-display font-bold text-base uppercase tracking-wider text-[#0A0A0A]">{test.author}</span>
                  <span class="font-mono text-[0.6rem] uppercase tracking-[0.2em] text-[#777]">{test.role}</span>
               </div>
            </div>
             
          </div>
        ))}

      </div>

  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("astro:page-load", () => {
    
    const section = document.getElementById("testimonials-v16");
    if (!section) return;

    const cards = gsap.utils.toArray(".testimonial-card");
    if(cards.length > 0) {
      gsap.fromTo(cards, 
        { opacity: 0, y: 30 },
        { 
          opacity: 1, 
          y: 0,
          duration: 1.5, 
          stagger: 0.2, 
          ease: "sine.out",
          scrollTrigger: {
            trigger: section,
            start: "top 75%",
          }
        }
      );
    }
     
  });
</script>
