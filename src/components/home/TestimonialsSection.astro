---
/**
 * TestimonialsSection — Modern Slider
 * Auto-playing carousel with glassmorphism cards
 */

const testimonials = [
  {
    quote: "La privacidad absoluta y la ejecución perfecta de nuestra travesía superó todas nuestras expectativas.",
    author: "Alberto de la C.",
    role: "Chárter Privado",
    location: "Ibiza",
    rating: 5
  },
  {
    quote: "Confiamos la gestión integral de nuestro yate a Cien Mares hace tres años. Su meticulosidad es incomparable.",
    author: "María Valdés",
    role: "Gestión Integral",
    location: "Sotogrande",
    rating: 5
  },
  {
    quote: "La Academia Náutica te enseña a leer el mar. Una experiencia formativa de élite con instructores excepcionales.",
    author: "Elena Rodríguez",
    role: "Academia Náutica",
    location: "Cádiz",
    rating: 5
  },
  {
    quote: "El servicio de traslados internacionales fue impecable. Profesionalidad y puntualidad en cada puerto.",
    author: "Carlos Méndez",
    role: "Traslados",
    location: "Málaga",
    rating: 5
  }
];

const stats = [
  { value: '4.9', suffix: '/5', label: 'Reviews' },
  { value: '500+', label: 'Clientes' },
  { value: '15+', label: 'Años' },
];
---

<section 
  class="relative bg-[#FAFAFA] text-[#0A0A0A] py-28 lg:py-36 overflow-hidden" 
  id="testimonials-section" 
  data-theme="light"
>
  <!-- Background -->
  <div class="absolute inset-0 z-0">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-[#CFA35A]/5 rounded-full blur-[120px]"></div>
  </div>

  <div class="container mx-auto px-6 lg:px-12 relative z-10 max-w-[1400px]">
    
    <!-- Header -->
    <div class="test-header flex flex-col lg:flex-row lg:items-end justify-between gap-10 mb-16">
      <div class="lg:w-1/2">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-[#0A0A0A] text-white rounded-full mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-[#CFA35A] animate-pulse"></span>
          <span class="font-mono text-[0.65rem] uppercase tracking-[0.2em] font-bold">Testimonios</span>
        </div>
        <h2 class="font-display font-black text-4xl md:text-5xl lg:text-6xl uppercase tracking-tight leading-[0.9]">
          Lo que dicen<br/><span class="text-[#CFA35A]">nuestros clientes</span>
        </h2>
      </div>
      
      <div class="flex gap-10 lg:pb-2">
        {stats.map((stat) => (
          <div class="text-center">
            <div class="flex items-baseline justify-center gap-1">
              <span class="font-display font-black text-3xl lg:text-4xl">{stat.value}</span>
              <span class="font-display text-lg text-[#CFA35A]">{stat.suffix}</span>
            </div>
            <span class="font-mono text-[0.6rem] uppercase tracking-[0.15em] text-[#0A0A0A]/40">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Slider Container -->
    <div class="test-slider relative">
      <!-- Slider Track -->
      <div class="slider-track flex gap-6 overflow-x-auto snap-x snap-mandatory scrollbar-hide pb-4" id="testimonial-slider">
        {testimonials.map((testimonial, i) => (
          <div class="test-card flex-shrink-0 w-[85vw] md:w-[45vw] lg:w-[35vw] snap-center">
            <div class="group relative p-8 lg:p-10 rounded-3xl bg-white border border-[#0A0A0A]/5 hover:border-[#CFA35A]/30 transition-all duration-500 h-full hover:shadow-2xl hover:shadow-[#CFA35A]/10">
              
              <!-- Quote Icon -->
              <div class="absolute top-6 right-6 w-12 h-12 rounded-full bg-[#CFA35A]/10 flex items-center justify-center group-hover:bg-[#CFA35A] transition-colors duration-300">
                <svg class="w-5 h-5 text-[#CFA35A] group-hover:text-white transition-colors" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
                </svg>
              </div>

              <!-- Stars -->
              <div class="flex gap-1 mb-6">
                {[...Array(testimonial.rating)].map(() => (
                  <svg class="w-4 h-4 text-[#CFA35A]" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                  </svg>
                ))}
              </div>

              <!-- Quote -->
              <blockquote class="font-body text-[#0A0A0A]/70 leading-relaxed mb-8 text-base lg:text-lg">
                "{testimonial.quote}"
              </blockquote>

              <!-- Author -->
              <div class="flex items-center gap-4 pt-6 border-t border-[#0A0A0A]/10">
                <div class="w-12 h-12 rounded-full bg-gradient-to-br from-[#CFA35A] to-[#8e6f38] flex items-center justify-center">
                  <span class="font-display font-bold text-sm text-white">
                    {testimonial.author.split(' ').map(n => n[0]).join('').substring(0, 2)}
                  </span>
                </div>
                <div>
                  <span class="font-display font-bold text-[#0A0A0A] block text-sm">{testimonial.author}</span>
                  <span class="font-mono text-[0.6rem] uppercase tracking-[0.15em] text-[#0A0A0A]/40">
                    {testimonial.role} · {testimonial.location}
                  </span>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Navigation Dots -->
      <div class="flex justify-center gap-3 mt-8">
        {testimonials.map((_, i) => (
          <button 
            class="slider-dot w-2 h-2 rounded-full bg-[#0A0A0A]/20 transition-all duration-300 hover:bg-[#CFA35A]"
            data-index={i}
            aria-label={`Ver testimonio ${i + 1}`}
          ></button>
        ))}
      </div>

      <!-- Navigation Arrows -->
      <button class="slider-prev absolute left-0 top-1/2 -translate-y-1/2 -translate-x-4 w-12 h-12 rounded-full bg-white shadow-lg flex items-center justify-center hover:bg-[#CFA35A] hover:text-white transition-all duration-300 hidden lg:flex">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
      </button>
      <button class="slider-next absolute right-0 top-1/2 -translate-y-1/2 translate-x-4 w-12 h-12 rounded-full bg-white shadow-lg flex items-center justify-center hover:bg-[#CFA35A] hover:text-white transition-all duration-300 hidden lg:flex">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </button>
    </div>
  </div>

  <style>
    .scrollbar-hide::-webkit-scrollbar {
      display: none;
    }
    .scrollbar-hide {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
    .slider-dot.active {
      background-color: #CFA35A;
      width: 24px;
    }
  </style>

  <script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener("astro:page-load", () => {
      // Header animation
      gsap.fromTo(".test-header", 
        { y: 50, opacity: 0 },
        { y: 0, opacity: 1, duration: 1, ease: "power3.out", scrollTrigger: { trigger: "#testimonials-section", start: "top 80%" }}
      );

      // Slider functionality
      const slider = document.getElementById('testimonial-slider');
      const cards = document.querySelectorAll('.test-card');
      const dots = document.querySelectorAll('.slider-dot');
      const prevBtn = document.querySelector('.slider-prev');
      const nextBtn = document.querySelector('.slider-next');
      
      let currentIndex = 0;
      
      function updateSlider(index: number) {
        if (!slider) return;
        const card = cards[index];
        if (card) {
          card.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
        }
        dots.forEach((dot, i) => {
          dot.classList.toggle('active', i === index);
        });
        currentIndex = index;
      }
      
      // Dot clicks
      dots.forEach((dot, i) => {
        dot.addEventListener('click', () => updateSlider(i));
      });
      
      // Arrow clicks
      prevBtn?.addEventListener('click', () => {
        const newIndex = currentIndex > 0 ? currentIndex - 1 : cards.length - 1;
        updateSlider(newIndex);
      });
      
      nextBtn?.addEventListener('click', () => {
        const newIndex = currentIndex < cards.length - 1 ? currentIndex + 1 : 0;
        updateSlider(newIndex);
      });
      
      // Auto-play
      setInterval(() => {
        const newIndex = currentIndex < cards.length - 1 ? currentIndex + 1 : 0;
        updateSlider(newIndex);
      }, 5000);
      
      // Set initial active
      updateSlider(0);
      
      // Scroll animation for cards
      gsap.fromTo(".test-card", 
        { y: 60, opacity: 0 },
        { y: 0, opacity: 1, duration: 0.8, stagger: 0.1, ease: "power3.out", scrollTrigger: { trigger: ".test-slider", start: "top 85%" }}
      );
    });
  </script>
</section>
