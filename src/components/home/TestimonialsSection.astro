---
/**
 * TestimonialsSection — Modern 3-Card Slider
 * Optimizado para Astro con componentes reutilizables
 */
import { SectionLabel, SectionTitle, TestimonialCard } from "../ui";

const TESTIMONIALS = [
  {
    quote: "La privacidad absoluta y la ejecución perfecta de nuestra travesía superó todas nuestras expectativas.",
    author: "Alberto de la C.",
    role: "Chárter Privado",
    location: "Ibiza",
    rating: 5,
  },
  {
    quote: "Confiamos la gestión integral de nuestro yate a Cien Mares hace tres años. Su meticulosidad es incomparable.",
    author: "María Valdés",
    role: "Gestión Integral",
    location: "Sotogrande",
    rating: 5,
  },
  {
    quote: "La Academia Náutica te enseña a leer el mar. Una experiencia formativa de élite con instructores excepcionales.",
    author: "Elena Rodríguez",
    role: "Academia Náutica",
    location: "Cádiz",
    rating: 5,
  },
  {
    quote: "El servicio de traslados internacionales fue impecable. Profesionalidad y puntualidad en cada puerto.",
    author: "Carlos Méndez",
    role: "Traslados",
    location: "Málaga",
    rating: 5,
  },
  {
    quote: "Una experiencia inolvidable. El equipo de Cien Mares hizo que nuestra luna de miel fuera mágica.",
    author: "Laura & Javier",
    role: "Chárter Privado",
    location: "Menorca",
    rating: 5,
  },
  {
    quote: "Excelencia en cada detalle. Desde la reserva hasta el desembarco, todo fue perfecto.",
    author: "Roberto Sánchez",
    role: "Eventos Corporativos",
    location: "Marbella",
    rating: 5,
  },
] as const;

const STATS = [
  { value: "4.9", suffix: "/5", label: "Reviews" },
  { value: "500+", label: "Clientes" },
  { value: "15+", label: "Años" },
] as const;

// Responsive items per page
const getItemsPerPage = () => {
  if (typeof window !== 'undefined') {
    if (window.innerWidth < 768) return 1; // Mobile
    if (window.innerWidth < 1024) return 2; // Tablet
  }
  return 3; // Desktop
};

const ITEMS_PER_PAGE = 3; // Default for SSR
const TOTAL_PAGES = Math.ceil(TESTIMONIALS.length / ITEMS_PER_PAGE);
---

<section
  class="relative bg-[#FAFAFA] text-[#0A0A0A] py-28 lg:py-36 overflow-hidden"
  id="testimonials-section"
  data-theme="light"
>
  {/* Background */}
  <div class="absolute inset-0 z-0">
    <div class="absolute top-0 right-0 w-[800px] h-[800px] bg-[#CFA35A]/[0.03] rounded-full blur-[150px]"></div>
    <div class="absolute bottom-0 left-0 w-[600px] h-[600px] bg-[#CFA35A]/[0.02] rounded-full blur-[120px]"></div>
  </div>

  <div class="container mx-auto px-6 lg:px-12 relative z-10 max-w-[1600px]">
    {/* Header */}
    <div class="test-header flex flex-col lg:flex-row lg:items-end justify-between gap-10 mb-16 lg:mb-20">
      <div class="lg:w-1/2">
        <div class="mb-6">
          <SectionLabel label="Testimonios" variant="dark" />
        </div>
        <SectionTitle firstLine="Lo que dicen" secondLine="nuestros clientes" />
      </div>

      {/* Stats */}
      <div class="flex gap-10 lg:pb-2">
        {
          STATS.map((stat) => (
            <div class="text-center group/stat cursor-default">
              <div class="flex items-baseline justify-center gap-1">
                <span class="font-display font-black text-3xl lg:text-4xl group-hover/stat:text-[#CFA35A] transition-colors duration-300">
                  {stat.value}
                </span>
                <span class="font-display text-lg text-[#CFA35A]">{stat.suffix}</span>
              </div>
              <span class="font-mono text-[0.6rem] uppercase tracking-[0.15em] text-[#0A0A0A]/40 group-hover/stat:text-[#0A0A0A]/70 transition-colors relative">
                {stat.label}
                <span class="absolute -bottom-1 left-1/2 -translate-x-1/2 w-0 h-[1px] bg-[#CFA35A] group-hover/stat:w-full transition-all duration-300" />
              </span>
            </div>
          ))
        }
      </div>
    </div>

    {/* Testimonials Grid */}
    <div class="testimonials-wrapper relative">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8" id="testimonials-grid">
        {
          TESTIMONIALS.slice(0, 3).map((testimonial, i) => (
            <TestimonialCard {...testimonial} index={i} />
          ))
        }
      </div>

      {/* Navigation */}
      <div class="flex items-center justify-center gap-6 mt-12">
        <button
          class="test-nav-prev w-14 h-14 rounded-full border-2 border-[#0A0A0A]/10 flex items-center justify-center hover:border-[#CFA35A] hover:bg-[#CFA35A] hover:text-white transition-all duration-300 group"
          aria-label="Anterior"
        >
          <svg
            class="w-5 h-5 text-[#0A0A0A]/50 group-hover:text-white transition-colors"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
          >
            <path d="M19 12H5M12 19l-7-7 7-7" />
          </svg>
        </button>

        {/* Dots - Render max possible (6) and JS will show/hide */}
        <div class="flex items-center gap-3" id="testimonials-dots">
          {TESTIMONIALS.map((_, i) => (
            <button
              class="test-dot w-3 h-3 rounded-full border-2 border-[#0A0A0A]/10 hover:border-[#CFA35A] transition-all duration-300"
              data-index={i}
              aria-label={`Página ${i + 1}`}
              style={i >= 2 ? "display: none;" : ""}
            />
          ))}
        </div>

        <button
          class="test-nav-next w-14 h-14 rounded-full border-2 border-[#0A0A0A]/10 flex items-center justify-center hover:border-[#CFA35A] hover:bg-[#CFA35A] hover:text-white transition-all duration-300 group"
          aria-label="Siguiente"
        >
          <svg
            class="w-5 h-5 text-[#0A0A0A]/50 group-hover:text-white transition-colors"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
          >
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <style>
    .test-dot.active {
      background-color: #cfa35a;
      border-color: #cfa35a;
      transform: scale(1.2);
    }
  </style>

  <script define:vars={{ testimonials: TESTIMONIALS }}>
    // Client-side data and pagination logic
    const allTestimonials = testimonials;
    
    // Responsive items per page
    function getItemsPerPage() {
      if (window.innerWidth < 768) return 1; // Mobile
      if (window.innerWidth < 1024) return 2; // Tablet
      return 3; // Desktop
    }

    function renderTestimonialCard(t, index) {
      const initials = t.author
        .split(" ")
        .map((n) => n[0])
        .join("")
        .substring(0, 2);

      return `
        <div class="test-card group relative" data-index="${index}">
          <div class="relative h-full p-8 lg:p-10 rounded-[2rem] bg-white border border-[#0A0A0A]/5 hover:border-[#CFA35A]/20 transition-all duration-500 hover:shadow-[0_20px_60px_-15px_rgba(207,163,90,0.15)] hover:-translate-y-1">
            <div class="absolute top-0 left-10 right-10 h-[2px] bg-gradient-to-r from-transparent via-[#CFA35A] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <div class="absolute -top-4 -right-4 w-16 h-16 rounded-full bg-gradient-to-br from-[#CFA35A] to-[#8e6f38] flex items-center justify-center shadow-lg shadow-[#CFA35A]/20 group-hover:scale-110 group-hover:rotate-12 transition-all duration-300">
              <svg class="w-7 h-7 text-white" viewBox="0 0 24 24" fill="currentColor">
                <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
              </svg>
            </div>
            <div class="flex gap-1 mb-6">
              ${Array(t.rating).fill('<svg class="w-5 h-5 text-[#CFA35A]" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>').join('')}
            </div>
            <blockquote class="font-body text-[#0A0A0A]/80 leading-relaxed mb-8 text-lg italic">"${t.quote}"</blockquote>
            <div class="flex items-center gap-4 pt-6 border-t border-[#0A0A0A]/5">
              <div class="w-14 h-14 rounded-full bg-gradient-to-br from-[#CFA35A] to-[#8e6f38] flex items-center justify-center shadow-lg group-hover:shadow-[0_0_20px_rgba(207,163,90,0.3)] transition-shadow">
                <span class="font-display font-bold text-base text-white">${initials}</span>
              </div>
              <div class="flex-1">
                <span class="font-display font-bold text-[#0A0A0A] block">${t.author}</span>
                <span class="font-mono text-[0.65rem] uppercase tracking-[0.15em] text-[#0A0A0A]/50">${t.role}</span>
              </div>
              <div class="text-right">
                <span class="font-mono text-[0.6rem] uppercase tracking-[0.1em] text-[#CFA35A]/70 flex items-center gap-1">
                  <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                    <circle cx="12" cy="10" r="3"/>
                  </svg>
                  ${t.location}
                </span>
              </div>
            </div>
          </div>
        </div>
      `;
    }

    // GSAP will be loaded by the page
    if (typeof gsap !== "undefined") {
      gsap.registerPlugin(ScrollTrigger);

      document.addEventListener("astro:page-load", () => {
        // Header animation
        gsap.fromTo(
          ".test-header",
          { y: 50, opacity: 0 },
          {
            y: 0,
            opacity: 1,
            duration: 1,
            ease: "power3.out",
            scrollTrigger: {
              trigger: "#testimonials-section",
              start: "top 80%",
            },
          }
        );

        // Cards animation
        gsap.fromTo(
          ".test-card",
          { y: 60, opacity: 0 },
          {
            y: 0,
            opacity: 1,
            duration: 0.8,
            stagger: 0.15,
            ease: "power3.out",
            scrollTrigger: {
              trigger: ".testimonials-wrapper",
              start: "top 85%",
            },
          }
        );

        // Pagination
        const grid = document.getElementById("testimonials-grid");
        const dots = document.querySelectorAll(".test-dot");
        const prevBtn = document.querySelector(".test-nav-prev");
        const nextBtn = document.querySelector(".test-nav-next");

        let currentPage = 0;
        let itemsPerPage = getItemsPerPage();
        let totalPages = Math.ceil(allTestimonials.length / itemsPerPage);

        // Handle resize with debounce
        let resizeTimeout;
        window.addEventListener('resize', () => {
          clearTimeout(resizeTimeout);
          resizeTimeout = setTimeout(() => {
            const newItemsPerPage = getItemsPerPage();
            if (newItemsPerPage !== itemsPerPage) {
              itemsPerPage = newItemsPerPage;
              totalPages = Math.ceil(allTestimonials.length / itemsPerPage);
              if (currentPage >= totalPages) currentPage = totalPages - 1;
              renderPage(currentPage);
            }
          }, 250);
        });

        function updateDots() {
          // Recalculate total pages
          totalPages = Math.ceil(allTestimonials.length / itemsPerPage);
          
          // Update dots visibility based on total pages
          dots.forEach((dot, i) => {
            dot.style.display = i < totalPages ? 'inline-block' : 'none';
            dot.classList.toggle("active", i === currentPage);
          });
        }

        function renderPage(page) {
          if (!grid) return;

          const start = page * itemsPerPage;
          const pageTestimonials = allTestimonials.slice(start, start + itemsPerPage);

          gsap.to(grid, {
            opacity: 0,
            y: 20,
            duration: 0.3,
            onComplete: () => {
              grid.innerHTML = pageTestimonials
                .map((t, i) => renderTestimonialCard(t, start + i))
                .join("");
              gsap.fromTo(grid, { opacity: 0, y: -20 }, { opacity: 1, y: 0, duration: 0.4 });
            },
          });

          updateDots();
        }

        dots.forEach((dot, i) => {
          dot.addEventListener("click", () => {
            currentPage = i;
            renderPage(currentPage);
          });
        });

        prevBtn?.addEventListener("click", () => {
          currentPage = currentPage > 0 ? currentPage - 1 : totalPages - 1;
          renderPage(currentPage);
        });

        nextBtn?.addEventListener("click", () => {
          currentPage = currentPage < totalPages - 1 ? currentPage + 1 : 0;
          renderPage(currentPage);
        });

        updateDots();
    }
  </script>
</section>
