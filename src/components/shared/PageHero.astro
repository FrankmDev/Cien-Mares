---
/**
 * PageHero — Hero Section para páginas interiores
 * Versión cinemática premium con efectos de profundidad
 */
interface Props {
  backgroundImage: string;
  badge?: {
    text: string;
    subtext?: string;
  };
  title: {
    line1: string;
    line2: string;
  };
  subtitle: string;
  cta: {
    primary: { text: string; href: string };
    secondary: { text: string; href: string };
  };
  stats?: Array<{
    value: string;
    label: string;
  }>;
}

const { backgroundImage, badge, title, subtitle, cta, stats } = Astro.props;
---

<section
  class="relative min-h-[90vh] lg:min-h-screen w-full overflow-hidden bg-[#02060a]"
  id="page-hero"
  data-theme="dark"
>
  {/* Layer 1: Background Image with Ken Burns Effect */}
  <div class="absolute inset-0 z-0">
    <img
      src={backgroundImage}
      alt=""
      class="hero-bg-image w-full h-full object-cover"
      style="filter: grayscale(40%) brightness(0.45) contrast(1.1);"
    />
    {/* Multi-layer gradients for depth */}
    <div class="absolute inset-0 bg-gradient-to-b from-[#02060a]/90 via-[#02060a]/50 to-[#02060a]"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-[#02060a]/70 via-transparent to-[#02060a]/70"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,transparent_0%,rgba(2,6,10,0.6)_70%,#02060a_100%)]"></div>
  </div>

  {/* Layer 2: Animated Particles */}
  <div class="absolute inset-0 z-[1] pointer-events-none overflow-hidden" id="hero-particles">
    {/* Generated by JS */}
  </div>

  {/* Layer 3: Light Rays */}
  <div class="absolute inset-0 z-[2] pointer-events-none overflow-hidden">
    <div class="light-ray absolute top-0 left-1/4 w-[1px] h-full bg-gradient-to-b from-[#CFA35A]/30 via-[#CFA35A]/10 to-transparent transform -rotate-12 origin-top"></div>
    <div class="light-ray absolute top-0 right-1/3 w-[2px] h-full bg-gradient-to-b from-[#CFA35A]/20 via-transparent to-transparent transform rotate-6 origin-top"></div>
  </div>

  {/* Layer 4: Floating Compass */}
  <div class="absolute top-1/4 right-[8%] w-40 h-40 lg:w-56 lg:h-56 opacity-10 z-[2] pointer-events-none hero-compass">
    <svg viewBox="0 0 100 100" fill="none" class="w-full h-full">
      <circle cx="50" cy="50" r="48" stroke="#CFA35A" stroke-width="0.5" stroke-dasharray="4 4"/>
      <circle cx="50" cy="50" r="38" stroke="#CFA35A" stroke-width="0.3"/>
      <circle cx="50" cy="50" r="28" stroke="#CFA35A" stroke-width="0.2"/>
      <path d="M50 5 L53 15 L50 18 L48 15 Z" fill="#CFA35A"/>
      <path d="M50 95 L52 85 L50 82 L48 85 Z" fill="#CFA35A" opacity="0.5"/>
      <path d="M95 50 L85 52 L82 50 L85 48 Z" fill="#CFA35A" opacity="0.5"/>
      <path d="M5 50 L15 52 L18 50 L15 48 Z" fill="#CFA35A" opacity="0.5"/>
      <path d="M50 35 L53 47 L65 50 L53 53 L50 65 L47 53 L35 50 L47 47 Z" fill="#CFA35A" opacity="0.6"/>
    </svg>
  </div>

  {/* Main Content */}
  <div class="relative z-10 h-full flex flex-col justify-center min-h-[90vh] lg:min-h-screen pt-24 pb-12">
    <div class="container mx-auto px-6 lg:px-12 max-w-[1400px]">
      <div class="max-w-4xl">
        
        {/* Badge */}
        {badge && (
          <div class="hero-badge opacity-0 translate-y-6 mb-8">
            <div class="inline-flex items-center gap-3 px-5 py-3 rounded-full bg-white/5 backdrop-blur-md border border-white/10 hover:border-[#CFA35A]/30 transition-all duration-500 group">
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#CFA35A] opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-[#CFA35A]"></span>
              </span>
              <span class="font-mono text-[0.65rem] uppercase tracking-[0.3em] text-white/80 font-bold">{badge.text}</span>
              {badge.subtext && (
                <>
                  <span class="hidden sm:inline-block w-[1px] h-3 bg-white/20"></span>
                  <span class="hidden sm:inline-block font-mono text-[0.6rem] uppercase tracking-[0.2em] text-[#CFA35A]">{badge.subtext}</span>
                </>
              )}
            </div>
          </div>
        )}

        {/* Title with 3D effect */}
        <div class="relative mb-8">
          {/* Shadow layer */}
          <div class="hero-title-shadow absolute inset-0 flex items-center justify-start pointer-events-none opacity-0">
            <span class="font-display font-black text-[clamp(2.5rem,8vw,6rem)] leading-[0.85] tracking-tighter uppercase text-transparent whitespace-nowrap" 
                  style="-webkit-text-stroke: 1px rgba(207,163,90,0.15); transform: translateY(6px);">
              {title.line1} {title.line2}
            </span>
          </div>
          
          <h1 class="hero-title opacity-0 translate-y-8 relative flex flex-wrap items-baseline gap-x-4">
            <span class="font-display font-black text-[clamp(2.5rem,8vw,6rem)] leading-[0.85] tracking-tighter uppercase text-white drop-shadow-2xl">
              {title.line1}
            </span>
            <span class="font-display font-black text-[clamp(2.5rem,8vw,6rem)] leading-[0.85] tracking-tighter uppercase text-transparent bg-clip-text bg-gradient-to-r from-[#CFA35A] via-[#f5e6c8] to-[#CFA35A] animate-gradient-shift">
              {title.line2}
            </span>
          </h1>
        </div>

        {/* Decorative line */}
        <div class="hero-line opacity-0 scale-x-0 origin-left mb-10">
          <div class="flex items-center gap-3">
            <div class="w-20 h-[2px] bg-gradient-to-r from-[#CFA35A] to-transparent"></div>
            <div class="w-2 h-2 rounded-full bg-[#CFA35A] shadow-[0_0_10px_rgba(207,163,90,0.8)]"></div>
            <div class="w-32 h-[2px] bg-[#CFA35A]/40"></div>
            <div class="w-2 h-2 rounded-full bg-[#CFA35A]/60"></div>
            <div class="w-12 h-[2px] bg-gradient-to-l from-transparent to-[#CFA35A]/30"></div>
          </div>
        </div>

        {/* Subtitle */}
        <p class="hero-subtitle opacity-0 translate-y-6 font-body text-lg lg:text-xl text-white/70 max-w-2xl mb-12 leading-relaxed">
          {subtitle}
        </p>

        {/* CTAs */}
        <div class="hero-cta opacity-0 translate-y-6 flex flex-col sm:flex-row gap-4">
          <a
            href={cta.primary.href}
            class="group relative inline-flex items-center justify-center gap-3 px-8 py-4 bg-[#CFA35A] text-[#02060a] rounded-full font-display font-bold text-sm uppercase tracking-[0.15em] overflow-hidden transition-all duration-500 hover:shadow-[0_0_60px_rgba(207,163,90,0.5)] hover:scale-105"
          >
            <span class="relative z-10">{cta.primary.text}</span>
            <svg class="relative z-10 w-4 h-4 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
            <div class="absolute inset-0 bg-white translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-out"></div>
          </a>

          <a
            href={cta.secondary.href}
            class="group inline-flex items-center justify-center gap-3 px-8 py-4 border border-white/30 text-white rounded-full font-display font-bold text-sm uppercase tracking-[0.15em] hover:bg-white/10 hover:border-[#CFA35A]/50 hover:shadow-[0_0_40px_rgba(207,163,90,0.2)] transition-all duration-500 backdrop-blur-sm"
          >
            <span>{cta.secondary.text}</span>
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M19 9l-7 7-7-7"/>
            </svg>
          </a>
        </div>

        {/* Stats */}
        {stats && stats.length > 0 && (
          <div class="hero-stats opacity-0 translate-y-6 mt-16 lg:mt-20 flex flex-wrap gap-10 lg:gap-16">
            {stats.map((stat, i) => (
              <div class="relative group">
                <div class="absolute -inset-4 bg-[#CFA35A]/5 rounded-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                <div class="relative text-center">
                  <span class="block font-display font-black text-3xl lg:text-4xl text-[#CFA35A] group-hover:scale-110 transition-transform duration-300">
                    {stat.value}
                  </span>
                  <span class="font-mono text-[0.6rem] uppercase tracking-[0.2em] text-white/40">
                    {stat.label}
                  </span>
                </div>
                {i < stats.length - 1 && (
                  <div class="hidden lg:block absolute -right-8 top-1/2 -translate-y-1/2 w-px h-12 bg-white/10"></div>
                )}
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  </div>

  {/* Bottom Wave Transition */}
  <div class="absolute bottom-0 left-0 right-0 z-[5]">
    <svg class="w-full h-16 lg:h-24" viewBox="0 0 1440 120" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <linearGradient id="pageWaveGrad" x1="0%" y1="0%" x2="0%" y2="100%">
          <stop offset="0%" stop-color="#02060a" stop-opacity="0.3"/>
          <stop offset="100%" stop-color="#02060a" stop-opacity="1"/>
        </linearGradient>
      </defs>
      <path fill="url(#pageWaveGrad)" fill-opacity="0.4" d="M0,60 C240,100 480,40 720,70 C960,100 1200,40 1440,60 L1440,120 L0,120 Z"/>
      <path fill="#02060a" fill-opacity="0.7" d="M0,80 C360,50 720,90 1080,70 C1260,60 1380,70 1440,80 L1440,120 L0,120 Z"/>
      <path fill="#02060a" d="M0,100 C480,70 960,100 1440,90 L1440,120 L0,120 Z"/>
    </svg>
  </div>

  {/* Corner Info */}
  <div class="absolute bottom-8 right-8 z-20 hidden lg:block text-right">
    <span class="font-mono text-[0.55rem] uppercase tracking-[0.3em] text-white/30 block">Cien Mares</span>
    <span class="font-mono text-[0.55rem] uppercase tracking-[0.3em] text-[#CFA35A]/50 block mt-1">Est. 2010</span>
  </div>
</section>

<style>
  /* Ken Burns animation for background */
  .hero-bg-image {
    animation: ken-burns 30s ease-in-out infinite alternate;
  }
  
  @keyframes ken-burns {
    from { transform: scale(1.05); }
    to { transform: scale(1.2); }
  }

  /* Gradient shift animation */
  .animate-gradient-shift {
    background-size: 200% 200%;
    animation: gradient-shift 8s ease infinite;
  }
  
  @keyframes gradient-shift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  /* Light ray animation */
  .light-ray {
    animation: ray-pulse 6s ease-in-out infinite;
  }
  .light-ray:nth-child(2) {
    animation-delay: -3s;
  }
  
  @keyframes ray-pulse {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 0.5; }
  }

  /* Compass rotation */
  .hero-compass {
    animation: compass-rotate 60s linear infinite;
  }
  
  @keyframes compass-rotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* Floating particles */
  .hero-particle {
    position: absolute;
    background: rgba(207, 163, 90, 0.4);
    border-radius: 50%;
    pointer-events: none;
    animation: float-particle linear infinite;
  }
  
  @keyframes float-particle {
    0% {
      transform: translateY(100vh) translateX(0) scale(0);
      opacity: 0;
    }
    10% { opacity: 0.5; }
    90% { opacity: 0.2; }
    100% {
      transform: translateY(-20vh) translateX(20px) scale(1);
      opacity: 0;
    }
  }
</style>

<script>
  import { gsap } from "gsap";

  document.addEventListener("astro:page-load", () => {
    // Generate particles
    const container = document.getElementById('hero-particles');
    if (container) {
      for (let i = 0; i < 20; i++) {
        const particle = document.createElement('div');
        particle.className = 'hero-particle';
        const size = Math.random() * 3 + 1;
        particle.style.width = size + 'px';
        particle.style.height = size + 'px';
        particle.style.left = Math.random() * 100 + '%';
        particle.style.animationDuration = (Math.random() * 10 + 15) + 's';
        particle.style.animationDelay = Math.random() * 10 + 's';
        particle.style.opacity = (Math.random() * 0.4 + 0.1).toString();
        container.appendChild(particle);
      }
    }

    // Timeline entrance
    const tl = gsap.timeline({ delay: 0.2 });

    tl.to(".hero-badge", {
      opacity: 1,
      y: 0,
      duration: 0.7,
      ease: "power2.out"
    })
    .to(".hero-title-shadow", {
      opacity: 1,
      y: 0,
      duration: 0.8,
      ease: "power3.out"
    }, "-=0.4")
    .to(".hero-title", {
      opacity: 1,
      y: 0,
      duration: 0.9,
      ease: "power3.out"
    }, "-=0.7")
    .to(".hero-line", {
      opacity: 1,
      scaleX: 1,
      duration: 0.7,
      ease: "power2.out"
    }, "-=0.5")
    .to(".hero-subtitle", {
      opacity: 1,
      y: 0,
      duration: 0.6,
      ease: "power2.out"
    }, "-=0.4")
    .to(".hero-cta", {
      opacity: 1,
      y: 0,
      duration: 0.6,
      ease: "power2.out"
    }, "-=0.3")
    .to(".hero-stats", {
      opacity: 1,
      y: 0,
      duration: 0.6,
      ease: "power2.out"
    }, "-=0.3");
  });
</script>
