---
/**
 * Preloader — Modern Oceanic Experience
 * Clean cinematic loading with wave video and refined animations
 */
---

<div
  id="global-preloader-v2"
  class="fixed inset-0 z-[99999] bg-[#02060a] flex flex-col items-center justify-center overflow-hidden"
>
  <!-- Video Background -->
  <div class="absolute inset-0 z-0 overflow-hidden">
    <video
      id="wave-video"
      class="absolute inset-0 w-full h-full object-cover scale-110"
      autoplay
      muted
      loop
      playsinline
      poster="https://images.unsplash.com/photo-1505142468610-359e7d316be0?w=1920&q=80"
    >
      <source
        src="https://assets.mixkit.co/videos/preview/mixkit-waves-in-the-water-1164-large.mp4"
        type="video/mp4"
      />
    </video>
    
    <!-- Ocean Gradient Overlay -->
    <div class="absolute inset-0 bg-gradient-to-b from-[#02060a]/60 via-[#0a1628]/40 to-[#02060a]/80 z-[1]"></div>
    
    <!-- Vignette -->
    <div class="absolute inset-0 z-[2]" style="background: radial-gradient(ellipse at center, transparent 0%, #02060a 90%);"></div>
  </div>

  <!-- Animated Waves SVG -->
  <div class="absolute bottom-0 left-0 right-0 z-[3] pointer-events-none">
    <svg class="absolute bottom-0 w-full h-[150px] lg:h-[250px]" xmlns="http://www.w3.org/2000/svg" viewBox="0 24 150 28" preserveAspectRatio="none">
      <defs>
        <path id="wave-shape" d="M-160 44c30 0 58-18 88-18s58 18 88 18 58-18 88-18 58 18 88 18v44h-352z"/>
      </defs>
      <g class="wave-parallax">
        <use href="#wave-shape" x="48" y="0" fill="rgba(207, 163, 90, 0.05)" />
        <use href="#wave-shape" x="48" y="3" fill="rgba(207, 163, 90, 0.08)" />
        <use href="#wave-shape" x="48" y="5" fill="rgba(207, 163, 90, 0.1)" />
      </g>
    </svg>
  </div>

  <!-- Floating Particles -->
  <div class="absolute inset-0 z-[4] pointer-events-none overflow-hidden">
    <div class="particle p-1"></div>
    <div class="particle p-2"></div>
    <div class="particle p-3"></div>
    <div class="particle p-4"></div>
    <div class="particle p-5"></div>
  </div>

  <!-- Noise Texture -->
  <div class="absolute inset-0 opacity-[0.03] mix-blend-overlay pointer-events-none z-[5]"
    style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%270 0 200 200%27 xmlns=%27http://www.w3.org/2000/svg%27%3E%3Cfilter id=%27n%27%3E%3CfeTurbulence type=%27fractalNoise%27 baseFrequency=%270.9%27 numOctaves=%274%27 stitchTiles=%27stitch%27/%3E%3C/filter%3E%3Crect width=%27100%25%27 height=%27100%25%27 filter=%27url(%23n)%27/%3E%3C/svg%3E');"
  ></div>

  <!-- Main Content -->
  <div class="relative z-20 flex flex-col items-center w-full max-w-7xl px-4">
    
    <!-- Logo Mark -->
    <div class="mb-10 opacity-0 preloader-mark">
      <svg width="56" height="56" viewBox="0 0 48 48" fill="none" class="text-[#CFA35A]">
        <circle cx="24" cy="24" r="22" stroke="currentColor" stroke-width="1.5" class="animate-pulse-slow"/>
        <path d="M24 8v32M8 24h32" stroke="currentColor" stroke-width="1.5"/>
        <circle cx="24" cy="24" r="8" fill="currentColor" opacity="0.8"/>
      </svg>
    </div>

    <!-- Title -->
    <div class="overflow-hidden mb-4">
      <h1 class="preloader-title font-display font-black text-[clamp(3rem,15vw,12rem)] leading-[0.8] tracking-tighter uppercase text-white flex items-center justify-center whitespace-nowrap">
        <span class="inline-block translate-y-[120%] preloader-char">C</span>
        <span class="inline-block translate-y-[120%] preloader-char">I</span>
        <span class="inline-block translate-y-[120%] preloader-char">E</span>
        <span class="inline-block translate-y-[120%] preloader-char">N</span>
        <span class="w-[3vw] md:w-[4vw]"></span>
        <span class="inline-block translate-y-[120%] preloader-char">M</span>
        <span class="inline-block translate-y-[120%] preloader-char">A</span>
        <span class="inline-block translate-y-[120%] preloader-char">R</span>
        <span class="inline-block translate-y-[120%] preloader-char">E</span>
        <span class="inline-block translate-y-[120%] preloader-char">S</span>
      </h1>
    </div>

    <!-- Tagline -->
    <div class="overflow-hidden mb-12">
      <p class="preloader-subtitle font-mono text-[0.65rem] md:text-xs uppercase tracking-[0.5em] text-[#CFA35A]/80 translate-y-[100%]">
        Experiencias Náuticas Premium
      </p>
    </div>

    <!-- Decorative Line -->
    <div class="w-0 h-[1px] bg-gradient-to-r from-transparent via-[#CFA35A]/60 to-transparent rounded-full preloader-line mb-10"></div>
    
    <!-- Progress -->
    <div class="flex items-center gap-4 opacity-0 preloader-progress">
      <span class="font-mono text-[0.6rem] uppercase tracking-[0.3em] text-white/40">Cargando</span>
      <div class="w-20 h-[2px] bg-white/10 rounded-full overflow-hidden">
        <div class="progress-bar h-full bg-[#CFA35A] w-0 rounded-full shadow-[0_0_10px_rgba(207,163,90,0.5)]"></div>
      </div>
      <span class="progress-percent font-mono text-[0.6rem] text-[#CFA35A] w-8 text-right" id="progress-text">0%</span>
    </div>
  </div>

  <!-- Corner Accents -->
  <div class="absolute top-8 left-8 w-16 h-16 border-l border-t border-white/10 z-20"></div>
  <div class="absolute top-8 right-8 w-16 h-16 border-r border-t border-white/10 z-20"></div>
  <div class="absolute bottom-8 left-8 w-16 h-16 border-l border-b border-white/10 z-20"></div>
  <div class="absolute bottom-8 right-8 w-16 h-16 border-r border-b border-white/10 z-20"></div>

  <!-- Wave Transition Overlay -->
  <div class="wave-transition absolute inset-0 z-[15] pointer-events-none" id="wave-transition">
    <div class="wave-layer wave-layer-1"></div>
    <div class="wave-layer wave-layer-2"></div>
    <div class="wave-layer wave-layer-3"></div>
  </div>
</div>

<style>
  /* Wave Animation */
  .wave-parallax use {
    animation: wave-move 20s cubic-bezier(.55,.5,.45,.5) infinite;
  }
  
  .wave-parallax use:nth-child(1) { animation-delay: -2s; animation-duration: 7s; }
  .wave-parallax use:nth-child(2) { animation-delay: -3s; animation-duration: 10s; }
  .wave-parallax use:nth-child(3) { animation-delay: -4s; animation-duration: 13s; }
  
  @keyframes wave-move {
    0% { transform: translate3d(-90px, 0, 0); }
    100% { transform: translate3d(85px, 0, 0); }
  }

  /* Particles */
  .particle {
    position: absolute;
    width: 3px;
    height: 3px;
    background: rgba(207, 163, 90, 0.3);
    border-radius: 50%;
    animation: float 15s ease-in-out infinite;
  }
  
  .p-1 { left: 15%; top: 80%; animation-delay: 0s; }
  .p-2 { left: 30%; top: 60%; animation-delay: -3s; }
  .p-3 { left: 60%; top: 75%; animation-delay: -7s; }
  .p-4 { left: 75%; top: 55%; animation-delay: -5s; }
  .p-5 { left: 90%; top: 70%; animation-delay: -10s; }
  
  @keyframes float {
    0%, 100% { transform: translateY(0) translateX(0); opacity: 0.1; }
    25% { transform: translateY(-30px) translateX(10px); opacity: 0.4; }
    50% { transform: translateY(-60px) translateX(-5px); opacity: 0.2; }
    75% { transform: translateY(-30px) translateX(15px); opacity: 0.3; }
  }

  /* Pulse Animation */
  .animate-pulse-slow {
    animation: pulse-slow 3s ease-in-out infinite;
  }
  
  @keyframes pulse-slow {
    0%, 100% { opacity: 0.5; }
    50% { opacity: 1; }
  }

  /* Wave Transition Layers */
  .wave-transition {
    opacity: 0;
    pointer-events: none;
  }
  
  .wave-layer {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 0;
    background: #02060a;
    transform-origin: bottom;
  }
  
  .wave-layer-1 {
    opacity: 0.9;
    border-radius: 100% 100% 0 0 / 20px 20px 0 0;
  }
  
  .wave-layer-2 {
    opacity: 0.7;
    border-radius: 100% 100% 0 0 / 40px 40px 0 0;
  }
  
  .wave-layer-3 {
    opacity: 1;
  }

  /* Video zoom */
  #wave-video {
    animation: subtle-zoom 25s ease-in-out infinite alternate;
  }
  
  @keyframes subtle-zoom {
    from { transform: scale(1.1); }
    to { transform: scale(1.15); }
  }
</style>

<script>
  import { gsap } from "gsap";

  document.addEventListener("astro:page-load", () => {
    const preloader = document.getElementById("global-preloader-v2");
    const video = document.getElementById("wave-video") as HTMLVideoElement;
    if (!preloader) return;

    document.body.style.overflow = "hidden";

    const progressText = document.getElementById("progress-text");
    const progressBar = document.querySelector(".progress-bar");
    let progress = 0;
    
    const progressInterval = setInterval(() => {
      progress += Math.random() * 12;
      if (progress >= 100) {
        progress = 100;
        clearInterval(progressInterval);
      }
      if (progressText) progressText.textContent = Math.floor(progress) + "%";
      if (progressBar) {
        (progressBar as HTMLElement).style.width = progress + "%";
      }
    }, 120);

    const tl = gsap.timeline({
      onComplete: () => {
        document.body.style.overflow = "";
        document.dispatchEvent(new CustomEvent("preloader:complete"));
      },
    });

    tl.to(".preloader-mark", { opacity: 1, scale: 1, duration: 0.8, ease: "power2.out" }, 0.2)
      .to(".preloader-char", { y: "0%", duration: 1.2, stagger: { each: 0.05, from: "center" }, ease: "power4.out" }, 0.3)
      .to(".preloader-subtitle", { y: "0%", duration: 0.8, ease: "power3.out" }, 0.6)
      .to(".preloader-line", { width: "50vw", duration: 1, ease: "power3.inOut" }, 0.8)
      .to(".preloader-progress", { opacity: 1, duration: 0.5, ease: "power2.out" }, 1)
      .to({}, { duration: 0.8 })
      .to(".progress-bar", { width: "100%", duration: 0.3, ease: "power2.out", onStart: () => { if (progressText) progressText.textContent = "100%"; }})
      .to(".preloader-char", { y: "-30%", opacity: 0, filter: "blur(8px)", duration: 0.6, stagger: { each: 0.02, from: "edges" }, ease: "power2.in" }, "+=0.2")
      .to([".preloader-subtitle", ".preloader-line", ".preloader-progress", ".preloader-mark"], { opacity: 0, y: -15, duration: 0.4, ease: "power2.in" }, "<+=0.1")
      .to(".wave-layer-1", { height: "120vh", duration: 0.9, ease: "power3.inOut" }, "-=0.2")
      .to(".wave-layer-2", { height: "120vh", duration: 0.8, ease: "power3.inOut" }, "-=0.75")
      .to(".wave-layer-3", { height: "120vh", duration: 0.7, ease: "power3.inOut" }, "-=0.65")
      .to("#wave-video", { scale: 1.25, opacity: 0, duration: 0.8, ease: "power2.inOut" }, "-=0.8")
      .to(preloader, { opacity: 0, duration: 0.4, ease: "power2.inOut" }, "-=0.3")
      .set(preloader, { display: "none" });

    setTimeout(() => { if (video) video.pause(); }, 5000);
  });
</script>
