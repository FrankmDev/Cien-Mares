---
/**
 * CTABanner — Banner final de llamada a la acción
 * Transición suave hacia el footer
 */
---

<section class="relative bg-[#02060a]" id="cta-banner" data-theme="dark">
  {/* Background Image Container */}
  <div class="relative h-[500px] lg:h-[600px] overflow-hidden">
    {/* Background Image with Parallax */}
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1505142468610-359e7d316be0?w=1920&q=85"
        alt="Atardecer en el mar"
        class="cta-bg-image absolute -top-[10%] left-0 right-0 w-full h-[120%] object-cover"
        style="filter: brightness(0.4) contrast(1.1) saturate(1.2); will-change: transform;"
      />
      {/* Gradients */}
      <div class="absolute inset-0 bg-gradient-to-r from-[#02060a] via-[#02060a]/50 to-transparent"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-[#02060a] via-transparent to-[#02060a]/40"></div>
    </div>

    {/* Floating Particles */}
    <div class="absolute inset-0 pointer-events-none overflow-hidden" id="cta-particles"></div>

    {/* Main Content */}
    <div class="relative z-10 h-full flex items-center">
      <div class="container mx-auto px-6 lg:px-12 max-w-[1400px]">
        <div class="max-w-3xl">
          {/* Badge */}
          <div class="cta-content inline-flex items-center gap-3 px-5 py-3 rounded-full bg-white/5 backdrop-blur-md border border-white/10 mb-6">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#CFA35A] opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-[#CFA35A]"></span>
            </span>
            <span class="font-mono text-[0.65rem] uppercase tracking-[0.25em] text-white/80 font-bold">Disponibilidad inmediata</span>
          </div>

          {/* Title */}
          <h2 class="cta-content font-display font-black text-4xl md:text-5xl lg:text-6xl uppercase leading-[0.95] text-white mb-6">
            ¿Tienes algo
            <span class="block text-transparent bg-clip-text bg-gradient-to-r from-[#CFA35A] via-[#f5e6c8] to-[#CFA35A]">
              en mente?
            </span>
          </h2>

          {/* Description */}
          <p class="cta-content font-body text-lg text-white/70 leading-relaxed mb-8 max-w-xl">
            Cuéntanoslo y lo organizamos. Cada salida es única y la preparamos a medida.
          </p>

          {/* CTA Buttons */}
          <div class="cta-content flex flex-col sm:flex-row gap-4">
            <a
              href="https://wa.me/34605183785"
              target="_blank"
              rel="noopener noreferrer"
              class="group inline-flex items-center justify-center gap-3 px-8 py-4 bg-[#25D366] text-white rounded-full font-display font-bold text-sm uppercase tracking-[0.1em] transition-all duration-300 hover:shadow-[0_0_40px_rgba(37,211,102,0.4)] hover:scale-105"
            >
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              <span>WhatsApp</span>
            </a>

            <a
              href="/contacto"
              class="group inline-flex items-center justify-center gap-3 px-8 py-4 border border-white/30 text-white rounded-full font-display font-bold text-sm uppercase tracking-[0.1em] hover:bg-white/10 hover:border-[#CFA35A]/50 transition-all duration-300"
            >
              <span>Formulario</span>
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    {/* Decorative Compass */}
    <div class="absolute top-1/2 right-[5%] -translate-y-1/2 hidden xl:block opacity-10">
      <div class="w-40 h-40 animate-spin-slow">
        <svg viewBox="0 0 100 100" fill="none" class="w-full h-full">
          <circle cx="50" cy="50" r="48" stroke="#CFA35A" stroke-width="1" stroke-dasharray="4 4"/>
          <circle cx="50" cy="50" r="35" stroke="#CFA35A" stroke-width="0.5"/>
        </svg>
      </div>
    </div>
  </div>

  {/* Wave Transition - Seamless with footer */}
  <div class="relative h-24 lg:h-32 bg-[#02060a] -mt-1">
    <svg class="absolute bottom-0 w-full h-full" viewBox="0 0 1440 120" preserveAspectRatio="none">
      <defs>
        <linearGradient id="ctaWaveGrad" x1="0%" y1="0%" x2="0%" y2="100%">
          <stop offset="0%" stop-color="#02060a" stop-opacity="0"/>
          <stop offset="100%" stop-color="#02060a" stop-opacity="1"/>
        </linearGradient>
      </defs>
      <path fill="url(#ctaWaveGrad)" d="M0,60 C360,100 720,40 1080,70 C1260,90 1380,60 1440,50 L1440,0 L0,0 Z" transform="scale(1,-1) translate(0,-120)"/>
      <path class="cta-wave" fill="#02060a" fill-opacity="0.5" d="M0,80 C240,40 480,90 720,60 C960,30 1200,80 1440,50 L1440,120 L0,120 Z"/>
    </svg>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("astro:page-load", () => {
    // Generate particles
    const container = document.getElementById('cta-particles');
    if (container) {
      for (let i = 0; i < 12; i++) {
        const particle = document.createElement('div');
        particle.className = 'absolute rounded-full bg-[#CFA35A]';
        particle.style.width = `${Math.random() * 2 + 1}px`;
        particle.style.height = particle.style.width;
        particle.style.left = `${Math.random() * 100}%`;
        particle.style.top = `${Math.random() * 100}%`;
        particle.style.opacity = `${Math.random() * 0.3 + 0.1}`;
        particle.style.animation = `float-cta ${8 + Math.random() * 8}s ease-in-out infinite`;
        particle.style.animationDelay = `${Math.random() * 4}s`;
        container.appendChild(particle);
      }
    }

    // Content animation
    gsap.fromTo(".cta-content", 
      { y: 30, opacity: 0 },
      {
        y: 0,
        opacity: 1,
        duration: 0.7,
        stagger: 0.1,
        ease: "power3.out",
        scrollTrigger: {
          trigger: "#cta-banner",
          start: "top 80%",
        },
      }
    );

    // Background parallax
    gsap.to(".cta-bg-image", {
      yPercent: 8,
      ease: "none",
      scrollTrigger: {
        trigger: "#cta-banner",
        start: "top bottom",
        end: "bottom top",
        scrub: 1,
      },
    });
  });
</script>

<style>
  @keyframes spin-slow {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  
  .animate-spin-slow {
    animation: spin-slow 60s linear infinite;
  }

  .cta-wave {
    animation: wave-drift 8s ease-in-out infinite alternate;
  }

  @keyframes wave-drift {
    from { transform: translateX(-10px); }
    to { transform: translateX(10px); }
  }

  @keyframes float-cta {
    0%, 100% { transform: translateY(0); opacity: 0.1; }
    50% { transform: translateY(-20px); opacity: 0.3; }
  }
</style>
