---
/**
 * RoutesSection — Rutas Disponibles
 * Diseño editorial premium con cards de destinos
 */
import { SectionLabel, SectionTitle } from "../ui";

const ROUTES = [
  {
    id: 'sancti-petri',
    name: 'Sancti Petri',
    distance: '12 millas',
    from: 'El Puerto',
    boatType: 'Velero / Lancha',
    description: 'Fondeo entre las ruinas del castillo y aguas turquesas poco profundas. Uno de los spots más fotografiados de la costa.',
    image: 'https://images.unsplash.com/photo-1507525428034-b723cf961d3e?w=800&q=85',
    duration: 'Medio día',
    difficulty: 'Fácil',
  },
  {
    id: 'conil',
    name: 'Conil',
    distance: '8 millas',
    from: 'El Puerto',
    boatType: 'Todos',
    description: 'Cala Roche, cala del Aceite y los acantilados de Barbate. Playas vírgenes accesibles solo por mar.',
    image: 'https://images.unsplash.com/photo-1559827260-dc66d52bef19?w=800&q=85',
    duration: 'Medio día',
    difficulty: 'Fácil',
  },
  {
    id: 'cadiz',
    name: 'Cádiz Capital',
    distance: '18 millas',
    from: 'El Puerto',
    boatType: 'Yate / Velero',
    description: 'Vista panorámica de la ciudad desde el mar, navegación por la bahía y fondeo junto al castillo de San Sebastián.',
    image: 'https://images.unsplash.com/photo-1523906834658-6e24ef2386f9?w=800&q=85',
    duration: 'Día completo',
    difficulty: 'Media',
  },
  {
    id: 'puerto-santa-maria',
    name: 'El Puerto',
    distance: 'Base',
    from: 'Puerto Sherry',
    boatType: 'Todos',
    description: 'Paseo por la ría de Cádiz, avistamiento de delfines y disfrute de la gastronomía en el propio puerto.',
    image: 'https://images.unsplash.com/photo-1519046904884-53103b34b206?w=800&q=85',
    duration: 'Flexible',
    difficulty: 'Fácil',
  },
  {
    id: 'rota',
    name: 'Rota',
    distance: '25 millas',
    from: 'El Puerto',
    boatType: 'Yate',
    description: 'Cabo Trafalgar y faro, playas de ensueño y aguas cristalinas. Experiencia premium de navegación.',
    image: 'https://images.unsplash.com/photo-1501785888041-af3ef285b470?w=800&q=85',
    duration: 'Día completo',
    difficulty: 'Media',
  },
  {
    id: 'chipiona',
    name: 'Chipiona',
    distance: '30 millas',
    from: 'El Puerto',
    boatType: 'Yate',
    description: 'El faro más alto de España, playas interminables y la desembocadura del Guadalquivir. Aventura completa.',
    image: 'https://images.unsplash.com/photo-1476673160081-cf065571db8c?w=800&q=85',
    duration: 'Día completo',
    difficulty: 'Alta',
  },
] as const;
---

<section class="relative bg-[#FAFAFA] py-28 lg:py-36 overflow-hidden" id="routes-section" data-theme="light">
  {/* Background Pattern */}
  <div class="absolute inset-0 z-0">
    <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-[#0A0A0A]/10 to-transparent"></div>
    <div class="absolute top-1/4 right-0 w-[600px] h-[600px] bg-[#CFA35A]/[0.03] rounded-full blur-[150px]"></div>
  </div>

  <div class="container mx-auto px-6 lg:px-12 relative z-10 max-w-[1400px]">
    {/* Header */}
    <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-8 mb-16 lg:mb-20">
      <div class="lg:w-[55%]">
        <div class="mb-6">
          <SectionLabel label="Destinos" variant="dark" />
        </div>
        <SectionTitle firstLine="Rutas" secondLine="disponibles" />
      </div>
      <div class="lg:w-[40%]">
        <p class="font-body text-base lg:text-lg text-[#0A0A0A]/60 leading-relaxed">
          Desde el Puerto de Santa María, accede a los enclaves más espectaculares de la costa gaditana.
          Cada ruta está diseñada para maximizar tu experiencia.
        </p>
      </div>
    </div>

    {/* Routes Grid - Editorial Layout */}
    <div class="hidden lg:grid grid-cols-12 gap-6 mb-12">
      {/* Featured Route - Large */}
      <div class="route-card-featured col-span-7 row-span-2 group relative">
        <div class="relative h-full min-h-[600px] rounded-3xl overflow-hidden bg-white shadow-xl hover:shadow-2xl transition-all duration-500">
          <div class="absolute inset-0">
            <img
              src={ROUTES[0].image}
              alt={ROUTES[0].name}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="eager"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-[#0A0A0A]/90 via-[#0A0A0A]/40 to-transparent"></div>
          </div>
          
          {/* Content Overlay */}
          <div class="absolute inset-0 flex flex-col justify-end p-8">
            <div class="absolute top-8 left-8">
              <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#CFA35A] text-[#02060a] text-[0.65rem] font-mono uppercase tracking-wider font-bold">
                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
                Destino destacado
              </span>
            </div>
            
            <div class="mb-4">
              <span class="font-mono text-[0.7rem] uppercase tracking-[0.3em] text-[#CFA35A] mb-2 block">
                {ROUTES[0].distance} desde {ROUTES[0].from}
              </span>
              <h3 class="font-display font-black text-5xl uppercase tracking-tight text-white group-hover:text-[#CFA35A] transition-colors duration-300">
                {ROUTES[0].name}
              </h3>
            </div>
            
            <p class="text-white/70 text-base leading-relaxed mb-6 max-w-md">
              {ROUTES[0].description}
            </p>
            
            <div class="flex items-center gap-6">
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-[#CFA35A]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10"/>
                  <path d="M12 6v6l4 2"/>
                </svg>
                <span class="font-mono text-[0.65rem] uppercase tracking-wider text-white/60">{ROUTES[0].duration}</span>
              </div>
              <div class="w-px h-4 bg-white/20"></div>
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-[#CFA35A]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
                </svg>
                <span class="font-mono text-[0.65rem] uppercase tracking-wider text-white/60">{ROUTES[0].boatType}</span>
              </div>
            </div>
          </div>
          
          {/* Hover Border */}
          <div class="absolute inset-0 rounded-3xl border-2 border-transparent group-hover:border-[#CFA35A]/30 transition-all duration-500 pointer-events-none"></div>
        </div>
      </div>

      {/* Side Routes - Smaller */}
      {ROUTES.slice(1, 3).map((route, i) => (
        <div class={`route-card-side col-span-5 group relative ${i === 0 ? '' : ''}`}>
          <div class="relative h-[290px] rounded-3xl overflow-hidden bg-white shadow-lg hover:shadow-xl transition-all duration-500">
            <div class="absolute inset-0">
              <img
                src={route.image}
                alt={route.name}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-[#0A0A0A]/80 via-[#0A0A0A]/30 to-transparent"></div>
            </div>
            
            <div class="absolute inset-0 flex flex-col justify-end p-6">
              <span class="font-mono text-[0.65rem] uppercase tracking-[0.25em] text-[#CFA35A] mb-1">
                {route.distance}
              </span>
              <h3 class="font-display font-black text-2xl uppercase tracking-tight text-white mb-2 group-hover:text-[#CFA35A] transition-colors duration-300">
                {route.name}
              </h3>
              <div class="flex items-center gap-4">
                <span class="font-mono text-[0.6rem] uppercase tracking-wider text-white/50">{route.duration}</span>
                <span class="w-1 h-1 rounded-full bg-white/30"></span>
                <span class="font-mono text-[0.6rem] uppercase tracking-wider text-white/50">{route.boatType}</span>
              </div>
            </div>
            
            <div class="absolute inset-0 rounded-3xl border border-transparent group-hover:border-[#CFA35A]/30 transition-all duration-500 pointer-events-none"></div>
          </div>
        </div>
      ))}

      {/* Bottom Row - 3 Columns */}
      {ROUTES.slice(3).map((route, i) => (
        <div class="route-card-bottom col-span-4 group relative">
          <div class="relative h-[280px] rounded-3xl overflow-hidden bg-white shadow-lg hover:shadow-xl transition-all duration-500">
            <div class="absolute inset-0">
              <img
                src={route.image}
                alt={route.name}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-[#0A0A0A]/80 via-[#0A0A0A]/30 to-transparent"></div>
            </div>
            
            {/* Difficulty Badge */}
            <div class="absolute top-5 right-5">
              <span class={`inline-flex items-center px-2.5 py-1 rounded-full text-[0.55rem] font-mono uppercase tracking-wider font-bold ${
                route.difficulty === 'Fácil' ? 'bg-green-500/20 text-green-400' :
                route.difficulty === 'Media' ? 'bg-yellow-500/20 text-yellow-400' :
                'bg-red-500/20 text-red-400'
              }`}>
                {route.difficulty}
              </span>
            </div>
            
            <div class="absolute inset-0 flex flex-col justify-end p-6">
              <span class="font-mono text-[0.65rem] uppercase tracking-[0.25em] text-[#CFA35A] mb-1">
                {route.distance}
              </span>
              <h3 class="font-display font-black text-xl uppercase tracking-tight text-white mb-2 group-hover:text-[#CFA35A] transition-colors duration-300">
                {route.name}
              </h3>
              <p class="text-white/60 text-sm leading-relaxed line-clamp-2 mb-3">
                {route.description}
              </p>
              <div class="flex items-center gap-3">
                <span class="font-mono text-[0.55rem] uppercase tracking-wider text-white/40">{route.duration}</span>
              </div>
            </div>
            
            <div class="absolute inset-0 rounded-3xl border border-transparent group-hover:border-[#CFA35A]/30 transition-all duration-500 pointer-events-none"></div>
          </div>
        </div>
      ))}
    </div>

    {/* Mobile Carousel */}
    <div class="lg:hidden relative mb-8">
      <div 
        class="flex overflow-x-auto snap-x snap-mandatory scrollbar-hide gap-5 pb-6 -mx-6 px-6"
        id="routes-carousel"
      >
        {ROUTES.map((route, i) => (
          <div 
            class="w-[85vw] shrink-0 snap-center"
            data-route-index={i}
          >
            <div class="relative h-[420px] rounded-3xl overflow-hidden bg-white shadow-lg">
              <div class="absolute inset-0">
                <img
                  src={route.image}
                  alt={route.name}
                  class="w-full h-full object-cover"
                  loading={i === 0 ? "eager" : "lazy"}
                />
                <div class="absolute inset-0 bg-gradient-to-t from-[#0A0A0A]/90 via-[#0A0A0A]/50 to-transparent"></div>
              </div>
              
              <div class="absolute top-5 right-5">
                <span class="inline-flex items-center px-3 py-1.5 rounded-full bg-[#CFA35A] text-[#02060a] text-[0.6rem] font-mono uppercase tracking-wider font-bold">
                  {route.duration}
                </span>
              </div>
              
              <div class="absolute inset-0 flex flex-col justify-end p-6">
                <span class="font-mono text-[0.65rem] uppercase tracking-[0.25em] text-[#CFA35A] mb-1">
                  {route.distance} desde {route.from}
                </span>
                <h3 class="font-display font-black text-2xl uppercase tracking-tight text-white mb-2">
                  {route.name}
                </h3>
                <p class="text-white/70 text-sm leading-relaxed line-clamp-2 mb-4">
                  {route.description}
                </p>
                <div class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-[#CFA35A]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
                  </svg>
                  <span class="font-mono text-[0.6rem] uppercase tracking-wider text-white/60">{route.boatType}</span>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      {/* Mobile Indicators */}
      <div class="flex justify-center gap-2 mt-4">
        {ROUTES.map((_, i) => (
          <button 
            class="route-dot w-2 h-2 rounded-full bg-[#0A0A0A]/20 transition-all duration-300"
            data-index={i}
            aria-label={`Ir a ruta ${i + 1}`}
          ></button>
        ))}
      </div>
    </div>

    {/* CTA */}
    <div class="text-center mt-12 lg:mt-16">
      <a href="/contacto" class="group inline-flex items-center gap-4 px-10 py-5 bg-[#0A0A0A] text-white rounded-full font-display font-bold text-sm uppercase tracking-[0.1em] hover:bg-[#CFA35A] hover:text-[#02060a] hover:shadow-[0_0_40px_rgba(207,163,90,0.4)] transition-all duration-500">
        <span>Planificar mi ruta personalizada</span>
        <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center group-hover:bg-[#02060a]/20 transition-colors">
          <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </div>
      </a>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { cleanupScrollTriggers } from "../../lib/animations";

  gsap.registerPlugin(ScrollTrigger);

  const triggers: (string | Element | null)[] = [];

  document.addEventListener("astro:page-load", () => {
    // Featured card animation
    gsap.fromTo(".route-card-featured",
      { x: -60, opacity: 0 },
      {
        x: 0,
        opacity: 1,
        duration: 1,
        ease: "power3.out",
        scrollTrigger: {
          trigger: "#routes-section",
          start: "top 70%",
          toggleActions: "play none none reverse",
        },
      }
    );

    // Side cards animation
    gsap.fromTo(".route-card-side",
      { y: 40, opacity: 0 },
      {
        y: 0,
        opacity: 1,
        duration: 0.8,
        stagger: 0.15,
        ease: "power3.out",
        scrollTrigger: {
          trigger: "#routes-section",
          start: "top 65%",
          toggleActions: "play none none reverse",
        },
      }
    );

    // Bottom cards animation
    gsap.fromTo(".route-card-bottom",
      { y: 50, opacity: 0 },
      {
        y: 0,
        opacity: 1,
        duration: 0.7,
        stagger: 0.1,
        ease: "power3.out",
        scrollTrigger: {
          trigger: ".route-card-bottom",
          start: "top 85%",
          toggleActions: "play none none reverse",
        },
      }
    );

    // Mobile carousel dots
    const carousel = document.getElementById('routes-carousel');
    const dots = document.querySelectorAll('.route-dot');
    
    if (carousel && dots.length > 0) {
      dots[0]?.classList.add('active');
      
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const index = parseInt(entry.target.getAttribute('data-route-index') || '0');
            dots.forEach((dot, i) => {
              dot.classList.toggle('active', i === index);
            });
          }
        });
      }, { root: carousel, threshold: 0.5 });

      carousel.querySelectorAll('[data-route-index]').forEach(slide => {
        observer.observe(slide);
      });

      dots.forEach((dot, i) => {
        dot.addEventListener('click', () => {
          const slide = carousel.querySelector(`[data-route-index="${i}"]`);
          slide?.scrollIntoView({ behavior: 'smooth', inline: 'center' });
        });
      });
    }

    triggers.push("#routes-section");
  });

  document.addEventListener("astro:before-swap", () => {
    cleanupScrollTriggers(triggers);
  });
</script>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  
  .route-dot.active {
    background-color: #CFA35A;
    width: 1.5rem;
  }
</style>
